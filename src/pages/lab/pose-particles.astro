---
// Full-screen pose-driven particle field.
// Multi-person via @mediapipe/tasks-vision PoseLandmarker (numPoses:2).
// Audio reactivity via Web Audio API AnalyserNode.
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Pose Particles | voidstar lab</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --accent:    #8b5cf6;
      --cyan:      #22d3ee;
      --pink:      #f472b6;
      --green:     #4ade80;
      --void:      #05050d;
      --surface:   rgba(10,10,26,0.82);
      --border:    rgba(45,45,80,0.7);
      --text:      #dde1f0;
      --muted:     #7878a8;
      --font-mono: 'JetBrains Mono', ui-monospace, monospace;
    }
    html, body { width: 100%; height: 100%; overflow: hidden; background: var(--void); }
    canvas { position: fixed; inset: 0; width: 100%; height: 100%; display: block; }

    #video {
      position: fixed; bottom: 1.25rem; right: 1.25rem;
      width: 220px; height: auto;
      /* aspect-ratio is set from JS once the camera stream metadata loads,
         so the thumbnail always matches the camera's native ratio — no crop */
      display: block;
      border-radius: 8px; border: 1px solid var(--border);
      opacity: 0.78; transform: scaleX(-1); z-index: 10;
      transition: opacity 0.2s, width 0.3s, top 0.3s, left 0.3s, bottom 0.3s, right 0.3s;
    }
    #video.hidden { opacity: 0; pointer-events: none; }
    #video.size-large  { width: 420px; }
    #video.size-full {
      top: 0; left: 0; right: 0; bottom: 0;
      width: 100vw; height: 100vh;
      opacity: 0.35; border-radius: 0; border: none;
      object-fit: contain; background: black;
    }

    #topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 20;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.6rem 1.25rem;
      background: var(--surface); backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      font-family: var(--font-mono); font-size: 0.8rem;
      transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), opacity 0.35s ease;
    }
    #topbar.zen { transform: translateY(-110%); opacity: 0; pointer-events: none; }
    #topbar-left  { display: flex; align-items: center; gap: 1rem; }
    #topbar-right { display: flex; align-items: center; gap: 0.6rem; }

    .back-link { color: var(--muted); text-decoration: none; display: flex; align-items: center; gap: 0.35rem; }
    .back-link:hover { color: var(--accent); }
    .experiment-title { color: var(--text); font-weight: 500; }
    .experiment-tag   { color: var(--accent); }
    #fps    { color: var(--muted); min-width: 5ch; }
    #pcount { color: var(--muted); min-width: 7ch; }
    #pose-count { color: var(--muted); min-width: 6ch; }
    #cam-res    { color: var(--muted); font-size: 0.72rem; opacity: 0.7; }

    .ctrl-btn {
      background: none; border: 1px solid var(--border); border-radius: 5px;
      color: var(--muted); font-family: var(--font-mono); font-size: 0.75rem;
      padding: 0.25rem 0.6rem; cursor: pointer;
      transition: all 0.15s; white-space: nowrap;
      text-decoration: none; display: inline-block;
    }
    .ctrl-btn:hover  { border-color: var(--accent); color: var(--accent); }
    .ctrl-btn.active { border-color: var(--cyan);   color: var(--cyan);   }
    .ctrl-btn.active-audio { border-color: var(--pink); color: var(--pink); }
    select.ctrl-btn {
      max-width: 160px; appearance: none;
      padding-right: 1.2rem;
      background-image: linear-gradient(45deg, transparent 50%, var(--muted) 50%),
                        linear-gradient(135deg, var(--muted) 50%, transparent 50%);
      background-position: calc(100% - 10px) 50%, calc(100% - 5px) 50%;
      background-size: 5px 5px; background-repeat: no-repeat;
    }
    select.ctrl-btn option { background: var(--surface); color: var(--text); }

    /* Zen handle */
    #zen-handle {
      position: fixed; top: 0; right: 1rem; z-index: 25;
      width: 44px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; opacity: 0; pointer-events: none;
      transition: opacity 0.5s ease;
    }
    #zen-handle.visible { opacity: 1; pointer-events: auto; }
    .zen-icon {
      font-size: 1.4rem; color: var(--accent); opacity: 0.8;
      animation: zen-spin 14s linear infinite;
      filter: drop-shadow(0 0 8px var(--accent)) drop-shadow(0 0 16px var(--accent));
      transition: opacity 0.2s; user-select: none; line-height: 1;
    }
    #zen-handle:hover .zen-icon { opacity: 1; filter: drop-shadow(0 0 12px var(--accent)) drop-shadow(0 0 24px var(--cyan)); }
    @keyframes zen-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

    /* Status overlay */
    #status-overlay {
      position: fixed; inset: 0; z-index: 30;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 1.25rem;
      background: rgba(5,5,13,0.93); font-family: var(--font-mono);
      transition: opacity 0.5s;
    }
    #status-overlay.hidden { opacity: 0; pointer-events: none; }
    .status-title { font-size: 1.1rem; color: var(--text); letter-spacing: 0.08em; }
    .status-msg   { font-size: 0.8rem; color: var(--muted); letter-spacing: 0.05em; }
    .status-dot   {
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--accent); box-shadow: 0 0 12px var(--accent);
      animation: pulse 1.4s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100% { opacity:0.4; transform:scale(0.9); } 50% { opacity:1; transform:scale(1.2); } }
    .start-btn {
      margin-top: 0.5rem; padding: 0.65rem 1.5rem;
      background: var(--accent); border: none; border-radius: 6px;
      color: white; font-family: var(--font-mono); font-size: 0.875rem;
      cursor: pointer; transition: all 0.2s;
    }
    .start-btn:hover { background: #7c3aed; box-shadow: 0 0 20px rgba(139,92,246,0.5); }

    #hints {
      position: fixed; bottom: 1.25rem; left: 1.25rem; z-index: 10;
      font-family: var(--font-mono); font-size: 0.68rem; color: var(--muted);
      display: flex; flex-direction: column; gap: 0.25rem; opacity: 0.6;
      transition: opacity 0.3s;
    }
    kbd {
      display: inline-block; background: rgba(45,45,80,0.8);
      border-radius: 3px; padding: 0 4px; color: var(--text);
    }

    #audio-panel {
      position: fixed; bottom: 1.25rem; left: 50%;
      transform: translateX(-50%);
      z-index: 15;
      background: var(--surface); backdrop-filter: blur(12px);
      border: 1px solid var(--border); border-radius: 10px;
      padding: 0.75rem 1rem; font-family: var(--font-mono);
      font-size: 0.72rem; color: var(--text-muted);
      display: flex; flex-direction: column; gap: 0.5rem;
      min-width: 280px;
    }
    .ap-presets {
      display: flex; align-items: center; gap: 0.4rem;
    }
    .ap-label { color: var(--text-dim); margin-right: 0.2rem; }
    .ap-preset {
      background: none; border: 1px solid var(--border);
      border-radius: 4px; color: var(--muted);
      font-family: var(--font-mono); font-size: 0.68rem;
      padding: 0.15rem 0.5rem; cursor: pointer;
      transition: all 0.15s;
    }
    .ap-preset:hover  { border-color: var(--accent); color: var(--accent); }
    .ap-preset.active { border-color: var(--pink);   color: var(--pink); }
    .ap-row {
      display: grid; grid-template-columns: 1fr auto;
      align-items: center; gap: 0.5rem;
    }
    .ap-row label {
      display: flex; align-items: center; gap: 0.35rem;
      color: var(--text-dim); white-space: nowrap;
    }
    .ap-val { color: var(--cyan); min-width: 5ch; text-align: right; }
    .ap-row input[type=range] {
      width: 130px; accent-color: var(--accent);
      cursor: pointer;
    }
  </style>
</head>
<body>

<canvas id="canvas"></canvas>
<video id="video" autoplay playsinline muted></video>

<div id="topbar">
  <div id="topbar-left">
    <a href="/lab" class="back-link">← lab</a>
    <span class="experiment-title">pose particles</span>
    <span class="experiment-tag">// mediapipe · canvas2d</span>
  </div>
  <div id="topbar-right">
    <span id="fps">-- fps</span>
    <span id="pcount">---- pts</span>
    <span id="pose-count">0 pose</span>
    <span id="cam-res"></span>
    <select id="cam-select" class="ctrl-btn" title="Choose camera" style="display:none;"></select>
    <button class="ctrl-btn" id="btn-trails">trails</button>
    <button class="ctrl-btn active" id="btn-camera">camera</button>
    <button class="ctrl-btn" id="btn-overlay" title="Skeleton overlay (P)">skeleton</button>
    <button class="ctrl-btn" id="btn-audio" title="Mic audio reactivity (M)">audio</button>
    <button class="ctrl-btn" id="btn-rotate" title="Rotate camera (O / 0)">rot 0°</button>
    <button class="ctrl-btn" id="btn-pause">pause</button>
    <button class="ctrl-btn" id="btn-zen" title="Zen mode (Z)">zen</button>
    <a href="https://github.com/randbrown" target="_blank" rel="noopener" class="ctrl-btn">source ↗</a>
  </div>
</div>

<div id="zen-handle" title="Exit zen mode (Z)">
  <span class="zen-icon">✦</span>
</div>

<div id="status-overlay">
  <div class="status-dot"></div>
  <div class="status-title">pose particles</div>
  <div class="status-msg" id="status-msg">click start to enable camera</div>
  <button class="start-btn" id="start-btn">enable camera →</button>
</div>

<div id="hints">
  <span><kbd>Space</kbd> pause</span>
  <span><kbd>T</kbd> trails</span>
  <span><kbd>C</kbd> cam size</span>
  <span><kbd>P</kbd> skeleton</span>
  <span><kbd>M</kbd> audio</span>
  <span><kbd>O</kbd> / <kbd>0</kbd> rotate</span>
  <span><kbd>Z</kbd> zen</span>
  <span><kbd>R</kbd> reset</span>
</div>

<div id="audio-panel" style="display:none">
  <div class="ap-presets">
    <span class="ap-label">preset</span>
    <button class="ap-preset" data-preset="acoustic">acoustic</button>
    <button class="ap-preset" data-preset="edm">EDM</button>
    <button class="ap-preset" data-preset="metal">metal</button>
  </div>
  <div class="ap-row">
    <label>gain<span class="ap-val" id="ap-gain-val">1.0×</span></label>
    <input type="range" id="ap-gain" min="0.25" max="4" step="0.05" value="1">
  </div>
  <div class="ap-row">
    <label>beat thresh<span class="ap-val" id="ap-thresh-val">1.45</span></label>
    <input type="range" id="ap-thresh" min="1.1" max="2.5" step="0.05" value="1.45">
  </div>
  <div class="ap-row">
    <label>beat gap<span class="ap-val" id="ap-cooldown-val">350ms</span></label>
    <input type="range" id="ap-cooldown" min="80" max="600" step="10" value="350">
  </div>
  <div class="ap-row">
    <label>response<span class="ap-val" id="ap-ema-val">slow←→fast</span></label>
    <input type="range" id="ap-ema" min="0.04" max="0.40" step="0.01" value="0.12">
  </div>
</div>

<script>
// ── Constants ─────────────────────────────────────────────────────────────────
const N               = 9000;
const DAMPING         = 0.972;
const CURL_SCALE      = 0.0018;
const CURL_SPEED      = 0.22;
const CURL_STR_BASE   = 0.28;
const ATTRACT_STR_BASE = 420;
const ATTRACT_RAD     = 0.38;
const SPAWN_VEL       = 1.4;

const REPEL_JOINTS = new Set([15, 16]); // wrists

const LM_WEIGHT = {
  0:  0.6,
  11: 1.0, 12: 1.0,
  13: 0.9, 14: 0.9,
  15: 1.5, 16: 1.5,
  23: 0.8, 24: 0.8,
  25: 0.7, 26: 0.7,
  27: 0.6, 28: 0.6,
};

// Per-person overlay colour palettes
const PERSON_PALETTE = [
  { boneA: 'rgba(139,92,246,0.75)',  boneB: 'rgba(34,211,238,0.75)',
    attractor: 'rgba(139,92,246,0.95)', repeller: 'rgba(34,211,238,0.95)',
    halo: 'rgba(139,92,246,0.18)' },
  { boneA: 'rgba(244,114,182,0.75)', boneB: 'rgba(74,222,128,0.75)',
    attractor: 'rgba(244,114,182,0.95)', repeller: 'rgba(74,222,128,0.95)',
    halo: 'rgba(244,114,182,0.18)' },
];

// Audio beat detection — mutable, controlled by UI sliders
let audioGain     = 1.0;   // pre-gain multiplier applied to all bands
let audioEMA      = 0.12;  // per-frame smoothing alpha (higher = faster/jitterier)
let beatThresh    = 1.45;  // bass/rolling-avg ratio to call a beat
let beatCooldown  = 350;   // ms minimum between beats

// Frequency-band bin indices — computed from actual sample rate in startAudio()
let binBassLo = 0,  binBassHi = 8;   // fallback defaults
let binMidsLo = 8,  binMidsHi = 80;
let binHighsLo= 80, binHighsHi= 200;

const AUDIO_PRESETS = {
  acoustic: { gain: 2.5, ema: 0.09, thresh: 1.25, cooldown: 550,
    label: 'acoustic / quiet mic' },
  edm:      { gain: 1.0, ema: 0.15, thresh: 1.38, cooldown: 360,
    label: 'EDM / club' },
  metal:    { gain: 0.7, ema: 0.30, thresh: 1.80, cooldown: 110,
    label: 'metal / blast beats' },
};

// Skeleton connections (MediaPipe Pose landmark index pairs)
const SKELETON_CONNECTIONS = [
  [11,12], [11,13],[13,15], [12,14],[14,16],
  [11,23], [12,24], [23,24],
  [23,25],[25,27], [24,26],[26,28],
  [27,29],[27,31],[29,31], [28,30],[28,32],[30,32],
];

// ── Camera rotation ───────────────────────────────────────────────────────────
let cameraRotation = 0;

function applyRotation(lx, ly, W, H) {
  const cx = W/2, cy = H/2, dx = lx-cx, dy = ly-cy;
  switch (cameraRotation) {
    case  90: return [cx+dy, cy-dx];
    case 180: return [cx-dx, cy-dy];
    case 270: return [cx-dy, cy+dx];
    default:  return [lx, ly];
  }
}

function lmToCanvas(lmx, lmy, W, H) {
  return applyRotation((1 - lmx) * W, lmy * H, W, H);
}
function updateVideoTransform() {
  videoEl.style.transform = `scaleX(-1) rotate(${cameraRotation}deg)`;
}

// ── Canvas ────────────────────────────────────────────────────────────────────
const canvas = document.getElementById('canvas');
const ctx    = canvas.getContext('2d');
function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
resize();
window.addEventListener('resize', resize);

// ── Particle state ────────────────────────────────────────────────────────────
const px   = new Float32Array(N);
const py   = new Float32Array(N);
const vx   = new Float32Array(N);
const vy   = new Float32Array(N);
const age  = new Float32Array(N);
const life = new Float32Array(N);
const hue  = new Float32Array(N);

function spawnParticle(i) {
  px[i] = Math.random() * canvas.width;
  py[i] = Math.random() * canvas.height;
  const a = Math.random() * Math.PI * 2;
  const s = (0.3 + Math.random() * 0.7) * SPAWN_VEL;
  vx[i] = Math.cos(a) * s; vy[i] = Math.sin(a) * s;
  life[i] = 4 + Math.random() * 6;
  age[i]  = Math.random() * life[i];
  hue[i]  = (Math.random() - 0.5) * 60;
}
for (let i = 0; i < N; i++) spawnParticle(i);

// ── Curl noise ────────────────────────────────────────────────────────────────
function potential(x, y, t) {
  const s = CURL_SCALE;
  return Math.sin(x*s*1.0 + t*0.31) * Math.cos(y*s*0.9 - t*0.19)
       + Math.sin(x*s*0.6 - y*s*1.3 + t*0.11) * 0.6
       + Math.cos(x*s*1.5 + y*s*0.7 - t*0.27) * 0.35;
}
function curlForce(x, y, t, str) {
  const e = 2.5;
  const dpdx = (potential(x+e,y,t) - potential(x-e,y,t)) / (2*e);
  const dpdy = (potential(x,y+e,t) - potential(x,y-e,t)) / (2*e);
  return [dpdy * str, -dpdx * str];
}

// ── Audio state ───────────────────────────────────────────────────────────────
let audioEnabled = false;
let analyserNode = null;
let freqBuf      = null;
let aBass = 0, aMids = 0, aHighs = 0; // smoothed 0..1
let bassAvg    = 0;
let lastBeatMs = 0;
let beatActive = false;

function avgBins(buf, lo, hi) {
  let s = 0;
  for (let i = lo; i < hi; i++) s += buf[i];
  return s / (hi - lo);
}

function tickAudio() {
  if (!audioEnabled || !analyserNode) { beatActive = false; return; }
  analyserNode.getByteFrequencyData(freqBuf);
  // Apply gain then clamp to 0-1
  const g = audioGain;
  const rawBass  = Math.min(avgBins(freqBuf, binBassLo,  binBassHi)  / 255 * g, 1);
  const rawMids  = Math.min(avgBins(freqBuf, binMidsLo,  binMidsHi)  / 255 * g, 1);
  const rawHighs = Math.min(avgBins(freqBuf, binHighsLo, binHighsHi) / 255 * g, 1);
  aBass  += audioEMA * (rawBass  - aBass);
  aMids  += audioEMA * (rawMids  - aMids);
  aHighs += audioEMA * (rawHighs - aHighs);

  bassAvg = 0.97 * bassAvg + 0.03 * rawBass;
  const now = performance.now();
  beatActive = rawBass > bassAvg * beatThresh && now - lastBeatMs > beatCooldown;
  if (beatActive) lastBeatMs = now;
}

// ── Shockwaves (spawned on beat) ──────────────────────────────────────────────
const shockwaves = []; // { x, y, r, palette }

function spawnShockwaves() {
  for (let p = 0; p < allLandmarks.length; p++) {
    const pal = PERSON_PALETTE[p % PERSON_PALETTE.length];
    const W = canvas.width, H = canvas.height;
    // Spawn from wrists (most expressive joints)
    for (const idx of [15, 16, 11, 12]) {
      const lm = allLandmarks[p]?.[idx];
      if (!lm || lm.visibility < 0.4) continue;
      const [x, y] = lmToCanvas(lm.x, lm.y, W, H);
      shockwaves.push({ x, y, r: 4, alpha: 0.9 * aBass, palette: pal });
    }
  }
}

// ── Pose state ────────────────────────────────────────────────────────────────
let allLandmarks = []; // Array<Array<{x,y,z,visibility}>>

// ── Simulation ────────────────────────────────────────────────────────────────
let simTime     = 0;
let paused      = false;
let trailMode   = false;
let showOverlay = false;
let lastTime    = performance.now();

function update(dt) {
  simTime += dt * CURL_SPEED;

  tickAudio();

  // Audio-modulated physics params
  const curlStr    = audioEnabled ? CURL_STR_BASE * (0.5 + aMids * 3.0)   : CURL_STR_BASE;
  const attractStr = audioEnabled ? ATTRACT_STR_BASE * (1 + aBass * 2.5)  : ATTRACT_STR_BASE;

  const W = canvas.width, H = canvas.height;
  const maxR  = W * ATTRACT_RAD;
  const maxR2 = maxR * maxR;

  // Flatten all active attractor positions across all persons
  const attractors = [];
  for (const personLms of allLandmarks) {
    for (const [k, weight] of Object.entries(LM_WEIGHT)) {
      const lm = personLms[Number(k)];
      if (!lm || lm.visibility < 0.4) continue;
      const [lx, ly] = lmToCanvas(lm.x, lm.y, W, H);
      attractors.push({ lx, ly, weight, repel: REPEL_JOINTS.has(Number(k)) });
    }
  }

  // Beat → shockwaves
  if (beatActive && attractors.length) spawnShockwaves();

  for (let i = 0; i < N; i++) {
    age[i] += dt;
    if (age[i] >= life[i]) { spawnParticle(i); continue; }

    // Curl noise
    const [cfx, cfy] = curlForce(px[i], py[i], simTime, curlStr);
    vx[i] += cfx; vy[i] += cfy;

    // Highs → random scatter
    if (audioEnabled && aHighs > 0.08) {
      vx[i] += (Math.random() - 0.5) * aHighs * 3;
      vy[i] += (Math.random() - 0.5) * aHighs * 3;
    }

    // Landmark forces (all persons)
    for (const { lx, ly, weight, repel } of attractors) {
      const dx = lx - px[i], dy = ly - py[i];
      const d2 = dx*dx + dy*dy;
      if (d2 > maxR2 || d2 < 1) continue;
      const d   = Math.sqrt(d2);
      const mag = (attractStr * weight) / (d2 + 200);
      const sgn = repel ? -1 : 1;
      vx[i] += (dx/d) * mag * sgn;
      vy[i] += (dy/d) * mag * sgn;
    }

    // Beat burst: push particles outward from nearest joint
    if (beatActive && attractors.length) {
      let minD2 = Infinity, bx = 0, by = 0;
      for (const { lx, ly } of attractors) {
        const d2 = (lx-px[i])**2 + (ly-py[i])**2;
        if (d2 < minD2) { minD2 = d2; bx = lx; by = ly; }
      }
      if (minD2 < maxR2) {
        const d = Math.sqrt(minD2);
        const bm = 7 * aBass;
        vx[i] += ((px[i]-bx)/d) * bm;
        vy[i] += ((py[i]-by)/d) * bm;
      }
    }

    vx[i] *= DAMPING; vy[i] *= DAMPING;
    px[i] += vx[i];   py[i] += vy[i];

    // Wrap edges
    if (px[i] <  0) px[i] += W; if (px[i] > W) px[i] -= W;
    if (py[i] <  0) py[i] += H; if (py[i] > H) py[i] -= H;
  }
}

// ── Draw ──────────────────────────────────────────────────────────────────────
function draw() {
  const W = canvas.width, H = canvas.height;

  // Trail fade — bass pumps it slightly faster (more energy = shorter trails)
  const baseFade = trailMode ? 0.07 : 0.16;
  const fade     = audioEnabled ? baseFade * (1 + aBass * 0.6) : baseFade;
  ctx.globalCompositeOperation = 'source-over';
  ctx.fillStyle = `rgba(5,5,13,${fade})`;
  ctx.fillRect(0, 0, W, H);

  // Beat flash — subtle purple bloom
  if (beatActive) {
    ctx.fillStyle = `rgba(139,92,246,${aBass * 0.07})`;
    ctx.fillRect(0, 0, W, H);
  }

  // Particles (additive blending)
  ctx.globalCompositeOperation = 'lighter';
  for (let i = 0; i < N; i++) {
    const speed    = Math.sqrt(vx[i]*vx[i] + vy[i]*vy[i]);
    // Audio highs → hue shift toward warmer colours
    const hueShift = audioEnabled ? aHighs * 40 : 0;
    const t01      = Math.min(speed / 4.5, 1);
    const h        = 270 + hue[i] + hueShift + t01 * 70;
    const l        = 45 + t01 * 30;
    const alpha    = 0.5 + t01 * 0.4;
    const radius   = 0.85 + t01 * 0.65;
    const lifeFrac = age[i] / life[i];
    const fadePt   = lifeFrac > 0.85 ? 1 - (lifeFrac - 0.85) / 0.15 : 1;
    ctx.fillStyle = `hsla(${h},80%,${l}%,${alpha * fadePt})`;
    ctx.fillRect(px[i]-radius, py[i]-radius, radius*2, radius*2);
  }

  // Shockwave rings
  for (let i = shockwaves.length - 1; i >= 0; i--) {
    const sw = shockwaves[i];
    sw.r    += 9;
    sw.alpha *= 0.82;
    if (sw.alpha < 0.02) { shockwaves.splice(i, 1); continue; }
    const pal = sw.palette;
    ctx.globalCompositeOperation = 'lighter';
    ctx.beginPath();
    ctx.arc(sw.x, sw.y, sw.r, 0, Math.PI * 2);
    ctx.strokeStyle = pal.boneA.replace(/[\d.]+\)$/, `${sw.alpha})`);
    ctx.lineWidth = 2;
    ctx.stroke();
  }

  ctx.globalCompositeOperation = 'source-over';

  // Audio level bars — bottom-left strip (bass | mids | highs)
  if (audioEnabled) {
    const barW = 3, gap = 3, maxH = 50;
    const bx   = 12, by = H - 12;
    const levels = [aBass, aMids, aHighs];
    const cols   = ['rgba(139,92,246,0.85)', 'rgba(34,211,238,0.85)', 'rgba(244,114,182,0.85)'];
    levels.forEach((lvl, j) => {
      const h = Math.max(2, lvl * maxH);
      ctx.fillStyle = cols[j];
      ctx.fillRect(bx + j*(barW+gap), by - h, barW, h);
    });
  }

  if (showOverlay) drawPoseOverlay();
}

// ── Pose skeleton overlay ─────────────────────────────────────────────────────
function drawPoseOverlay() {
  if (!allLandmarks.length) return;
  const W = canvas.width, H = canvas.height;

  function lmPos(lm) { return lmToCanvas(lm.x, lm.y, W, H); }

  ctx.save();
  ctx.globalCompositeOperation = 'source-over';

  allLandmarks.forEach((personLms, pIdx) => {
    const pal = PERSON_PALETTE[pIdx % PERSON_PALETTE.length];

    // Bones (gradient per connection)
    ctx.lineWidth = 1.8; ctx.lineCap = 'round';
    for (const [a, b] of SKELETON_CONNECTIONS) {
      const lmA = personLms[a], lmB = personLms[b];
      if (!lmA || !lmB || lmA.visibility < 0.35 || lmB.visibility < 0.35) continue;
      const [ax, ay] = lmPos(lmA);
      const [bx, by] = lmPos(lmB);
      const grad = ctx.createLinearGradient(ax, ay, bx, by);
      grad.addColorStop(0, pal.boneA); grad.addColorStop(1, pal.boneB);
      ctx.strokeStyle = grad;
      ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx, by); ctx.stroke();
    }

    // Joints
    for (const [k, weight] of Object.entries(LM_WEIGHT)) {
      const idx = Number(k);
      const lm  = personLms[idx];
      if (!lm || lm.visibility < 0.35) continue;
      const [x, y] = lmPos(lm);
      const r = 2 + weight * 2;

      // Audio bass → pulse joint radius
      const pulse = audioEnabled ? 1 + aBass * 1.8 : 1;

      ctx.beginPath(); ctx.arc(x, y, (r+4)*pulse, 0, Math.PI*2);
      ctx.fillStyle = pal.halo; ctx.fill();

      ctx.beginPath(); ctx.arc(x, y, r * pulse, 0, Math.PI*2);
      ctx.fillStyle = REPEL_JOINTS.has(idx) ? pal.repeller : pal.attractor;
      ctx.fill();
    }
  });

  ctx.restore();
}

// ── Render loop ───────────────────────────────────────────────────────────────
const fpsEl      = document.getElementById('fps');
const pcountEl   = document.getElementById('pcount');
const poseCountEl = document.getElementById('pose-count');
let frameCount = 0, fpsTimer = 0;

function loop(now) {
  requestAnimationFrame(loop);
  const dt = Math.min((now - lastTime) / 1000, 0.05);
  lastTime = now;
  frameCount++; fpsTimer += dt;
  if (fpsTimer >= 0.5) {
    fpsEl.textContent      = `${Math.round(frameCount/fpsTimer)} fps`;
    pcountEl.textContent   = `${N.toLocaleString()} pts`;
    poseCountEl.textContent = `${allLandmarks.length} pose${allLandmarks.length !== 1 ? 's' : ''}`;
    frameCount = 0; fpsTimer = 0;
  }
  if (!paused) { update(dt); draw(); }
}
requestAnimationFrame(loop);

// ── MediaPipe boot — tasks-vision PoseLandmarker (multi-person) ───────────────
const overlay   = document.getElementById('status-overlay');
const statusMsg = document.getElementById('status-msg');
const startBtn  = document.getElementById('start-btn');
const videoEl   = document.getElementById('video');
const camSelect = document.getElementById('cam-select');
const camResEl  = document.getElementById('cam-res');

const CAM_KEY = 'voidstar.pose.cameraId';
let currentStream = null;
let detectLoopStarted = false;
let poseLandmarker = null;

function stopCurrentStream() {
  if (currentStream) {
    currentStream.getTracks().forEach(t => t.stop());
    currentStream = null;
  }
}

async function openCamera(deviceId) {
  stopCurrentStream();

  // Important: do NOT pin aspectRatio or a fixed width+height. Doing so lets
  // the browser deliver the camera's native sensor mode with no letterboxing.
  // We hint at a large width so high-res cameras give us their best mode;
  // the camera picks its own height based on its native aspect ratio.
  const base = { width: { ideal: 1920 }, facingMode: 'user' };
  const videoConstraints = deviceId
    ? { deviceId: { exact: deviceId } }
    : base;

  const stream = await navigator.mediaDevices.getUserMedia({ video: videoConstraints });
  currentStream     = stream;
  videoEl.srcObject = stream;

  await new Promise(r => { videoEl.onloadedmetadata = r; });
  const vw = videoEl.videoWidth, vh = videoEl.videoHeight;
  if (vw && vh) videoEl.style.aspectRatio = `${vw} / ${vh}`;

  const track    = stream.getVideoTracks()[0];
  const settings = track.getSettings();
  console.log('[pose-particles] camera settings', settings,
              'capabilities', track.getCapabilities?.());

  if (camResEl) camResEl.textContent = `${vw}×${vh}`;

  await videoEl.play().catch(() => {});

  if (settings.deviceId) localStorage.setItem(CAM_KEY, settings.deviceId);

  return settings.deviceId ?? deviceId ?? null;
}

async function populateCameraList(activeDeviceId) {
  try {
    const devices = await navigator.mediaDevices.enumerateDevices();
    const cams = devices.filter(d => d.kind === 'videoinput');
    if (cams.length <= 1) { camSelect.style.display = 'none'; return; }

    camSelect.innerHTML = '';
    cams.forEach((cam, i) => {
      const opt = document.createElement('option');
      opt.value = cam.deviceId;
      opt.textContent = cam.label || `Camera ${i + 1}`;
      if (cam.deviceId === activeDeviceId) opt.selected = true;
      camSelect.appendChild(opt);
    });
    camSelect.style.display = '';
  } catch (e) {
    camSelect.style.display = 'none';
  }
}

async function boot() {
  statusMsg.textContent  = 'loading pose model…';
  startBtn.style.display = 'none';

  try {
    const { PoseLandmarker, FilesetResolver } = await import(
      'https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision/vision_bundle.mjs'
    );

    statusMsg.textContent = 'initialising model…';

    const vision = await FilesetResolver.forVisionTasks(
      'https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision/wasm'
    );

    poseLandmarker = await PoseLandmarker.createFromOptions(vision, {
      baseOptions: {
        modelAssetPath: 'https://storage.googleapis.com/mediapipe-models/pose_landmarker/pose_landmarker_lite/float16/1/pose_landmarker_lite.task',
        delegate: 'GPU',
      },
      runningMode: 'VIDEO',
      numPoses: 2,
      minPoseDetectionConfidence: 0.5,
      minPosePresenceConfidence: 0.5,
      minTrackingConfidence: 0.5,
    });

    statusMsg.textContent = 'requesting camera…';

    const remembered = localStorage.getItem(CAM_KEY);
    let activeId;
    try {
      activeId = await openCamera(remembered ?? null);
    } catch {
      // Remembered camera no longer available — fall back to default
      activeId = await openCamera(null);
    }

    // Now that we have a permissioned stream, labels become available
    await populateCameraList(activeId);

    overlay.classList.add('hidden');

    if (!detectLoopStarted) {
      detectLoopStarted = true;
      (function detectLoop() {
        requestAnimationFrame(detectLoop);
        if (!poseLandmarker)               return;
        if (videoEl.readyState < 2)        return;
        if (videoEl.paused || videoEl.ended) return;
        try {
          const result = poseLandmarker.detectForVideo(videoEl, performance.now());
          allLandmarks = result.landmarks ?? [];
        } catch (e) { /* swallow timestamp regressions */ }
      })();
    }

  } catch (err) {
    statusMsg.textContent  = `error: ${err.message}`;
    startBtn.textContent   = 'retry';
    startBtn.style.display = '';
  }
}

camSelect.addEventListener('change', async () => {
  try {
    const id = await openCamera(camSelect.value);
    await populateCameraList(id);
  } catch (err) {
    alert(`Could not open camera: ${err.message}`);
  }
});

startBtn.addEventListener('click', boot);

// ── Audio boot ────────────────────────────────────────────────────────────────
async function startAudio() {
  try {
    const stream   = await navigator.mediaDevices.getUserMedia({ audio: true, video: false });
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    analyserNode   = audioCtx.createAnalyser();
    analyserNode.fftSize               = 2048;
    analyserNode.smoothingTimeConstant = 0.75;
    audioCtx.createMediaStreamSource(stream).connect(analyserNode);
    freqBuf = new Uint8Array(analyserNode.frequencyBinCount);

    // Derive bin indices from actual sample rate so 44.1kHz vs 48kHz is correct
    const hz = audioCtx.sampleRate / analyserNode.fftSize; // Hz per bin
    const freq2bin = f => Math.max(0, Math.min(Math.round(f / hz), analyserNode.frequencyBinCount - 1));
    binBassLo  = freq2bin(20);   binBassHi  = freq2bin(250);
    binMidsLo  = freq2bin(250);  binMidsHi  = freq2bin(4000);
    binHighsLo = freq2bin(4000); binHighsHi = freq2bin(12000);

    audioEnabled = true;
    btnAudio.classList.remove('active');
    btnAudio.classList.add('active-audio');
    btnAudio.textContent = 'audio on';
    audioPanelEl.style.display = '';
  } catch (err) {
    alert(`Microphone error: ${err.message}`);
  }
}

// ── Audio panel wiring ────────────────────────────────────────────────────────
const audioPanelEl = document.getElementById('audio-panel');

function applyPreset(name) {
  const p = AUDIO_PRESETS[name];
  if (!p) return;
  audioGain    = p.gain;
  audioEMA     = p.ema;
  beatThresh   = p.thresh;
  beatCooldown = p.cooldown;
  // Sync sliders
  document.getElementById('ap-gain').value     = p.gain;
  document.getElementById('ap-thresh').value   = p.thresh;
  document.getElementById('ap-cooldown').value = p.cooldown;
  document.getElementById('ap-ema').value      = p.ema;
  updateAudioPanelLabels();
  document.querySelectorAll('.ap-preset').forEach(b =>
    b.classList.toggle('active', b.dataset.preset === name));
}

function updateAudioPanelLabels() {
  document.getElementById('ap-gain-val').textContent     = `${audioGain.toFixed(2)}×`;
  document.getElementById('ap-thresh-val').textContent   = beatThresh.toFixed(2);
  document.getElementById('ap-cooldown-val').textContent = `${beatCooldown}ms`;
  // EMA: show as a qualitative bar
  const pct = Math.round((audioEMA - 0.04) / (0.40 - 0.04) * 100);
  document.getElementById('ap-ema-val').textContent = `${pct}%`;
}

document.getElementById('ap-gain').addEventListener('input', e => {
  audioGain = parseFloat(e.target.value);
  updateAudioPanelLabels();
  document.querySelectorAll('.ap-preset').forEach(b => b.classList.remove('active'));
});
document.getElementById('ap-thresh').addEventListener('input', e => {
  beatThresh = parseFloat(e.target.value);
  updateAudioPanelLabels();
  document.querySelectorAll('.ap-preset').forEach(b => b.classList.remove('active'));
});
document.getElementById('ap-cooldown').addEventListener('input', e => {
  beatCooldown = parseInt(e.target.value, 10);
  updateAudioPanelLabels();
  document.querySelectorAll('.ap-preset').forEach(b => b.classList.remove('active'));
});
document.getElementById('ap-ema').addEventListener('input', e => {
  audioEMA = parseFloat(e.target.value);
  updateAudioPanelLabels();
  document.querySelectorAll('.ap-preset').forEach(b => b.classList.remove('active'));
});
document.querySelectorAll('.ap-preset').forEach(b =>
  b.addEventListener('click', () => applyPreset(b.dataset.preset)));

updateAudioPanelLabels();

// ── UI controls ───────────────────────────────────────────────────────────────
const btnTrails  = document.getElementById('btn-trails');
const btnCamera  = document.getElementById('btn-camera');
const btnOverlay = document.getElementById('btn-overlay');
const btnAudio   = document.getElementById('btn-audio');
const btnRotate  = document.getElementById('btn-rotate');
const btnPause   = document.getElementById('btn-pause');
const btnZen     = document.getElementById('btn-zen');
const zenHandle  = document.getElementById('zen-handle');
const topbarEl   = document.getElementById('topbar');
const hintsEl    = document.getElementById('hints');

let zenMode = false;
function setZen(on) {
  zenMode = on;
  topbarEl.classList.toggle('zen', on);
  zenHandle.classList.toggle('visible', on);
  const hide = on ? 'none' : '';
  hintsEl.style.opacity       = on ? '0' : '';
  hintsEl.style.pointerEvents = on ? 'none' : '';
  if (audioEnabled) audioPanelEl.style.display = on ? 'none' : '';
}

btnTrails.addEventListener('click', () => {
  trailMode = !trailMode;
  btnTrails.classList.toggle('active', trailMode);
});
// Camera preview has 4 states: hidden → small → large → fullscreen → hidden...
const CAM_SIZES = ['small', 'large', 'full', 'hidden'];
let camSizeIdx  = 0;
function setCamSize(idx) {
  camSizeIdx = ((idx % CAM_SIZES.length) + CAM_SIZES.length) % CAM_SIZES.length;
  const s = CAM_SIZES[camSizeIdx];
  videoEl.classList.remove('hidden','size-large','size-full');
  if (s === 'hidden')  videoEl.classList.add('hidden');
  if (s === 'large')   videoEl.classList.add('size-large');
  if (s === 'full')    videoEl.classList.add('size-full');
  btnCamera.classList.toggle('active', s !== 'hidden');
  btnCamera.textContent = s === 'full' ? 'cam full'
                       : s === 'large' ? 'cam large'
                       : s === 'small' ? 'camera'
                       : 'cam off';
}
btnCamera.addEventListener('click', () => setCamSize(camSizeIdx + 1));
btnOverlay.addEventListener('click', () => {
  showOverlay = !showOverlay;
  btnOverlay.classList.toggle('active', showOverlay);
});
btnAudio.addEventListener('click', () => {
  if (!audioEnabled) startAudio();
});
btnRotate.addEventListener('click', () => {
  cameraRotation = (cameraRotation + 90) % 360;
  btnRotate.textContent = `rot ${cameraRotation}°`;
  btnRotate.classList.toggle('active', cameraRotation !== 0);
  updateVideoTransform();
});
btnPause.addEventListener('click', () => {
  paused = !paused;
  btnPause.classList.toggle('active', paused);
  btnPause.textContent = paused ? 'resume' : 'pause';
});
btnZen.addEventListener('click',    () => setZen(true));
zenHandle.addEventListener('click', () => setZen(false));

document.addEventListener('keydown', e => {
  if (['INPUT','TEXTAREA','SELECT'].includes(e.target.tagName)) return;
  switch (e.code) {
    case 'Space':   e.preventDefault(); btnPause.click(); break;
    case 'KeyT':    btnTrails.click();  break;
    case 'KeyC':    btnCamera.click();  break;
    case 'KeyP':    btnOverlay.click(); break;
    case 'KeyM':    btnAudio.click();   break;
    case 'KeyO':
    case 'Digit0':
    case 'Numpad0': btnRotate.click();  break;
    case 'KeyZ':    setZen(!zenMode);   break;
    case 'KeyR':
      for (let i = 0; i < N; i++) spawnParticle(i);
      simTime = 0;
      ctx.fillStyle = '#05050d';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      break;
  }
});
</script>
</body>
