---
// Legacy route — the phone remote was renamed spooky → tether. Old QR codes,
// bookmarks, and installed home-screen apps still launch /lab/spooky, so this
// stub forwards them. The redirect must run client-side: the room + control
// token ride the URL FRAGMENT (never sent to any server), and only JS can
// carry location.hash across to the new path.
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Tether | voidstar</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#05050d" />
  <script is:inline>location.replace('/lab/tether' + location.hash);</script>
  <style>
    body { background: #05050d; color: #8b8fa8; font: 15px/1.5 monospace;
      display: grid; place-items: center; min-height: 100vh; margin: 0; }
  </style>
</head>
<body>
  <p>spooky is now <a href="/lab/tether" style="color:#22d3ee">⌁ tether</a> — taking you there…</p>
</body>
</html>
