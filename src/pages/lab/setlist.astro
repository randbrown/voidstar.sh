---
// Setlist — live-use and rehearsal setlist manager for pedal steel gigs.
// Standalone page (no BaseLayout) following the entangle.astro pattern.
import ThemeBoot from '../../components/ThemeBoot.astro';
import '../../styles/themes.css';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <ThemeBoot />
  <title>Setlist | voidstar lab</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      min-height: 100dvh;
      background: var(--void);
      color: var(--text);
      font-family: var(--font-sans);
      -webkit-tap-highlight-color: transparent;
    }
    body {
      padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
    }

    /* ── Root ── */
    .setlist-root {
      max-width: 40rem;
      margin: 0 auto;
      padding: 0 1rem 4rem;
      min-height: 100dvh;
    }

    /* ── Top bar ── */
    .sl-topbar {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1rem;
      position: sticky;
      top: 0;
      background: var(--void);
      z-index: 10;
      flex-wrap: wrap;
    }
    .sl-topbar-title {
      font-family: var(--font-mono);
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--text);
      flex: 1;
      min-width: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .sl-actions {
      display: flex;
      gap: 0.4rem;
      margin-left: auto;
    }

    /* ── Buttons ── */
    .sl-btn {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      padding: 0.4rem 0.75rem;
      border-radius: var(--radius, 6px);
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      transition: border-color 0.15s, background 0.15s;
      white-space: nowrap;
    }
    .sl-btn:hover { border-color: var(--border-2); }
    .sl-btn-primary { background: var(--accent); color: var(--void); border-color: var(--accent); }
    .sl-btn-primary:hover { filter: brightness(1.15); }
    .sl-btn-accent { background: var(--cyan); color: var(--void); border-color: var(--cyan); font-weight: 600; }
    .sl-btn-accent:hover { filter: brightness(1.15); }
    .sl-btn-ghost { background: transparent; border-color: var(--border); color: var(--text-muted); }
    .sl-btn-ghost:hover { color: var(--text); border-color: var(--border-2); }
    .sl-btn-danger { color: var(--pink); border-color: transparent; background: transparent; }
    .sl-btn-danger:hover { background: rgba(255, 94, 126, 0.1); }
    .sl-btn-icon { background: transparent; border: none; font-size: 1.2rem; padding: 0.2rem 0.5rem; color: var(--text-muted); }
    .sl-btn-icon:hover { color: var(--text); }
    .sl-btn-sm { font-size: 0.75rem; padding: 0.3rem 0.6rem; }
    .sl-btn-xs { font-size: 0.7rem; padding: 0.15rem 0.4rem; }
    .sl-btn-spotify { background: #1DB954; color: #000; border-color: #1DB954; }
    .sl-btn-mic {
      background: var(--surface);
      border-color: var(--border);
      position: relative;
    }
    .sl-btn-mic.sl-listening {
      background: var(--pink);
      color: var(--void);
      border-color: var(--pink);
      animation: sl-pulse 1.2s ease-in-out infinite;
    }
    @keyframes sl-pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.6; }
    }

    /* ── Cards & Grid ── */
    .sl-grid {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .sl-setlist-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg, 10px);
      padding: 1rem;
      cursor: pointer;
      transition: border-color 0.15s, transform 0.15s;
    }
    .sl-setlist-card:hover { border-color: var(--accent); transform: translateY(-1px); }
    .sl-setlist-card-title { font-weight: 600; font-size: 1.05rem; margin-bottom: 0.35rem; }
    .sl-setlist-card-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      font-size: 0.78rem;
      color: var(--text-muted);
      font-family: var(--font-mono);
    }
    .sl-setlist-meta {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-bottom: 1rem;
      font-family: var(--font-mono);
    }

    /* ── Song cards (setlist view) ── */
    .sl-song-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      padding: 0.65rem 0.85rem;
      margin-bottom: 0.5rem;
      cursor: pointer;
      transition: border-color 0.15s;
    }
    .sl-song-card:hover { border-color: var(--accent); }
    .sl-song-card:active { background: var(--surface-2); }
    .sl-song-card-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .sl-song-num {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--text-dim);
      min-width: 1.5rem;
      text-align: right;
    }
    .sl-song-card-title {
      font-weight: 600;
      font-size: 0.95rem;
      flex: 1;
      min-width: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* ── Badges ── */
    .sl-key-badge {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 700;
      background: color-mix(in srgb, var(--accent) 20%, transparent);
      color: var(--accent);
      padding: 0.15rem 0.5rem;
      border-radius: 999px;
      white-space: nowrap;
    }
    .sl-key-sm { font-size: 0.65rem; padding: 0.1rem 0.4rem; }
    .sl-key-empty { color: var(--text-dim); background: var(--surface-2); }
    .sl-orig { font-weight: 400; opacity: 0.7; }
    .sl-badge {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      background: var(--surface-2);
      color: var(--text-muted);
      padding: 0.15rem 0.5rem;
      border-radius: 999px;
      white-space: nowrap;
    }
    .sl-badge-dim { opacity: 0.7; }
    .sl-steel-tag {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--cyan);
      margin-top: 0.2rem;
      padding-left: 2rem;
    }
    .sl-vocalist {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      font-weight: 700;
      width: 1.4rem;
      height: 1.4rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .sl-vocalist[data-v="C"] { background: color-mix(in srgb, var(--cyan) 25%, transparent); color: var(--cyan); }
    .sl-vocalist[data-v="S"] { background: color-mix(in srgb, var(--green) 25%, transparent); color: var(--green); }
    .sl-vocalist[data-v="H"] { background: color-mix(in srgb, var(--pink) 25%, transparent); color: var(--pink); }
    .sl-vocalist[data-v="D"] { background: color-mix(in srgb, var(--amber) 25%, transparent); color: var(--amber); }

    .sl-note-preview {
      font-size: 0.78rem;
      color: var(--text-dim);
      margin-top: 0.2rem;
      padding-left: 2rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* ── Set divider ── */
    .sl-set-divider {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 0.75rem 0 0.35rem;
      border-bottom: 1px solid var(--border);
      margin: 0.75rem 0 0.5rem;
    }

    /* ── Inputs & Forms ── */
    .sl-search {
      width: 100%;
      padding: 0.5rem 0.75rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      color: var(--text);
      margin-bottom: 1rem;
      outline: none;
    }
    .sl-search:focus { border-color: var(--accent); }
    .sl-search::placeholder { color: var(--text-dim); }

    .sl-input {
      width: 100%;
      padding: 0.45rem 0.6rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      color: var(--text);
      outline: none;
    }
    .sl-input:focus { border-color: var(--accent); }
    .sl-input::placeholder { color: var(--text-dim); }
    .sl-input-sm { max-width: 10rem; }

    .sl-label {
      display: block;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.6rem;
    }
    .sl-label input, .sl-label textarea { margin-top: 0.25rem; }

    .sl-textarea {
      width: 100%;
      padding: 0.5rem 0.75rem;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      color: var(--text);
      resize: vertical;
      outline: none;
    }
    .sl-textarea:focus { border-color: var(--accent); }
    .sl-textarea::placeholder { color: var(--text-dim); }
    .sl-textarea-sm { min-height: 3rem; }

    .sl-row { display: flex; gap: 0.5rem; }
    .sl-flex1 { flex: 1; }
    .sl-hint {
      font-size: 0.72rem;
      color: var(--text-dim);
      margin-top: 0.3rem;
      font-style: italic;
    }
    .sl-hidden { display: none !important; }

    /* ── Sections ── */
    .sl-section {
      margin: 1.25rem 0;
    }
    .sl-section-title {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.6rem;
      font-weight: 600;
    }
    .sl-dim { font-weight: 400; opacity: 0.6; }

    /* ── Edit form ── */
    .sl-edit-form {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      padding: 1rem;
      margin: 0.75rem 0;
    }
    .sl-edit-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 0;
      border-bottom: 1px solid var(--border);
      font-size: 0.88rem;
    }
    .sl-edit-row span { flex: 1; }

    /* ── Vocalist legend ── */
    .sl-voc-grid {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      margin-bottom: 0.5rem;
    }
    .sl-voc-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    /* ── Song library ── */
    .sl-song-list {
      display: flex;
      flex-direction: column;
    }
    .sl-lib-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.6rem 0.4rem;
      border-bottom: 1px solid var(--border);
      cursor: pointer;
      transition: background 0.1s;
    }
    .sl-lib-row:hover { background: var(--surface); }
    .sl-lib-title { font-weight: 500; flex: 1; }
    .sl-lib-artist { font-size: 0.82rem; color: var(--text-muted); }

    /* ── Song Focus ── */
    .sl-focus { padding-bottom: 6rem; }
    .sl-focus-info { margin-bottom: 0.75rem; }
    .sl-focus-title {
      font-size: clamp(1.4rem, 5vw, 2rem);
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 0.2rem;
    }
    .sl-focus-artist {
      font-size: 1rem;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
    }
    .sl-focus-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      align-items: center;
    }

    .sl-action-bar {
      display: flex;
      gap: 0.5rem;
      margin: 0.75rem 0;
      flex-wrap: wrap;
    }

    .sl-spotify-embed {
      margin: 0.75rem 0;
      border-radius: 8px;
      overflow: hidden;
    }

    /* ── Notes ── */
    .sl-notes-list {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      margin-bottom: 0.75rem;
    }
    .sl-note {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      padding: 0.5rem 0.75rem;
      position: relative;
    }
    .sl-note-text {
      font-size: 0.88rem;
      line-height: 1.5;
      white-space: pre-wrap;
    }
    .sl-note-meta {
      display: flex;
      gap: 0.5rem;
      margin-top: 0.25rem;
      font-size: 0.68rem;
      color: var(--text-dim);
      font-family: var(--font-mono);
    }
    .sl-voice-badge {
      background: color-mix(in srgb, var(--pink) 20%, transparent);
      color: var(--pink);
      padding: 0 0.3rem;
      border-radius: 3px;
    }
    .sl-note .sl-btn-icon {
      position: absolute;
      top: 0.2rem;
      right: 0.2rem;
      opacity: 0.3;
    }
    .sl-note:hover .sl-btn-icon { opacity: 1; }

    .sl-note-input {
      margin-top: 0.5rem;
    }
    .sl-note-btns {
      display: flex;
      gap: 0.4rem;
      margin-top: 0.4rem;
    }

    .sl-lyrics {
      font-family: var(--font-mono);
      font-size: 0.82rem;
      color: var(--text-muted);
      white-space: pre-wrap;
      line-height: 1.6;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      padding: 0.75rem;
      overflow-x: auto;
    }

    /* ── Empty & Error ── */
    .sl-empty {
      text-align: center;
      color: var(--text-dim);
      padding: 2rem 1rem;
      font-size: 0.9rem;
    }
    .sl-error {
      color: var(--pink);
      padding: 2rem;
      text-align: center;
    }

    .sl-danger-zone {
      margin-top: 3rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
    }

    /* ── Performance Mode ── */
    .sl-perform {
      max-width: none;
      padding: 0;
    }
    .sl-perform-container {
      position: fixed;
      inset: 0;
      background: var(--void);
      z-index: 1000;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .sl-perform-progress {
      position: absolute;
      top: 0;
      left: 0;
      height: 3px;
      background: var(--accent);
      transition: width 0.3s;
      z-index: 2;
    }
    .sl-perform-counter {
      position: absolute;
      top: 0.75rem;
      right: 1rem;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--text-dim);
      z-index: 2;
    }
    .sl-perform-exit {
      position: absolute;
      top: 0.5rem;
      left: 0.75rem;
      z-index: 2;
      font-size: 1.5rem;
      opacity: 0.4;
    }
    .sl-perform-exit:hover { opacity: 1; }
    .sl-perform-content {
      flex: 1;
      overflow-y: auto;
      padding: 3rem 1.5rem 2rem;
      display: flex;
      flex-direction: column;
      -webkit-overflow-scrolling: touch;
    }
    .sl-perform-title {
      font-size: clamp(1.8rem, 6vw, 3rem);
      font-weight: 700;
      line-height: 1.15;
      margin-bottom: 0.3rem;
    }
    .sl-perform-artist {
      font-size: 1.1rem;
      color: var(--text-muted);
      margin-bottom: 0.75rem;
    }
    .sl-perform-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
      margin-bottom: 0.75rem;
    }
    .sl-perform-badges .sl-key-badge {
      font-size: 1rem;
      padding: 0.25rem 0.75rem;
    }
    .sl-perform-badges .sl-badge {
      font-size: 0.85rem;
    }
    .sl-perform-steel {
      font-family: var(--font-mono);
      font-size: 1rem;
      color: var(--cyan);
      margin-bottom: 1rem;
      font-weight: 600;
    }
    .sl-perform-notes {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }
    .sl-perform-note {
      font-size: 1rem;
      line-height: 1.5;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      padding: 0.6rem 0.85rem;
    }
    .sl-perform-chart {
      align-self: flex-start;
      margin-top: auto;
    }
    .sl-perform-divider {
      font-family: var(--font-mono);
      font-size: 1.8rem;
      color: var(--text-dim);
      text-align: center;
      padding-top: 30vh;
      text-transform: uppercase;
      letter-spacing: 0.15em;
    }

    @media (min-width: 640px) {
      .sl-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      }
    }
  </style>
</head>
<body>
  <div id="setlist-root"></div>
  <script>
    import { initSetlistApp } from '../../lib/setlist/app.js';
    initSetlistApp(document.getElementById('setlist-root'));
  </script>
</body>
</html>
