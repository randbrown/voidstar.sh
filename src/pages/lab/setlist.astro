---
// Setlist — live-use and rehearsal setlist manager for pedal steel gigs.
// Standalone page (no BaseLayout) following the entangle.astro pattern.
import { execSync } from 'node:child_process';
import ThemeBoot from '../../components/ThemeBoot.astro';
import '../../styles/themes.css';

// Build stamp — short commit + commit timestamp + build timestamp.
// Baked at build time so the deployed page can be verified against the
// latest commit (avoids "is my browser serving a stale cache?" guesswork).
// Surfaced two ways here: <meta name="voidstar-build"> in view-source and
// window.__VOIDSTAR_BUILD__ in the console. Same helper lives in
// BaseLayout.astro / qualia.astro; setlist is standalone (doesn't wrap
// BaseLayout) so we recompute here. Git calls fall back to '?' so a
// non-git build env still works.
function readBuildStamp() {
  let commit = '?', commitISO = '?';
  try { commit    = execSync('git rev-parse --short HEAD').toString().trim(); } catch {}
  try { commitISO = execSync('git log -1 --format=%cI').toString().trim();   } catch {}
  return { commit, commitISO, builtAt: new Date().toISOString() };
}
const buildStamp = readBuildStamp();
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <ThemeBoot />
  <title>Setlist | voidstar lab</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/icon-192.png" />
  <!-- Setlist uses its own manifest so installing from this page anchors
       start_url to /lab/setlist (the default manifest's start_url is /
       so installs from that page would always boot to home). Installing
       as an app is what makes the SW-cached shell available offline at a
       gig with no signal. -->
  <link rel="manifest" href="/manifest-setlist.webmanifest" />
  <meta name="theme-color" content="#05050d" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="setlist" />

  <!-- Register the PWA service worker (skipped on local dev hosts so
       Astro's HMR isn't fighting cached assets). This is what caches the
       app shell + hashed JS so perform mode still boots offline. -->
  <script is:inline>
    if ('serviceWorker' in navigator
        && !/^(localhost|127\.|0\.0\.0\.0|192\.168\.|10\.)/.test(location.hostname)) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      });
    }
  </script>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      min-height: 100dvh;
      background: var(--void);
      color: var(--text);
      font-family: var(--font-sans);
      -webkit-tap-highlight-color: transparent;
    }
    body {
      padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
    }

    /* ── Root ── */
    .setlist-root {
      max-width: 40rem;
      margin: 0 auto;
      padding: 0 1rem 4rem;
      min-height: 100dvh;
    }

    /* ── Top bar ──
       Mobile-first (portrait is the primary use case): the back button and the
       title share the first row so the name gets the full width and can wrap
       to two lines instead of truncating to "Boots…"; the action buttons drop
       to their own row below. On wider screens (≥640px, e.g. laptop) it
       collapses back to a single inline row with an ellipsized title. */
    .sl-topbar {
      display: flex;
      align-items: center;
      gap: 0.4rem 0.5rem;
      padding: 0.6rem 0;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1rem;
      position: sticky;
      top: 0;
      background: var(--void);
      z-index: 10;
      flex-wrap: wrap;
    }
    .sl-topbar-title {
      font-family: var(--font-mono);
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--text);
      flex: 1 1 auto;
      min-width: 0;
      line-height: 1.25;
      overflow-wrap: anywhere;
    }
    .sl-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      /* Own row on phones so buttons never crowd out the title. */
      flex: 1 0 100%;
    }

    /* ── Buttons ── */
    .sl-btn {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      padding: 0.55rem 0.9rem;
      min-height: 2.6rem;
      border-radius: var(--radius, 6px);
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.3rem;
      transition: border-color 0.15s, background 0.15s;
      white-space: nowrap;
      touch-action: manipulation;
    }
    .sl-btn:hover { border-color: var(--border-2); }
    .sl-btn-primary { background: var(--accent); color: var(--void); border-color: var(--accent); }
    .sl-btn-primary:hover { filter: brightness(1.15); }
    .sl-btn-accent { background: var(--cyan); color: var(--void); border-color: var(--cyan); font-weight: 600; }
    .sl-btn-accent:hover { filter: brightness(1.15); }
    .sl-btn-ghost { background: transparent; border-color: var(--border); color: var(--text-muted); }
    .sl-btn-ghost:hover { color: var(--text); border-color: var(--border-2); }
    .sl-btn-danger { color: var(--pink); border-color: transparent; background: transparent; }
    .sl-btn-danger:hover { background: rgba(255, 94, 126, 0.1); }
    .sl-btn-icon { background: transparent; border: none; font-size: 1.3rem; padding: 0.3rem 0.6rem; min-height: 2.6rem; min-width: 2.6rem; color: var(--text-muted); }
    .sl-btn-icon:hover { color: var(--text); }
    .sl-btn-sm { font-size: 0.8rem; padding: 0.45rem 0.7rem; min-height: 2.25rem; }
    .sl-btn-xs { font-size: 0.74rem; padding: 0.35rem 0.55rem; min-height: 2rem; }
    .sl-btn-spotify { background: #1DB954; color: #000; border-color: #1DB954; }
    .sl-btn-mic {
      background: var(--surface);
      border-color: var(--border);
      position: relative;
    }
    .sl-btn-mic.sl-listening {
      background: var(--pink);
      color: var(--void);
      border-color: var(--pink);
      animation: sl-pulse 1.2s ease-in-out infinite;
    }
    @keyframes sl-pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.6; }
    }

    /* ── Cards & Grid ── */
    .sl-grid {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .sl-setlist-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg, 10px);
      padding: 1rem;
      cursor: pointer;
      transition: border-color 0.15s, transform 0.15s;
    }
    .sl-setlist-card:hover { border-color: var(--accent); transform: translateY(-1px); }
    .sl-setlist-card-title { font-weight: 600; font-size: 1.05rem; margin-bottom: 0.35rem; }
    .sl-setlist-card-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      font-size: 0.78rem;
      color: var(--text-muted);
      font-family: var(--font-mono);
    }
    .sl-setlist-meta {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-bottom: 1rem;
      font-family: var(--font-mono);
    }

    /* ── Sync / connectivity pill (dashboard) ── */
    .sl-sync-pill {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      margin: -0.4rem 0 0.8rem;
      letter-spacing: 0.02em;
    }
    .sl-sync-pill:empty { display: none; margin: 0; }
    .sl-sync-offline { color: var(--pink); }
    .sl-sync-pending { color: var(--amber, #ffc857); }
    .sl-sync-syncing { color: var(--text-muted); }
    .sl-sync-synced  { color: var(--green); }
    .sl-sync-reconnect { color: var(--amber, #ffc857); }
    .sl-sync-tappable { cursor: pointer; text-decoration: underline dotted; text-underline-offset: 3px; }
    /* Inline "sync now" button + status used on edit pages. */
    .sl-sync-inline { display: inline-flex; align-items: center; gap: 0.5rem; }
    .sl-sync-inline-status { font-size: 0.72rem; }

    /* ── Offline-charts bar (setlist view) ── */
    .sl-offline-bar {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.4rem 0.6rem;
      margin-bottom: 1rem;
      font-family: var(--font-mono);
      font-size: 0.8rem;
    }
    .sl-offline-bar:empty { display: none; margin: 0; }
    .sl-offline-label { color: var(--text-muted); }
    .sl-offline-label.sl-offline-ready { color: var(--green); }
    .sl-offline-hint { color: var(--text-muted); opacity: 0.75; }

    /* ── Song cards (setlist view) ── */
    .sl-song-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      padding: 0.65rem 0.85rem;
      margin-bottom: 0.5rem;
      cursor: pointer;
      transition: border-color 0.15s;
    }
    .sl-song-card:hover { border-color: var(--accent); }
    .sl-song-card:active { background: var(--surface-2); }
    .sl-song-card-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .sl-song-num {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--text-dim);
      min-width: 1.5rem;
      text-align: right;
    }
    .sl-song-card-title {
      font-weight: 600;
      font-size: 0.95rem;
      flex: 1;
      min-width: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* ── Badges ── */
    .sl-key-badge {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 700;
      background: color-mix(in srgb, var(--accent) 20%, transparent);
      color: var(--accent);
      padding: 0.15rem 0.5rem;
      border-radius: 999px;
      white-space: nowrap;
    }
    .sl-key-sm { font-size: 0.65rem; padding: 0.1rem 0.4rem; }
    .sl-key-empty { color: var(--text-dim); background: var(--surface-2); }
    .sl-orig { font-weight: 400; opacity: 0.7; }
    .sl-badge {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      background: var(--surface-2);
      color: var(--text-muted);
      padding: 0.15rem 0.5rem;
      border-radius: 999px;
      white-space: nowrap;
    }
    .sl-badge-dim { opacity: 0.7; }
    /* Key-change callout — a mid-song modulation must grab the eye, so it's a
       solid amber badge with a slow pulse, rendered right next to the key. */
    .sl-keychange-badge {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 700;
      background: #f5a623;
      color: #0d1020;
      padding: 0.15rem 0.6rem;
      border-radius: 999px;
      white-space: nowrap;
      animation: sl-keychange-pulse 1.8s ease-in-out infinite;
    }
    @keyframes sl-keychange-pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(245, 166, 35, 0.55); }
      50% { box-shadow: 0 0 0 6px rgba(245, 166, 35, 0); }
    }
    .sl-steel-tag {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--cyan);
      margin-top: 0.2rem;
      padding-left: 2rem;
    }
    .sl-vocalist {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      font-weight: 700;
      width: 1.4rem;
      height: 1.4rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .sl-vocalist[data-v="C"] { background: color-mix(in srgb, var(--cyan) 25%, transparent); color: var(--cyan); }
    .sl-vocalist[data-v="S"] { background: color-mix(in srgb, var(--green) 25%, transparent); color: var(--green); }
    .sl-vocalist[data-v="H"] { background: color-mix(in srgb, var(--pink) 25%, transparent); color: var(--pink); }
    .sl-vocalist[data-v="D"] { background: color-mix(in srgb, var(--amber) 25%, transparent); color: var(--amber); }

    .sl-note-preview {
      font-size: 0.78rem;
      color: var(--text-dim);
      margin-top: 0.2rem;
      padding-left: 2rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* ── Set divider ── */
    .sl-set-divider {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 0.75rem 0 0.35rem;
      border-bottom: 1px solid var(--border);
      margin: 0.75rem 0 0.5rem;
    }

    /* ── Inputs & Forms ── */
    .sl-search {
      width: 100%;
      padding: 0.5rem 0.75rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      color: var(--text);
      margin-bottom: 1rem;
      outline: none;
    }
    .sl-search:focus { border-color: var(--accent); }
    .sl-search::placeholder { color: var(--text-dim); }

    .sl-input {
      width: 100%;
      padding: 0.45rem 0.6rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      color: var(--text);
      outline: none;
    }
    .sl-input:focus { border-color: var(--accent); }
    .sl-input::placeholder { color: var(--text-dim); }
    .sl-input-sm { max-width: 10rem; }

    .sl-label {
      display: block;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.6rem;
    }
    .sl-label input, .sl-label textarea { margin-top: 0.25rem; }

    .sl-textarea {
      width: 100%;
      padding: 0.5rem 0.75rem;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      color: var(--text);
      resize: vertical;
      outline: none;
    }
    .sl-textarea:focus { border-color: var(--accent); }
    .sl-textarea::placeholder { color: var(--text-dim); }
    .sl-textarea-sm { min-height: 3rem; }

    .sl-row { display: flex; gap: 0.5rem; }
    .sl-flex1 { flex: 1; }
    .sl-hint {
      font-size: 0.72rem;
      color: var(--text-dim);
      margin-top: 0.3rem;
      font-style: italic;
    }
    .sl-hidden { display: none !important; }

    /* ── Sections ── */
    .sl-section {
      margin: 1.25rem 0;
    }
    .sl-section-title {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.6rem;
      font-weight: 600;
    }
    .sl-dim { font-weight: 400; opacity: 0.6; }

    /* ── Edit form ── */
    .sl-edit-form {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      padding: 1rem;
      margin: 0.75rem 0;
    }
    .sl-edit-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 0;
      border-bottom: 1px solid var(--border);
      font-size: 0.88rem;
    }
    .sl-edit-row span { flex: 1; }

    /* ── Vocalist legend ── */
    .sl-voc-grid {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      margin-bottom: 0.5rem;
    }
    .sl-voc-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    /* ── Song library ── */
    .sl-song-list {
      display: flex;
      flex-direction: column;
    }
    .sl-lib-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.6rem 0.4rem;
      border-bottom: 1px solid var(--border);
      cursor: pointer;
      transition: background 0.1s;
    }
    .sl-lib-row:hover { background: var(--surface); }
    .sl-lib-title { font-weight: 500; flex: 1; }
    .sl-lib-artist { font-size: 0.82rem; color: var(--text-muted); }
    /* Library tools — collapsed panel of whole-library passes */
    .sl-lib-tools-toggle { margin: 0.25rem 0 0.5rem; }
    .sl-lib-tools {
      margin-bottom: 0.75rem;
      padding: 0.25rem 0.6rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: color-mix(in srgb, var(--surface) 55%, transparent);
    }

    /* ── Song Focus ── */
    .sl-focus { padding-bottom: 6rem; }
    .sl-focus-info { margin-bottom: 0.75rem; }
    .sl-focus-art {
      float: right;
      width: 72px;
      height: 72px;
      border-radius: 8px;
      object-fit: cover;
      margin: 0 0 0.4rem 0.6rem;
      opacity: 0.92;
      border: 1px solid var(--border);
    }
    .sl-focus-title {
      font-size: clamp(1.4rem, 5vw, 2rem);
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 0.2rem;
    }
    .sl-focus-artist {
      font-size: 1rem;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
    }
    .sl-focus-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      align-items: center;
    }
    /* AI-drafted steel direction — quick-reference prose, kept visually in
       the steel family (cyan) but calm enough to skim past. */
    .sl-steel-summary {
      font-size: 0.82rem;
      line-height: 1.5;
      color: color-mix(in srgb, var(--cyan) 78%, var(--text));
      background: color-mix(in srgb, var(--cyan) 7%, transparent);
      border-left: 2px solid color-mix(in srgb, var(--cyan) 45%, transparent);
      border-radius: 0 var(--radius, 6px) var(--radius, 6px) 0;
      padding: 0.45rem 0.7rem;
      margin-top: 0.6rem;
    }
    /* Verdict controls on the summary block (edit / redo / wrong / delete) —
       quiet enough not to compete with the prose. */
    .sl-steel-summary-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      margin-top: 0.4rem;
      opacity: 0.85;
    }

    .sl-action-bar {
      display: flex;
      gap: 0.5rem;
      margin: 0.75rem 0;
      flex-wrap: wrap;
    }

    /* ── Practice-status chips (song page) + abbreviated badges (setlist) ──
       One accent color per status, shared by the toggle chip's on-state and
       the row badge via --st. */
    .sl-status-chip[data-s='todo'], .sl-status-badge[data-s='todo'] { --st: var(--pink, #ff5e7e); }
    .sl-status-chip[data-s='needsWork'], .sl-status-badge[data-s='needsWork'] { --st: #f5a623; }
    .sl-status-chip[data-s='ok'], .sl-status-badge[data-s='ok'] { --st: #cbd54b; }
    .sl-status-chip[data-s='goodToGo'], .sl-status-badge[data-s='goodToGo'] { --st: #2ec27e; }
    .sl-status-chip[data-s='steelLead'], .sl-status-badge[data-s='steelLead'] { --st: #7aa2ff; }

    .sl-status-row {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
      margin: 0.5rem 0 0.25rem;
    }
    .sl-status-chip {
      font-size: 0.72rem;
      padding: 0.18rem 0.65rem;
      border-radius: 999px;
      background: transparent;
      border: 1px solid color-mix(in srgb, var(--st) 45%, var(--border));
      color: var(--text-muted);
    }
    .sl-status-chip.sl-on {
      background: var(--st);
      border-color: var(--st);
      color: #0d1020;
      font-weight: 600;
    }
    .sl-status-badge {
      font-size: 0.62rem;
      font-family: var(--font-mono);
      font-weight: 700;
      padding: 0.05rem 0.35rem;
      border-radius: 3px;
      background: var(--st);
      color: #0d1020;
      white-space: nowrap;
    }

    /* Inline chart (with read-only annotations) on the song page */
    .sl-focus-chart {
      margin: 0.25rem 0 0.75rem;
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      overflow: hidden;
    }

    /* Web chart-search candidates (below the action bar) */
    .sl-chart-candidates {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      margin: 0.25rem 0 0.75rem;
    }
    .sl-chart-candidate {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      padding: 0.45rem 0.6rem;
    }
    .sl-chart-candidate-info { flex: 1; min-width: 0; }
    .sl-chart-candidate-name {
      font-size: 0.85rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .sl-chart-candidate-meta {
      font-size: 0.68rem;
      color: var(--text-dim);
      font-family: var(--font-mono);
    }
    a.sl-btn { text-decoration: none; display: inline-flex; align-items: center; }

    .sl-spotify-embed {
      margin: 0.75rem 0;
      border-radius: 8px;
      overflow: hidden;
    }

    /* ── Notes ── */
    .sl-notes-list {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      margin-bottom: 0.75rem;
    }
    .sl-note {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      padding: 0.5rem 0.75rem;
      position: relative;
    }
    .sl-note-text {
      font-size: 0.88rem;
      line-height: 1.5;
      white-space: pre-wrap;
    }
    .sl-note-meta {
      display: flex;
      gap: 0.5rem;
      margin-top: 0.25rem;
      font-size: 0.68rem;
      color: var(--text-dim);
      font-family: var(--font-mono);
    }
    .sl-voice-badge {
      background: color-mix(in srgb, var(--pink) 20%, transparent);
      color: var(--pink);
      padding: 0 0.3rem;
      border-radius: 3px;
    }
    .sl-note .sl-btn-icon {
      position: absolute;
      top: 0.2rem;
      right: 0.2rem;
      opacity: 0.3;
    }
    .sl-note .sl-note-edit { right: 1.9rem; }
    .sl-note:hover .sl-btn-icon { opacity: 1; }

    .sl-note-input {
      margin-top: 0.5rem;
    }
    .sl-note-btns {
      display: flex;
      gap: 0.4rem;
      margin-top: 0.4rem;
    }

    .sl-lyrics {
      font-family: var(--font-mono);
      font-size: 0.82rem;
      color: var(--text-muted);
      white-space: pre-wrap;
      line-height: 1.6;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      padding: 0.75rem;
      overflow-x: auto;
    }
    /* Synced lyrics scroll inside their own box; the active line follows the
       timecode timer. */
    .sl-lyrics-synced {
      position: relative;
      max-height: 40vh;
      overflow-y: auto;
      scroll-behavior: smooth;
    }
    .sl-lyrics-line {
      padding: 0.1rem 0.35rem;
      border-radius: 4px;
      transition: color 0.2s, background 0.2s;
    }
    .sl-lyrics-line.sl-active {
      color: var(--text);
      background: color-mix(in srgb, var(--accent) 18%, transparent);
    }

    /* ── Empty & Error ── */
    .sl-empty {
      text-align: center;
      color: var(--text-dim);
      padding: 2rem 1rem;
      font-size: 0.9rem;
    }
    .sl-error {
      color: var(--pink);
      padding: 2rem;
      text-align: center;
    }

    .sl-danger-zone {
      margin-top: 3rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
    }

    /* ── Undo toast ── *
       A live set is full of fat-finger taps; destructive actions (deleting a
       note) drop a toast here that restores the item on tap. Sits above the
       bottom nav so the performer can reach it without hunting. */
    .sl-toast {
      position: fixed;
      left: 50%;
      bottom: calc(4.5rem + env(safe-area-inset-bottom));
      transform: translateX(-50%);
      z-index: 1200;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      max-width: calc(100vw - 2rem);
      padding: 0.6rem 0.75rem 0.6rem 1rem;
      background: var(--surface-2);
      border: 1px solid var(--border-2);
      border-radius: 999px;
      box-shadow: 0 6px 24px rgba(0, 0, 0, 0.5);
      font-size: 0.85rem;
      color: var(--text);
      animation: sl-toast-in 0.18s ease-out;
    }
    .sl-toast-msg { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sl-toast .sl-btn { min-height: 2.2rem; }
    @keyframes sl-toast-in {
      from { opacity: 0; transform: translate(-50%, 0.5rem); }
      to   { opacity: 1; transform: translate(-50%, 0); }
    }

    /* ── Performance Mode ── */
    .sl-perform {
      max-width: none;
      padding: 0;
    }
    .sl-perform-container {
      position: fixed;
      inset: 0;
      background: var(--void);
      z-index: 1000;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      /* ── Low-light stage palette ──
         Pull text off pure white toward the theme's warm accent and knock the
         intensity down a notch. On a near-black background this keeps a strong
         contrast ratio (easy to read at a glance) while avoiding a bright white
         glow that would pollute a dark stage and wreck the performer's night
         vision. Built from theme tokens so it adapts per theme. */
      --sl-stage-text: color-mix(in srgb, var(--text) 70%, var(--amber));
      --sl-stage-muted: color-mix(in srgb, var(--text-muted) 82%, var(--amber));
    }
    .sl-perform-progress {
      position: absolute;
      top: 0;
      left: 0;
      height: 3px;
      background: var(--accent);
      transition: width 0.3s;
      z-index: 2;
    }
    .sl-perform-counter {
      position: absolute;
      top: 0.75rem;
      right: 1rem;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--text-dim);
      z-index: 2;
    }
    .sl-perform-exit {
      position: absolute;
      top: 0.5rem;
      left: 0.75rem;
      z-index: 2;
      font-size: 1.5rem;
      opacity: 0.4;
    }
    .sl-perform-exit:hover { opacity: 1; }
    .sl-perform-content {
      flex: 1;
      overflow-y: auto;
      overflow-x: hidden;
      color: var(--sl-stage-text);
      -webkit-overflow-scrolling: touch;
      /* Keep the browser from hijacking a two-finger gesture as a page pinch
         (native pinch-zoom is disabled inside the Fullscreen API anyway) — we
         run our own pinch-to-zoom on the zoom layer below. pan-x/pan-y still
         let long charts scroll natively when unzoomed. */
      touch-action: pan-x pan-y;
    }
    /* The zoom layer holds the actual song content and is what our pinch
       gesture scales/pans via a transform, so zoom works even in fullscreen
       where the browser locks page-scale. At scale 1 it's a no-op and the
       content scrolls natively. */
    .sl-perform-zoom {
      display: flex;
      flex-direction: column;
      min-height: 100%;
      box-sizing: border-box;
      padding: 3rem 1.5rem 1.5rem;
      transform-origin: 0 0;
      will-change: transform;
    }
    /* While actively zoomed, JS locks native scroll so panning stays under our
       transform (avoids a double-scroll fight). */
    .sl-perform-content.sl-zoomed { overflow: hidden; }
    .sl-perform-title {
      font-size: clamp(1.8rem, 6vw, 3rem);
      font-weight: 700;
      line-height: 1.15;
      margin-bottom: 0.3rem;
      color: var(--sl-stage-text);
    }
    .sl-perform-artist {
      font-size: 1.1rem;
      color: var(--sl-stage-muted);
      margin-bottom: 0.75rem;
    }
    .sl-perform-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
      margin-bottom: 0.75rem;
    }
    .sl-perform-badges .sl-key-badge {
      font-size: 1rem;
      padding: 0.25rem 0.75rem;
    }
    .sl-perform-badges .sl-badge {
      font-size: 0.85rem;
    }
    .sl-perform-badges .sl-keychange-badge {
      font-size: 1rem;
      padding: 0.25rem 0.75rem;
    }
    .sl-perform-steel {
      font-family: var(--font-mono);
      font-size: 1rem;
      color: var(--cyan);
      margin-bottom: 1rem;
      font-weight: 600;
    }
    .sl-perform-steel-summary {
      font-size: 0.95rem;
      line-height: 1.5;
      color: color-mix(in srgb, var(--cyan) 70%, var(--sl-stage-text));
      border-left: 2px solid color-mix(in srgb, var(--cyan) 45%, transparent);
      padding-left: 0.7rem;
      margin: 0 0 1rem;
      max-width: 60ch;
    }
    /* Tuck the summary up under its "steel:" line when both are present. */
    .sl-perform-steel + .sl-perform-steel-summary { margin-top: -0.6rem; }
    .sl-perform-notes {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }
    .sl-perform-note {
      font-size: 1.05rem;
      line-height: 1.55;
      color: var(--sl-stage-text);
      background: color-mix(in srgb, var(--surface) 72%, var(--void));
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      padding: 0.7rem 0.95rem;
    }
    .sl-perform-chart {
      align-self: flex-start;
      margin-top: auto;
    }
    .sl-perform-divider {
      font-family: var(--font-mono);
      font-size: 1.8rem;
      color: var(--text-dim);
      text-align: center;
      padding-top: 30vh;
      text-transform: uppercase;
      letter-spacing: 0.15em;
    }

    /* ── Sync overlay ── */
    .sl-sync-overlay {
      position: fixed;
      inset: 0;
      background: color-mix(in srgb, var(--void) 85%, transparent);
      z-index: 500;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      cursor: pointer;
    }
    .sl-sync-spinner {
      width: 2rem;
      height: 2rem;
      border: 3px solid var(--border);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: sl-spin 0.8s linear infinite;
    }
    @keyframes sl-spin {
      to { transform: rotate(360deg); }
    }
    .sl-sync-status {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      color: var(--text-muted);
    }
    .sl-sync-result {
      font-family: var(--font-mono);
      font-size: 0.9rem;
      color: var(--green);
      text-align: center;
      max-width: 30rem;
      padding: 0 1rem;
      line-height: 1.6;
    }
    .sl-sync-error { color: var(--pink); }

    /* ── Sources / settings ── */
    .sl-source-list {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      margin-bottom: 0.5rem;
    }
    .sl-source-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 0.6rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      font-size: 0.82rem;
    }
    /* Library-health expandable song lists (Settings → library helpers) */
    .sl-health-sublist {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
      margin: 0.1rem 0 0.35rem 0.75rem;
      padding-left: 0.6rem;
      border-left: 1px solid var(--border);
    }
    .sl-health-song {
      font-family: var(--font-mono);
      font-size: 0.76rem;
      color: var(--text-muted);
      padding: 0.2rem 0.3rem;
      border-radius: 4px;
      cursor: pointer;
    }
    .sl-health-song:hover {
      color: var(--text);
      background: color-mix(in srgb, var(--surface) 70%, transparent);
    }
    .sl-source-url {
      flex: 1;
      min-width: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--text-muted);
    }
    code {
      font-family: var(--font-mono);
      font-size: 0.8em;
      background: var(--surface-2);
      padding: 0.1rem 0.35rem;
      border-radius: 3px;
    }

    /* ── Song card artist ── */
    .sl-song-card-artist {
      font-weight: 400;
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-left: 0.15rem;
    }

    /* ── Fullscreen toggle in performance mode ── */
    .sl-perform-fs {
      position: absolute;
      top: 0.5rem;
      left: 3rem;
      z-index: 2;
      font-size: 1.3rem;
      opacity: 0.4;
    }
    .sl-perform-fs:hover { opacity: 1; }

    /* ── Annotation view ── */
    .sl-annotation-container {
      position: fixed;
      inset: 0;
      background: var(--void);
      z-index: 1000;
      display: flex;
      flex-direction: column;
    }
    .sl-annotation-toolbar {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.5rem 0.75rem;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      flex-wrap: wrap;
      z-index: 2;
    }
    .sl-ann-sep {
      width: 1px;
      height: 1.2rem;
      background: var(--border);
      margin: 0 0.2rem;
    }
    .sl-ann-color {
      width: 2rem;
      height: 1.8rem;
      border: 1px solid var(--border);
      border-radius: 4px;
      background: transparent;
      cursor: pointer;
      padding: 0;
    }
    .sl-ann-size {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      color: var(--text);
      padding: 0.2rem 0.4rem;
    }
    .sl-annotation-wrap {
      flex: 1;
      position: relative;
      /* Scroll viewport for the aspect-locked stage. If the stage is taller
         than the visible region the chart (and its annotations, which live in
         the same stage) scroll together, staying aligned. */
      overflow: auto;
    }
    /* Aspect-locked drawing surface. Width-driven height (aspect-ratio set at
       runtime to the annotation's authoring ratio) keeps the canvas coordinate
       box identical across annotate/view modes, so strokes stay pinned to the
       chart regardless of how tall the toolbar is. */
    .sl-annotation-stage {
      position: relative;
      width: 100%;
      flex-shrink: 0;
      /* Pre-load fallback; replaced at runtime with the authoring aspect. */
      aspect-ratio: 3 / 4;
    }
    /* Flat text chart (Google-Doc charts rendered from their plain-text
       export). In flow — not absolutely positioned — so the box takes the
       content's full height: the page scrolls chart + annotation canvas
       together (an iframe's internal scroll would leave the ink behind).
       All type metrics are container-relative (cqw), so the layout scales
       uniformly with box width and the box's natural aspect — which
       annotation strokes are normalized against — matches on every device. */
    .sl-text-stage { container-type: inline-size; }
    .sl-text-chart {
      margin: 0;
      /* Tight margins + large bold type: legible from a mic stand. Sized so
         the widest generated lines (legend, Key/Time/BPM row) still fit.
         The font is PINNED (not var(--font-mono), which is theme-dependent)
         and uses a weight the webfont actually ships (300/400/500 — a 600
         would be synthesized differently per OS): line-wrap points must be
         identical on every device, or the stage height — which annotation
         strokes are normalized against — drifts between phone and laptop. */
      padding: 2cqw 2.5cqw;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 3.4cqw;
      line-height: 1.32;
      font-weight: 500;
      white-space: pre-wrap;
      overflow-wrap: break-word;
      color: #f4f6ff;
      background: var(--surface);
    }
    /* Annotation ink gets a dark halo so it reads at a glance on white
       scans and dark text charts alike. */
    .sl-annotation-canvas,
    .sl-perform-chart-canvas {
      filter: drop-shadow(0 0 1px rgba(0, 0, 0, 0.9)) drop-shadow(0 1px 2px rgba(0, 0, 0, 0.5));
    }
    /* Chart appearance — the toggle stores a TARGET look ('dark'/'light'),
       and each document type inverts only when it needs to: scans/PDF pages
       are natively white, so DARK mode inverts them (their ink canvas
       inverts along, matching how the strokes were drawn); our flat text
       charts are natively dark, so LIGHT mode restyles them to paper and
       their ink never inverts. */
    .sl-charts-dark .sl-annotation-iframe,
    .sl-charts-dark .sl-annotation-img,
    .sl-charts-dark .sl-annotation-canvas {
      filter: invert(1) hue-rotate(180deg);
    }
    .sl-charts-dark.sl-text-stage .sl-annotation-canvas,
    .sl-charts-dark.sl-text-stage .sl-perform-chart-canvas {
      filter: drop-shadow(0 0 1px rgba(0, 0, 0, 0.9)) drop-shadow(0 1px 2px rgba(0, 0, 0, 0.5));
    }
    .sl-charts-light .sl-text-chart {
      background: #f4f1e8;
      color: #16181f;
    }

    /* Mini toolbar above the song page's inline chart */
    .sl-chart-tools {
      display: flex;
      justify-content: flex-end;
      margin: 0.5rem 0 0.25rem;
    }

    .sl-annotation-iframe,
    .sl-annotation-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }
    .sl-annotation-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      cursor: crosshair;
    }
    .sl-ann-selmenu {
      position: absolute;
      z-index: 5;
      display: flex;
      gap: 0.25rem;
      padding: 0.2rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.45);
    }

    /* ── Timecode tracker ── */
    .sl-timecode-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin: 0.5rem 0;
      padding: 0.4rem 0.6rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius, 6px);
      font-family: var(--font-mono);
      font-size: 0.78rem;
    }
    .sl-timecode-label {
      font-size: 0.68rem;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .sl-timecode-display {
      font-weight: 700;
      color: var(--accent);
      min-width: 3rem;
    }

    /* ── Timecode / section / steel badges on notes ── */
    .sl-tc-badge {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      font-weight: 600;
      background: color-mix(in srgb, var(--accent) 20%, transparent);
      color: var(--accent);
      padding: 0.05rem 0.35rem;
      border-radius: 3px;
    }
    .sl-section-badge {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      background: color-mix(in srgb, var(--green) 20%, transparent);
      color: var(--green);
      padding: 0.05rem 0.35rem;
      border-radius: 3px;
    }
    .sl-steel-note-badge {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      background: color-mix(in srgb, var(--cyan) 20%, transparent);
      color: var(--cyan);
      padding: 0.05rem 0.35rem;
      border-radius: 3px;
    }

    /* ── Steel quick-buttons ── */
    .sl-steel-buttons {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      margin-top: 0.4rem;
      flex-wrap: wrap;
    }
    .sl-steel-qb {
      border-color: color-mix(in srgb, var(--cyan) 40%, transparent);
      color: var(--cyan);
    }
    .sl-steel-qb:hover {
      background: color-mix(in srgb, var(--cyan) 10%, transparent);
      border-color: var(--cyan);
    }

    /* ── Note section row ── */
    .sl-note-section-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 0.4rem;
    }

    /* ── Performance mode note badges ── */
    .sl-perform-note .sl-tc-badge,
    .sl-perform-note .sl-section-badge,
    .sl-perform-note .sl-steel-note-badge {
      font-size: 0.75rem;
      margin-right: 0.25rem;
    }

    /* ── Drag reorder ── */
    .sl-drag-handle {
      display: none;
      cursor: grab;
      color: var(--text-dim);
      font-size: 1.1rem;
      padding: 0.2rem 0.15rem;
      touch-action: none;
      user-select: none;
      flex-shrink: 0;
    }
    /* Reordering is locked until the user toggles it on. */
    .sl-reorder-on .sl-drag-handle { display: inline-block; }
    .sl-reorder-on .sl-edit-row { background: var(--surface); }
    .sl-drag-handle:active { cursor: grabbing; }
    .sl-dragging {
      background: var(--surface-2) !important;
      border-color: var(--accent) !important;
      box-shadow: 0 2px 8px rgba(0,0,0,0.3);
      z-index: 100;
      position: relative;
    }
    .sl-drag-container {
      display: flex;
      flex-direction: column;
    }

    /* ── Song link in edit mode ── */
    .sl-edit-song-link {
      font-size: 0.85rem;
      opacity: 0.4;
    }
    .sl-edit-song-link:hover { opacity: 1; }

    /* ── Song navigation bar (bottom, song focus) ── */
    .sl-song-nav {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      padding-bottom: calc(0.5rem + env(safe-area-inset-bottom));
      background: var(--surface);
      border-top: 1px solid var(--border);
      z-index: 20;
    }
    .sl-song-nav-pos {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      color: var(--text-dim);
      min-width: 3rem;
      text-align: center;
    }
    /* Larger touch targets on the song-focus bottom nav too. */
    .sl-song-nav .sl-btn {
      flex: 1;
      max-width: 11rem;
      min-height: 3rem;
      font-size: 0.9rem;
    }

    /* ── Perform detail button ── */
    .sl-perform-detail {
      position: absolute;
      top: 0.55rem;
      right: 4.5rem;
      z-index: 2;
      opacity: 0.35;
      font-size: 0.8rem;
      color: var(--text-muted);
    }
    .sl-perform-detail:hover { opacity: 0.8; }

    /* ── Chart preview in perform mode ── */
    .sl-perform-chart-wrap {
      position: relative;
      width: 100%;
      /* Aspect locked at runtime to the annotation's authoring ratio so the
         overlay lines up; this is just the pre-load fallback. */
      aspect-ratio: 3 / 4;
      /* Never let the surrounding notes squeeze the chart: in the flex-column
         scroll container it would otherwise shrink, forcing the embed's own
         inner scrollbar. Keeping its full height means the whole page (notes +
         chart) scrolls as one document — a single scrollbar. */
      flex-shrink: 0;
      margin-top: 0.75rem;
      margin-bottom: 0.5rem;
      border-radius: var(--radius, 6px);
      overflow: hidden;
      border: 1px solid var(--border);
      /* Our own dark backdrop behind the chart. For a flattened image this is
         what shows around/below the page — and because it's ours (not Google's
         cross-origin viewer) it stays dark in invert mode instead of flipping
         to white, so the area around the doc matches the doc. */
      background: #000;
    }
    .sl-perform-chart-iframe,
    .sl-perform-chart-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }
    /* Flattened chart image: fit to width, pinned to the top — but any space
       around it is our dark backdrop rather than the viewer's. */
    .sl-perform-chart-img.sl-chart-flat {
      height: auto;
      bottom: auto;
    }
    /* When the song has annotations, the overlay canvas fills the aspect-locked
       wrap (aspect = the annotation's authoring ratio). The chart image must
       fill the SAME box so canvas rect == chart rect == the box the strokes
       were normalized to — otherwise a natural-aspect (height:auto) image is a
       different rectangle than the canvas and the strokes drift. This mirrors
       how .sl-annotation-stage lays out chart + canvas in the annotate/detail
       views (both inset:0, 100%/100%), which is why those stay aligned. */
    .sl-perform-chart-wrap.sl-has-annotations .sl-perform-chart-img.sl-chart-flat {
      height: 100%;
      bottom: 0;
    }
    .sl-perform-chart-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
    }

    /* ── Perform bottom nav bar ── */
    .sl-perform-nav {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      padding: 0.6rem 0.85rem;
      padding-bottom: calc(0.6rem + env(safe-area-inset-bottom));
      background: var(--surface);
      border-top: 1px solid var(--border);
      flex-shrink: 0;
    }
    /* Big thumb-reach prev/next for live use — fill the bar so an imprecise
       tap in low light still lands. */
    .sl-perform-nav .sl-btn {
      flex: 1;
      max-width: 13rem;
      min-height: 3.25rem;
      font-size: 1rem;
      padding: 0.8rem 1rem;
    }

    /* ── Invert colors toggle for chart (top control strip) ── */
    .sl-perform-invert {
      position: absolute;
      top: 0.55rem;
      left: 5.5rem;
      z-index: 2;
      opacity: 0.5;
      font-size: 0.8rem;
    }
    .sl-perform-invert:hover { opacity: 0.85; }
    .sl-perform-invert.sl-btn-active { opacity: 1; }
    /* Enhance (auto-levels) toggle sits just right of the appearance glyph.
       Same no-accent treatment: the chart itself shows what the toggle did. */
    .sl-perform-enhance {
      position: absolute;
      top: 0.55rem;
      left: 8.5rem;
      z-index: 2;
      opacity: 0.5;
      font-size: 0.8rem;
    }
    .sl-perform-enhance:hover { opacity: 0.85; }
    .sl-btn-active {
      color: var(--accent);
      border-color: var(--accent);
    }
    .sl-charts-dark .sl-perform-chart-iframe,
    .sl-charts-dark .sl-perform-chart-img {
      filter: invert(1) hue-rotate(180deg);
    }
    .sl-charts-dark .sl-perform-chart-canvas {
      filter: invert(1) hue-rotate(180deg);
    }

    /* ── Annotation controls container ── */
    .sl-ann-controls {
      display: flex;
      align-items: center;
      gap: 0.35rem;
    }

    @media (min-width: 640px) {
      .sl-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      }
      /* Laptop: title + actions back on one inline row, ellipsized title. */
      .sl-topbar-title {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .sl-actions {
        flex: 0 0 auto;
        margin-left: auto;
      }
    }
  </style>

  <meta name="voidstar-build" content={`${buildStamp.commit} · committed ${buildStamp.commitISO} · built ${buildStamp.builtAt}`} />

  <!-- Build stamp on window + console — every page can be verified against
       the latest deploy independent of the debug overlay. -->
  <script is:inline define:vars={{ build: buildStamp }}>
    window.__VOIDSTAR_BUILD__ = build;
    console.log('[voidstar/setlist] build ' + build.commit
      + ' · committed ' + build.commitISO
      + ' · built ' + build.builtAt);
  </script>

  <!-- Mobile diagnostics — same as BaseLayout, but inlined here because
       /lab/setlist is a standalone page (doesn't wrap BaseLayout). See
       BaseLayout.astro for full notes; in short: ?debug=1 injects Eruda
       + shows a "DBG" status badge in the corner so users can confirm
       the script ran even if the CDN is blocked. ?debug=0 disables. -->
  <script is:inline>
    (function () {
      try {
        var qs = new URLSearchParams(location.search);
        var qDebug = qs.get('debug');
        var KEY = 'voidstar.debug.console';
        if (qDebug === '0' || qDebug === 'off') {
          localStorage.removeItem(KEY);
          console.log('[voidstar] debug console disabled');
          return;
        }
        if (qDebug === '1' || qDebug === 'eruda' || qDebug === 'on') {
          localStorage.setItem(KEY, 'eruda');
        }
        if (localStorage.getItem(KEY) !== 'eruda') return;
        console.log('[voidstar] debug=eruda — loading overlay…');

        var badge = null;
        function ensureBadge() {
          if (badge || !document.body) return badge;
          badge = document.createElement('div');
          badge.id = 'voidstar-debug-badge';
          badge.textContent = 'DBG…';
          var b = window.__VOIDSTAR_BUILD__ || {};
          badge.title = 'voidstar build ' + (b.commit || '?')
            + (b.builtAt ? ' · built ' + b.builtAt : '')
            + ' — tap to open console; long-press to disable';
          var s = badge.style;
          s.position = 'fixed';
          s.top = 'calc(env(safe-area-inset-top, 0px) + 6px)';
          s.right = '6px';
          s.zIndex = '2147483647';
          s.padding = '2px 6px';
          s.borderRadius = '4px';
          s.font = '11px ui-monospace, Menlo, Consolas, monospace';
          s.background = 'rgba(0,0,0,0.72)';
          s.color = '#ffc857';
          s.border = '1px solid #ffc857';
          s.pointerEvents = 'auto';
          s.cursor = 'pointer';
          var pressTimer = null;
          badge.addEventListener('click', function () {
            try { window.eruda && window.eruda.show(); } catch (_) {}
          });
          badge.addEventListener('touchstart', function () {
            pressTimer = setTimeout(function () {
              localStorage.removeItem(KEY);
              location.reload();
            }, 1200);
          });
          badge.addEventListener('touchend', function () { clearTimeout(pressTimer); });
          document.body.appendChild(badge);
          return badge;
        }
        function setBadge(text, color) {
          var b = ensureBadge();
          if (!b) return;
          b.textContent = text;
          b.style.color = color;
          b.style.borderColor = color;
        }
        function bootEruda() {
          if (!window.eruda) {
            console.error('[voidstar] eruda failed to load (CDN blocked?). '
              + 'Try chrome://inspect remote debugging instead.');
            setBadge('DBG!', '#ff5e7e');
            return;
          }
          try {
            window.eruda.init();
            console.log('[voidstar] eruda initialized — tap the gear (or the badge).');
            setBadge('DBG', '#7cf2a5');
          } catch (e) {
            console.error('[voidstar] eruda.init() threw', e);
            setBadge('DBG!', '#ff5e7e');
          }
        }
        function loadFrom(src, next) {
          var s = document.createElement('script');
          s.src = src;
          s.crossOrigin = 'anonymous';
          s.onload  = bootEruda;
          s.onerror = next || function () {
            console.error('[voidstar] eruda CDN unreachable:', src);
            setBadge('DBG!', '#ff5e7e');
          };
          document.head.appendChild(s);
        }
        function start() {
          ensureBadge();
          loadFrom('https://cdn.jsdelivr.net/npm/eruda', function () {
            loadFrom('https://unpkg.com/eruda', null);
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', start);
        } else {
          start();
        }
      } catch (e) {
        try { console.error('[voidstar] debug-script error', e); } catch (_) {}
      }
    })();
  </script>
</head>
<body>
  <div id="setlist-root"></div>
  <script>
    import { initSetlistApp } from '../../lib/setlist/app.js';
    initSetlistApp(document.getElementById('setlist-root'));
  </script>
</body>
</html>
