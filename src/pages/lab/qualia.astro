<!-- Bottom-left HUD: audio panel + dynamically-built fx params card. -->
<div id="panel-stack">
  <div id="diag-card" class="qp-card collapsed">
    <div class="qp-head" data-toggle="diag-card">
      <span class="qp-title">diagnostics</span>
      <span class="qp-spacer"></span>
      <span>▾</span>
    </div>
    <div class="qp-body" id="diag-body">
      <div class="diag-build" title={`commit ${buildStamp.commit} · committed ${buildStamp.commitISO} · built ${buildStamp.builtAt}`}>{buildStampShort}</div>
      <div class="qp-row diag-row"><span class="diag-label">fps</span><span class="qp-val" id="diag-fps">—</span></div>
      <div class="qp-row diag-row"><span class="diag-label">frame</span><span class="qp-val" id="diag-ms">—</span></div>
      <div class="qp-row diag-row"><span class="diag-label">bass</span><span class="qp-val" id="diag-bass">—</span></div>
      <div class="qp-row diag-row"><span class="diag-label">mids</span><span class="qp-val" id="diag-mids">—</span></div>
      <div class="qp-row diag-row"><span class="diag-label">highs</span><span class="qp-val" id="diag-highs">—</span></div>
      <div class="qp-row diag-row"><span class="diag-label">rms</span><span class="qp-val" id="diag-rms">—</span></div>
      <div class="qp-row diag-row"><span class="diag-label">kick / 5s</span><span class="qp-val" id="diag-beat">0</span></div>
      <div class="qp-row diag-row"><span class="diag-label">snare / 5s</span><span class="qp-val" id="diag-snare">0</span></div>
      <div class="qp-row diag-row"><span class="diag-label">hat / 5s</span><span class="qp-val" id="diag-hat">0</span></div>
      <div class="qp-row diag-row"><span class="diag-label">poses</span><span class="qp-val" id="diag-poses">0</span></div>
      <div class="qp-row" data-qp="viz-fps" title="Cap the visualizer frame rate. 'max' = uncapped. Lower frees the main thread (helps Strudel timing + UI on Windows) and doubles as a slow-motion / strobe aesthetic down to 1fps. Audio reactivity is unaffected.">
        <label>render cap<span class="qp-val">max</span></label>
        <input type="range" min="1" max="61" step="1" value="61">
      </div>
      <div class="qp-section-tag">advanced</div>
      <div class="qp-row diag-row">
        <span class="diag-label">stuck state?</span>
        <button class="qp-toggle" id="btn-reset-all" title="Clear all qualia settings + service-worker caches and reload">reset all</button>
      </div>
    </div>
  </div>

  <div id="audio-card" class="qp-card collapsed" style="display:none">
    <div class="qp-head" data-toggle="audio-card">
      <span class="qp-title">audio</span>
      <span class="qp-spacer"></span>
      <span>▾</span>
    </div>
    <div class="qp-body">
      <div class="qp-presets" data-qp="audio-presets"></div>
      <div class="qp-row" data-qp="audio-gain">
        <label>gain<span class="qp-val"></span></label>
        <input type="range" min="0.25" max="4" step="0.05" value="1.0">
      </div>
      <div class="qp-row" data-qp="audio-thresh">
        <label>beat thresh<span class="qp-val"></span></label>
        <input type="range" min="1.10" max="2.50" step="0.05" value="1.30">
      </div>
      <div class="qp-row" data-qp="audio-cooldown">
        <label>beat gap<span class="qp-val"></span></label>
        <input type="range" min="80" max="1000" step="10" value="500">
      </div>
      <div class="qp-row" data-qp="audio-ema">
        <label>response<span class="qp-val"></span></label>
        <input type="range" min="0.05" max="0.60" step="0.01" value="0.30">
      </div>
    </div>
  </div>

  <div id="pose-card" class="qp-card collapsed" style="display:none">
    <div class="qp-head" data-toggle="pose-card">
      <span class="qp-title">pose</span>
      <span class="qp-spacer"></span>
      <span>▾</span>
    </div>
    <div class="qp-body">
      <div class="qp-row" data-qp="pose-smooth">
        <label>smooth<span class="qp-val">50%</span></label>
        <input type="range" min="0" max="1" step="0.01" value="0.5">
      </div>
      <div class="qp-row" data-qp="pose-fps" title="Pose detection rate. Independent of the visualizer frame rate — run the viz high while pose tracks slow (less CPU, or a deliberate stutter aesthetic).">
        <label>rate<span class="qp-val">30fps</span></label>
        <input type="range" min="1" max="60" step="1" value="30">
      </div>
      <div class="qp-row" data-qp="pose-detect">
        <label>detect<span class="qp-val"></span></label>
        <input type="range" min="0.005" max="1" step="0.005" value="0.05">
      </div>
      <div class="qp-row" data-qp="pose-presence">
        <label>presence<span class="qp-val"></span></label>
        <input type="range" min="0.005" max="1" step="0.005" value="0.05">
      </div>
      <div class="qp-row" data-qp="pose-track">
        <label>tracking<span class="qp-val"></span></label>
        <input type="range" min="0.005" max="1" step="0.005" value="0.05">
      </div>
      <div class="qp-row" data-qp="pose-linger">
        <label>linger<span class="qp-val">800ms</span></label>
        <input type="range" min="0" max="3000" step="50" value="800">
      </div>
    </div>
  </div>

  <!-- Camera card — only shown while pose camera is on. Houses zoom slider
       (when the active track exposes the zoom capability) plus an explicit
       flip-front/back button as a UI fallback for the double-tap gesture. -->
  <div id="camera-card" class="qp-card collapsed" style="display:none">
    <div class="qp-head" data-toggle="camera-card">
      <span class="qp-title">camera</span>
      <span class="qp-spacer"></span>
      <span>▾</span>
    </div>
    <div class="qp-body">
      <div class="qp-row" data-qp="cam-flip">
        <label>facing<span class="qp-val" id="cam-facing-val">user</span></label>
        <button class="qp-toggle" id="btn-cam-flip" title="Flip front/back camera">flip</button>
      </div>
      <div class="qp-row" data-qp="cam-zoom" style="display:none">
        <label>zoom<span class="qp-val">1.0×</span></label>
        <input type="range" min="1" max="4" step="0.1" value="1">
      </div>
      <div class="qp-row" data-qp="cam-zoom-unsupported" id="cam-zoom-unsupported" style="display:none">
        <label style="color:var(--muted); font-size:0.65rem;">zoom unavailable on this camera</label>
        <span></span>
      </div>
    </div>
  </div>

  <div id="mosh-card" class="qp-card collapsed" style="display:none">
    <div class="qp-head" data-toggle="mosh-card">
      <span class="qp-title">data-mosh</span>
      <span class="qp-spacer"></span>
      <span>▾</span>
    </div>
    <div class="qp-body">
      <div class="qp-row" data-qp="mosh-intensity">
        <label>intensity<span class="qp-val"></span></label>
        <input type="range" min="0" max="1.5" step="0.05" value="0.85">
      </div>
      <div class="qp-row" data-qp="mosh-smear">
        <label>smear<span class="qp-val"></span></label>
        <input type="range" min="0" max="1" step="0.02" value="0.55">
      </div>
      <div class="qp-row" data-qp="mosh-glitch">
        <label>glitch rate<span class="qp-val"></span></label>
        <input type="range" min="0" max="1" step="0.02" value="0.30">
      </div>
      <div class="qp-row" data-qp="mosh-block">
        <label>block size<span class="qp-val"></span></label>
        <input type="range" min="8" max="128" step="2" value="32">
      </div>
      <div class="qp-row" data-qp="mosh-split">
        <label>color split<span class="qp-val"></span></label>
        <input type="range" min="0" max="20" step="1" value="4">
      </div>
    </div>
  </div>

  <div id="edge-card" class="qp-card collapsed" style="display:none">
    <div class="qp-head" data-toggle="edge-card">
      <span class="qp-title">edge-detect</span>
      <span class="qp-spacer"></span>
      <span>▾</span>
    </div>
    <div class="qp-body">
      <div class="qp-row" data-qp="edge-intensity">
        <label>intensity<span class="qp-val"></span></label>
        <input type="range" min="0" max="3" step="0.05" value="1.20">
      </div>
      <div class="qp-row" data-qp="edge-threshold">
        <label>threshold<span class="qp-val"></span></label>
        <input type="range" min="0" max="0.4" step="0.005" value="0.05">
      </div>
      <div class="qp-row" data-qp="edge-thickness">
        <label>thickness<span class="qp-val"></span></label>
        <input type="range" min="0" max="2" step="0.05" value="0.40">
      </div>
      <div class="qp-row" data-qp="edge-glow">
        <label>glow<span class="qp-val"></span></label>
        <input type="range" min="0" max="1" step="0.02" value="0.45">
      </div>
    </div>
  </div>

  <div id="fx-card" class="qp-card">
    <div class="qp-head" data-toggle="fx-card">
      <span class="qp-title">params</span>
      <span class="qp-spacer"></span>
      <button class="qp-toggle" id="btn-fx-reset" title="Reset to defaults">reset</button>
      <span>▾</span>
    </div>
    <div class="qp-body" id="fx-params"></div>
  </div>

  <!-- Qualem card — saved snapshots of the entire macro-experience. Each
       row recalls one snapshot back into the live state (fx + audio +
       pose + overlay + glitch + strudel + sequencer + vocoder + camera +
       cycle pool). Toolbar buttons: save current, new (clean defaults),
       random (rolls new strudel + seq patterns), import (.qualem.json). -->
  <div id="qualem-card" class="qp-card collapsed">
    <div class="qp-head" data-toggle="qualem-card">
      <span class="qp-title">qualem</span>
      <span class="qp-spacer"></span>
      <span>▾</span>
    </div>
    <div class="qp-body" id="qualem-body">
      <div class="sp-pat-toolbar">
        <button class="ctrl-btn" id="btn-qualem-save"   title="Save the current state as a new qualem">save current</button>
        <button class="ctrl-btn" id="btn-qualem-new"    title="Reset live state to clean defaults">new</button>
        <button class="ctrl-btn" id="btn-qualem-random" title="Roll a new strudel + sequencer pattern (visuals untouched)">random</button>
        <button class="ctrl-btn" id="btn-qualem-import" title="Load a .qualem.json file from disk">import</button>
        <button class="ctrl-btn" id="btn-qualem-share-current" title="Share current live state as a URL">share live</button>
      </div>
      <div id="qualem-list" class="sp-pat-list"></div>
      <input type="file" id="qualem-file-input" accept=".json,application/json" style="display:none" />
    </div>
  </div>
</div>

<!-- Share popover: a small floating dialog with the qualem URL pre-selected
     and a one-click copy. Opened by `share` per-row buttons + the toolbar's
     `share live` button. Single instance, repositioned on each open. -->
<div id="qualem-share-backdrop" style="display:none"></div>
<div id="qualem-share" role="dialog" aria-modal="true" aria-labelledby="qualem-share-title" style="display:none">
  <div id="qualem-share-head">
    <span class="qualem-share-title" id="qualem-share-title">share qualem</span>
    <span class="qualem-share-spacer"></span>
    <button class="ctrl-btn" id="qualem-share-close" title="Close">×</button>
  </div>
  <div id="qualem-share-body">
    <textarea id="qualem-share-url" readonly spellcheck="false"></textarea>
    <div id="qualem-share-actions">
      <button class="ctrl-btn" id="qualem-share-copy" title="Copy URL to clipboard">copy</button>
      <button class="ctrl-btn" id="qualem-share-open" title="Open URL in a new tab">open</button>
      <span class="qualem-share-status" id="qualem-share-status"></span>
    </div>
    <div class="qualem-share-hint">
      Anyone opening this link gets the same experience loaded automatically.
      QR-code display + GitHub Gist sync are coming in a follow-up.
    </div>
  </div>
</div>

<!-- Recording status + save dialog. Two roles:
     1. While recording, `#rec-toast` shows a fixed pill near the top of
        the viewport so the user can SEE the recording is live even when
        zen mode / fullscreen hides the topbar. It mirrors the rec button
        state and shows the elapsed time.
     2. After stop, the toast morphs into a "tap to save" prompt with an
        explicit button. Mobile browsers reject anchor.click() inside an
        async stop callback (lost user-gesture); the explicit tap is the
        portable way to make sure the download fires. Desktop showSave-
        FilePicker bypasses this entirely (file is already written). -->
<div id="rec-toast" role="status" aria-live="polite" style="display:none">
  <div id="rec-toast-body">
    <span id="rec-toast-dot">●</span>
    <span id="rec-toast-text">recording</span>
  </div>
  <div id="rec-toast-actions" style="display:none">
    <button class="ctrl-btn" id="rec-toast-save" title="Download the recording">save</button>
    <button class="ctrl-btn" id="rec-toast-dismiss" title="Dismiss without saving">dismiss</button>
  </div>
</div>

<!-- Tab bar — visible only on touch / narrow viewports. Tapping a tab
     opens that card and collapses the others (enforces accordion). Lives
     OUTSIDE #panel-stack so it stays anchored at the bottom of the
     viewport while card content scrolls independently above it. -->
<div id="panel-tabs" class="qp-tabs" role="tablist" aria-label="Settings panels">
  <button class="qp-tab" data-card="fx-card"     role="tab">params</button>
  <button class="qp-tab" data-card="qualem-card" role="tab">qualem</button>
  <button class="qp-tab" data-card="audio-card"  role="tab">audio</button>
  <button class="qp-tab" data-card="pose-card"   role="tab">pose</button>
  <button class="qp-tab" data-card="camera-card" role="tab">camera</button>
  <button class="qp-tab" data-card="mosh-card"   role="tab">mosh</button>
  <button class="qp-tab" data-card="edge-card"   role="tab">edge</button>
  <button class="qp-tab" data-card="diag-card"   role="tab">diag</button>
</div>

<!-- Cycle-pool manager — populated by page-init.js. Backdrop swallows
     outside clicks to close the modal. -->
<div id="cycle-mgr-backdrop"></div>
<div id="cycle-mgr" role="dialog" aria-modal="true" aria-labelledby="cycle-mgr-title">
  <div id="cycle-mgr-head">
    <span class="cycle-mgr-title" id="cycle-mgr-title">cycle pool</span>
    <span class="cycle-mgr-spacer"></span>
    <button class="ctrl-btn" id="cycle-mgr-close" title="Close">×</button>
  </div>
  <div id="cycle-mgr-bulk">
    <button class="ctrl-btn" id="cycle-mgr-all">select all</button>
    <button class="ctrl-btn" id="cycle-mgr-none">deselect all</button>
  </div>
  <div id="cycle-mgr-list"></div>
</div>

<div id="strudel-panel" style="display:none">
  <div id="strudel-header">
    <span class="sp-title">strudel</span>
    <span class="sp-err" id="strudel-error" style="display:none" title="" role="alert"></span>
    <span class="sp-status" id="strudel-status">click ▶ in editor to start</span>
    <button class="ctrl-btn" id="btn-strudel-play"    title="Evaluate / play (Ctrl+Enter)">▶</button>
    <button class="ctrl-btn" id="btn-strudel-stop"    title="Stop (Ctrl+.)">■</button>
    <button class="ctrl-btn panel-mute-btn" id="btn-strudel-mute" title="Mute Strudel audio (transport keeps running so sync stays locked)">live</button>
    <input type="range" class="panel-gain-slider" id="strudel-gain" min="0" max="1" step="0.01" value="1" title="Output level (0–1×). Stacks with Strudel's own gain() — use this to ride the mix without editing the pattern." />
    <button class="ctrl-btn" id="btn-strudel-newline" title="Insert newline at cursor (Android touch keyboards drop the Enter event)">↵</button>
    <button class="ctrl-btn" id="btn-strudel-close"   title="Close (S)">×</button>
  </div>
  <div id="strudel-tabs">
    <button class="sp-tab active" data-tab="editor">editor</button>
    <button class="sp-tab"        data-tab="patterns">patterns</button>
    <button class="sp-opt" id="btn-strudel-lines" title="Toggle line numbers" aria-pressed="false">#</button>
  </div>
  <div id="strudel-mount"></div>
  <div id="strudel-patterns" style="display:none">
    <div class="sp-pat-toolbar">
      <button class="ctrl-btn" id="btn-pat-save"   title="Save current editor as a new pattern">save current</button>
      <button class="ctrl-btn" id="btn-pat-new"    title="Replace editor with a blank template">new</button>
      <button class="ctrl-btn" id="btn-pat-random" title="Replace editor with a random pattern">random</button>
    </div>
    <div id="pat-list" class="sp-pat-list"></div>
  </div>
</div>

<!-- Pattern sequencer panel — second programmable audio source. Lives as a
     sibling of #strudel-panel so each draggable window is independent. -->
<div id="sequencer-panel" style="display:none">
  <div id="sequencer-header">
    <span class="sp-title">seq</span>
    <input type="text" id="sequencer-name" class="seq-name-input" placeholder="pattern name" />
    <span class="sp-status" id="sequencer-status">click ▶ to play</span>
    <button class="ctrl-btn" id="btn-sequencer-play"  title="Play (Ctrl+Enter)">▶</button>
    <button class="ctrl-btn" id="btn-sequencer-stop"  title="Stop">■</button>
    <button class="ctrl-btn panel-mute-btn" id="btn-sequencer-mute" title="Mute sequencer audio (transport keeps running so sync stays locked)">live</button>
    <input type="range" class="panel-gain-slider" id="sequencer-gain" min="0" max="1" step="0.01" value="0.9" title="Output level (0–1×). Rides the sequencer mix without editing per-pad gain." />
    <button class="ctrl-btn" id="btn-sequencer-sync" title="Realign sequencer to Strudel cycle boundary now" style="display:none">⟲</button>
    <button class="ctrl-btn" id="btn-sequencer-close" title="Close (Q)">×</button>
  </div>
  <div id="sequencer-tabs">
    <button class="sp-tab active" data-tab="grid">grid</button>
    <button class="sp-tab"        data-tab="patterns">patterns</button>
  </div>
  <div id="sequencer-grid">
    <div id="seq-props"></div>
    <div id="seq-matrix-wrap">
      <div id="seq-matrix"></div>
    </div>
  </div>
  <div id="sequencer-patterns" style="display:none">
    <div class="sp-pat-toolbar">
      <button class="ctrl-btn" id="btn-seq-pat-save"   title="Save current grid as a new pattern">save current</button>
      <button class="ctrl-btn" id="btn-seq-pat-new"    title="Replace grid with an empty pattern">new</button>
      <button class="ctrl-btn" id="btn-seq-pat-random" title="Sprinkle some random hits over the default groove">random</button>
    </div>
    <div id="seq-pat-list" class="sp-pat-list"></div>
  </div>
</div>

<!-- Vocoder panel — mic-driven channel vocoder for live narration. Sibling
     of #sequencer-panel so each draggable window stays independent. -->
<div id="vocoder-panel" style="display:none">
  <div id="vocoder-header">
    <span class="sp-title">vox <span class="sp-tag">// vocal fx</span></span>
    <span class="sp-status" id="vocoder-status">click ▶ to start</span>
    <button class="ctrl-btn" id="btn-vocoder-play"  title="Open the mic">▶</button>
    <button class="ctrl-btn" id="btn-vocoder-stop"  title="Close the mic">■</button>
    <button class="ctrl-btn panel-mute-btn" id="btn-vocoder-mute" title="Mute output (mic stays open)">live</button>
    <button class="ctrl-btn" id="btn-vocoder-close" title="Close (W)">×</button>
  </div>
  <div id="vocoder-body">
    <!-- Shared controls — affect every vox effect. -->
    <div id="vox-shared">
      <label class="seq-prop" title="Presets — artistic starting points (Daft Punk, Nightcall, Imogen Heap …). Loading one only sets controls that stay fully editable afterward; it leaves mic / gate / output / feed alone.">
        <span class="seq-prop-label">preset</span>
        <select id="voc-preset" class="ctrl-btn"><option value="">presets…</option></select>
      </label>
      <label class="seq-prop" title="Microphone — shared by every vox effect. 'same as main mic' follows the topbar mic selector; pick a device to give vox its own dedicated input.">
        <span class="seq-prop-label">mic</span>
        <select id="voc-mic" class="ctrl-btn"><option value="">same as main mic</option></select>
      </label>
      <label class="seq-prop voc-range" title="Noise gate — mutes the vocoder and harmonizer when the mic drops below this level. Shared by both; also breaks acoustic feedback at silence. 0 = gate off.">
        <span class="seq-prop-label">gate</span>
        <input type="range" id="voc-gate" min="0" max="1" step="0.01" />
        <span class="qp-val" id="voc-gate-val"></span>
      </label>
      <label class="seq-prop voc-range" title="Master output gain — the whole vox panel.">
        <span class="seq-prop-label">output</span>
        <input type="range" id="voc-output" min="0" max="2" step="0.01" />
        <span class="qp-val" id="voc-output-val"></span>
      </label>
      <label class="seq-prop" title="Feed the vox output into audio-reactive modulation — it joins strudel + sequencer as an audio source, heard by fx and recordings in the 'mix' / 'all' audio modes.">
        <span class="seq-prop-label">feed</span>
        <button id="btn-vocoder-feed" class="ctrl-btn">off</button>
      </label>
    </div>
    <!-- Vocoder effect. -->
    <div id="voc-section" class="vox-section">
      <div id="voc-fx-head" class="vox-sec-head">
        <button class="vox-caret" type="button" title="Collapse / expand">▾</button>
        <span class="seq-prop-label">vocoder</span>
        <button class="ctrl-btn" id="btn-voc-fx" title="Vocoder effect on/off — the mic and the harmonizer stay live when it's off.">on</button>
        <span class="sp-tag">// voice → robot</span>
      </div>
      <div class="vox-sec-body">
        <div id="voc-props" class="voc-props">
          <label class="seq-prop" title="Carrier waveform — drone (saw + sub) is the classic robot timbre; noise gives a whispered/breathy quality.">
            <span class="seq-prop-label">carrier</span>
            <select id="voc-carrier" class="ctrl-btn">
              <option value="drone">drone</option>
              <option value="sawtooth">sawtooth</option>
              <option value="square">square</option>
              <option value="triangle">triangle</option>
              <option value="noise">noise</option>
            </select>
          </label>
          <label class="seq-prop" title="Carrier fundamental in Hz. 100-130 Hz reads as a male robot, 180-240 Hz reads as a female / higher robot.">
            <span class="seq-prop-label">pitch</span>
            <input type="number" id="voc-pitch" class="seq-num seq-num-wide" min="40" max="500" step="1" />
            <span class="seq-prop-label">Hz</span>
          </label>
          <label class="seq-prop" title="Number of analysis bands. More bands = more intelligible but heavier CPU. 24 is a good live default; 40 is clearest but heaviest.">
            <span class="seq-prop-label">bands</span>
            <select id="voc-bands" class="ctrl-btn">
              <option value="8">8</option>
              <option value="16">16</option>
              <option value="24">24</option>
              <option value="32">32</option>
              <option value="40">40</option>
            </select>
          </label>
          <label class="seq-prop" title="Detuned unison oscillators per carrier partial. More voices fill the gaps between harmonics for a thicker, less hollow tone. 1 = single oscillator.">
            <span class="seq-prop-label">voices</span>
            <select id="voc-voices" class="ctrl-btn">
              <option value="1">1</option>
              <option value="3">3</option>
              <option value="5">5</option>
              <option value="7">7</option>
            </select>
          </label>
          <label class="seq-prop voc-range" title="Consonant clarity — blends a pink-noise carrier into the high bands so fricatives (s, sh, f, t) read as noise instead of a pitched whistle. The single biggest intelligibility control.">
            <span class="seq-prop-label">consonant</span>
            <input type="range" id="voc-consonant" min="0" max="1" step="0.01" />
            <span class="qp-val" id="voc-consonant-val"></span>
          </label>
          <label class="seq-prop voc-range" title="High-frequency voice passthrough — preserves sibilants (s, sh, t, f) which a pure vocoder mangles into low buzz.">
            <span class="seq-prop-label">sibilance</span>
            <input type="range" id="voc-sibilance" min="0" max="1" step="0.01" />
            <span class="qp-val" id="voc-sibilance-val"></span>
          </label>
          <label class="seq-prop voc-range" title="Dry voice mix — sends a small amount of unprocessed mic to the output. Default 0; raise if a venue needs extra clarity.">
            <span class="seq-prop-label">dry</span>
            <input type="range" id="voc-dry" min="0" max="1" step="0.01" />
            <span class="qp-val" id="voc-dry-val"></span>
          </label>
        </div>
      </div>
    </div>
    <!-- Master output chain — clarity EQ + dynamics, shared by the vocoder
         and the harmonizer's voice engine. -->
    <div id="voc-output-section" class="vox-section">
      <div class="vox-sec-head">
        <button class="vox-caret" type="button" title="Collapse / expand">▾</button>
        <span class="seq-prop-label">master</span>
        <span class="sp-tag">// clarity eq + dynamics</span>
      </div>
      <div class="vox-sec-body">
        <div class="voc-props">
          <label class="seq-prop voc-range" title="Presence EQ — a lift around 3 kHz where word recognition lives. A little goes a long way for clarity.">
            <span class="seq-prop-label">presence</span>
            <input type="range" id="voc-presence" min="0" max="12" step="0.5" />
            <span class="qp-val" id="voc-presence-val"></span>
          </label>
          <label class="seq-prop voc-range" title="Master compression — keeps quiet syllables audible under loud ones. 0 = near-transparent, 1 = heavy.">
            <span class="seq-prop-label">compress</span>
            <input type="range" id="voc-compress" min="0" max="1" step="0.01" />
            <span class="qp-val" id="voc-compress-val"></span>
          </label>
          <label class="seq-prop voc-range" title="De-esser — tames loud sibilance ('sss', 'sh') with a dynamic 6 kHz shelf cut, so consonant clarity doesn't turn harsh. 0 = off.">
            <span class="seq-prop-label">de-ess</span>
            <input type="range" id="voc-deess" min="0" max="1" step="0.01" />
            <span class="qp-val" id="voc-deess-val"></span>
          </label>
        </div>
      </div>
    </div>
    <div id="harm-section" class="vox-section">
      <div id="harm-head" class="vox-sec-head">
        <button class="vox-caret" type="button" title="Collapse / expand">▾</button>
        <span class="seq-prop-label">harmonizer</span>
        <button class="ctrl-btn" id="btn-harm" title="Harmonizer on/off — independent of the vocoder.">off</button>
        <select id="harm-engine" class="ctrl-btn" title="Engine — robot: the chord drives the vocoder carrier, the robot choir (turns the vocoder on) · voice: pitch-shifts your actual voice — natural, intelligible, standalone.">
          <option value="synth">robot</option>
          <option value="voice">voice</option>
        </select>
        <select id="harm-mode" class="ctrl-btn" title="Chord source — chord: a held chord · keys: tap notes · track: voices follow your pitch, snapped to the key.">
          <option value="picker">chord</option>
          <option value="keys">keys</option>
          <option value="track">track</option>
        </select>
        <button class="ctrl-btn" id="btn-harm-tune" title="Autotune — snap your lead vocal to the nearest scale note so the lead and every harmony land on exact pitches (voice engine).">tune</button>
        <span class="sp-tag" id="harm-chord">—</span>
      </div>
      <div class="vox-sec-body">
        <div id="harm-picker" class="harm-row">
          <label class="seq-prop" title="Chord root note.">
            <span class="seq-prop-label">root</span>
            <select id="harm-root" class="ctrl-btn"></select>
          </label>
          <label class="seq-prop" title="Chord quality.">
            <span class="seq-prop-label">quality</span>
            <select id="harm-quality" class="ctrl-btn"></select>
          </label>
        </div>
        <div id="harm-keys-row" class="harm-row">
          <button class="ctrl-btn" id="harm-oct-down" title="Octave down">▼</button>
          <span class="seq-prop-label" id="harm-oct-label">C4</span>
          <div id="harm-keys"></div>
          <button class="ctrl-btn" id="harm-oct-up" title="Octave up">▲</button>
        </div>
        <div id="harm-track" class="harm-row">
          <label class="seq-prop" title="Musical key the tracked voices snap to.">
            <span class="seq-prop-label">key</span>
            <select id="harm-key" class="ctrl-btn"></select>
          </label>
          <label class="seq-prop" title="Scale — the voices stay inside this key signature as your pitch moves.">
            <span class="seq-prop-label">scale</span>
            <select id="harm-scale" class="ctrl-btn"></select>
          </label>
          <label class="seq-prop" title="Harmony voicing stacked diatonically on the tracked lead.">
            <span class="seq-prop-label">voicing</span>
            <select id="harm-voicing" class="ctrl-btn"></select>
          </label>
        </div>
        <div id="harm-formant-row" class="harm-row">
          <label class="seq-prop voc-range" title="Formant shift — moves the harmony's vocal 'character' without moving its pitch. 0 keeps each voice's natural identity; negative is darker / larger, positive is brighter / smaller. Voice engine only (needs the formant-shift worklet; the granular fallback ignores it).">
            <span class="seq-prop-label">formant</span>
            <input type="range" id="harm-formant" min="-12" max="12" step="1" />
            <span class="qp-val" id="harm-formant-val"></span>
          </label>
        </div>
      </div>
    </div>
    <div id="voc-help">
      Load a <b>preset</b> as a starting point, then tweak freely. ▶ opens the
      mic; <b>vocoder</b> and <b>harmonizer</b> are independent effects on it.
      <b>consonant</b> blends noise into the high bands so words stay crisp;
      <b>master</b> adds clarity EQ + dynamics. Harmonizer engine —
      <b>robot</b>: the chord drives the vocoder carrier (robot choir);
      <b>voice</b>: pitch-shifts your actual voice for natural harmony, with
      <b>tune</b> (exact pitches) and <b>formant</b> (timbre) control.
      <b>feed</b> routes the output into fx. Section heads collapse.
    </div>
  </div>
</div>

<script>
// All bootstrap logic lives in src/lib/qualia/page-init.js so Astro/Vite
// can resolve the ESM import graph correctly. (Inline scripts in .astro
// files are emitted verbatim and would 404 on the relative paths.)
import { initQualiaPage } from '../../lib/qualia/page-init.js';
initQualiaPage();
</script>

</body>
</html>
