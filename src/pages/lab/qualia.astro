---
// Qualia — pluggable visualizer harness. The shell here is intentionally
// thin; everything reactive lives in src/lib/qualia/. Adding a new fx is
// one new file in src/lib/qualia/fx/<name>.js plus a register() call below.
import { execSync } from 'node:child_process';

// Build stamp — short commit + commit timestamp + build timestamp.
// Baked at build time so the deployed page can be verified against the
// latest commit (avoids "is my browser serving a stale cache?" guesswork).
// Surfaced three ways: <meta name="voidstar-build"> in view-source,
// window.__VOIDSTAR_BUILD__ in the console, and a row at the top of the
// diag panel. Same helper lives in BaseLayout.astro for non-lab pages;
// qualia is standalone (doesn't wrap BaseLayout) so we recompute here.
function readBuildStamp() {
  let commit = '?', commitISO = '?';
  try { commit    = execSync('git rev-parse --short HEAD').toString().trim(); } catch {}
  try { commitISO = execSync('git log -1 --format=%cI').toString().trim();   } catch {}
  return { commit, commitISO, builtAt: new Date().toISOString() };
}
const buildStamp = readBuildStamp();
// Compact form for the diag panel readout — `<sha> · built YYYY-MM-DD HH:MM Z`.
const buildStampShort = `${buildStamp.commit} · built ${buildStamp.builtAt.slice(0, 16).replace('T', ' ')}Z`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Qualia | voidstar lab</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/icon-192.png" />
  <!-- Qualia uses its own manifest so installing from this page anchors
       start_url to /lab/qualia (the default manifest's start_url is /
       so installs from that page would always boot to home). -->
  <link rel="manifest" href="/manifest-qualia.webmanifest" />
  <meta name="theme-color" content="#05050d" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="qualia" />
  <meta name="voidstar-build" content={`${buildStamp.commit} · committed ${buildStamp.commitISO} · built ${buildStamp.builtAt}`} />

  <!-- Build stamp on window + console — every page can be verified against
       the latest deploy independent of the debug overlay. Run this BEFORE
       the SW registration so the SW boot log lands after the build log in
       DevTools order. -->
  <script is:inline define:vars={{ build: buildStamp }}>
    window.__VOIDSTAR_BUILD__ = build;
    console.log('[voidstar/qualia] build ' + build.commit
      + ' · committed ' + build.commitISO
      + ' · built ' + build.builtAt);
  </script>

  <!-- Register the PWA service worker (skipped on local dev hosts so
       Astro's HMR isn't fighting cached assets). -->
  <script is:inline>
    if ('serviceWorker' in navigator
        && !/^(localhost|127\.|0\.0\.0\.0|192\.168\.|10\.)/.test(location.hostname)) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      });
    }
  </script>

  <!-- Mobile diagnostics — same as BaseLayout, but inlined here because
       /lab/qualia/ is a standalone page (doesn't wrap BaseLayout). See
       BaseLayout.astro for full notes; in short: ?debug=1 injects Eruda
       + shows a "DBG" status badge in the corner so users can confirm
       the script ran even if the CDN is blocked. ?debug=0 disables. -->
  <script is:inline>
    (function () {
      try {
        var qs = new URLSearchParams(location.search);
        var qDebug = qs.get('debug');
        var KEY = 'voidstar.debug.console';
        if (qDebug === '0' || qDebug === 'off') {
          localStorage.removeItem(KEY);
          console.log('[voidstar] debug console disabled');
          return;
        }
        if (qDebug === '1' || qDebug === 'eruda' || qDebug === 'on') {
          localStorage.setItem(KEY, 'eruda');
        }
        if (localStorage.getItem(KEY) !== 'eruda') return;
        console.log('[voidstar] debug=eruda — loading overlay…');

        var badge = null;
        function ensureBadge() {
          if (badge || !document.body) return badge;
          badge = document.createElement('div');
          badge.id = 'voidstar-debug-badge';
          badge.textContent = 'DBG…';
          var b = window.__VOIDSTAR_BUILD__ || {};
          badge.title = 'voidstar build ' + (b.commit || '?')
            + (b.builtAt ? ' · built ' + b.builtAt : '')
            + ' — tap to open console; long-press to disable';
          var s = badge.style;
          s.position = 'fixed';
          s.top = 'calc(env(safe-area-inset-top, 0px) + 6px)';
          s.right = '6px';
          s.zIndex = '2147483647';
          s.padding = '2px 6px';
          s.borderRadius = '4px';
          s.font = '11px ui-monospace, Menlo, Consolas, monospace';
          s.background = 'rgba(0,0,0,0.72)';
          s.color = '#ffc857';
          s.border = '1px solid #ffc857';
          s.pointerEvents = 'auto';
          s.cursor = 'pointer';
          var pressTimer = null;
          badge.addEventListener('click', function () {
            try { window.eruda && window.eruda.show(); } catch (_) {}
          });
          badge.addEventListener('touchstart', function () {
            pressTimer = setTimeout(function () {
              localStorage.removeItem(KEY);
              location.reload();
            }, 1200);
          });
          badge.addEventListener('touchend', function () { clearTimeout(pressTimer); });
          document.body.appendChild(badge);
          return badge;
        }
        function setBadge(text, color) {
          var b = ensureBadge();
          if (!b) return;
          b.textContent = text;
          b.style.color = color;
          b.style.borderColor = color;
        }
        function bootEruda() {
          if (!window.eruda) {
            console.error('[voidstar] eruda failed to load (CDN blocked?). '
              + 'Try chrome://inspect remote debugging instead.');
            setBadge('DBG!', '#ff5e7e');
            return;
          }
          try {
            window.eruda.init();
            console.log('[voidstar] eruda initialized — tap the gear (or the badge).');
            setBadge('DBG', '#7cf2a5');
          } catch (e) {
            console.error('[voidstar] eruda.init() threw', e);
            setBadge('DBG!', '#ff5e7e');
          }
        }
        function loadFrom(src, next) {
          var s = document.createElement('script');
          s.src = src;
          s.crossOrigin = 'anonymous';
          s.onload  = bootEruda;
          s.onerror = next || function () {
            console.error('[voidstar] eruda CDN unreachable:', src);
            setBadge('DBG!', '#ff5e7e');
          };
          document.head.appendChild(s);
        }
        function start() {
          ensureBadge();
          loadFrom('https://cdn.jsdelivr.net/npm/eruda', function () {
            loadFrom('https://unpkg.com/eruda', null);
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', start);
        } else {
          start();
        }
      } catch (e) {
        try { console.error('[voidstar] debug-script error', e); } catch (_) {}
      }
    })();
  </script>
  <style is:global>
    /* Hydra runs UNDER the viz so qualia patterns + pose skeleton overlay
       appear on top. Same z-index map as cymatics so Strudel patterns that
       call .out(o0) keep working. */
    #hydra-canvas {
      position: fixed; inset: 0; width: 100%; height: 100%; display: block;
      z-index: 1; pointer-events: none;
    }
    /* Canvases that QualiaCore creates inside #qualia-host inherit fullscreen
       fixed positioning. mix-blend-mode:screen lets near-black fill reveal
       Hydra underneath. 100dvh tracks the dynamic viewport (handles the
       Chrome URL bar collapse on Android without leaving a black band).

       Geometry is driven by the --viz-* vars (defaults = full viewport) so
       split-screen mode can shrink the fx panel to one half WITHOUT changing
       the canvas's stacking sibling relationship to #hydra-canvas (the canvas
       stays a fixed body-level layer, so mix-blend-mode:screen still composites
       against Hydra). The host stays unpositioned/zero-size; the page calls
       core.refreshSize() after a var change to re-sync the backing buffer,
       since the ResizeObserver watches the host, not the fixed canvas. */
    #qualia-host > canvas {
      position: fixed;
      left: var(--viz-left, 0px); top: var(--viz-top, 0px);
      width: var(--viz-w, 100vw); height: var(--viz-h, 100dvh);
      display: block; z-index: 2; mix-blend-mode: screen;
    }

    /* ── Split-screen stage ────────────────────────────────────────────────
       body.split-v → fx panel | camera (side by side)
       body.split-h → fx panel / camera (stacked)
       --split-ratio is the fx panel's fraction of the axis (0.18–0.82),
       driven live by the splitter drag in page-init.js. */
    body.split-v {
      --viz-left: 0px; --viz-top: 0px;
      --viz-w: calc(var(--split-ratio, 0.5) * 100vw); --viz-h: 100dvh;
    }
    body.split-h {
      --viz-left: 0px; --viz-top: 0px;
      --viz-w: 100vw; --viz-h: calc(var(--split-ratio, 0.5) * 100dvh);
    }
    body.split-dragging { user-select: none; -webkit-user-select: none; }
    body.split-dragging #video { transition: none; }

    /* Splitter handle — a thin draggable bar at the panel boundary. Above the
       camera (17) but below the topbar (20). */
    #cam-splitter {
      position: fixed; z-index: 18; display: none; touch-action: none;
      background: transparent;
    }
    body.split-v #cam-splitter, body.split-h #cam-splitter { display: block; }
    body.split-v #cam-splitter {
      top: 0; height: 100dvh; width: 16px;
      left: calc(var(--split-ratio, 0.5) * 100vw); transform: translateX(-50%);
      cursor: col-resize;
    }
    body.split-h #cam-splitter {
      left: 0; width: 100vw; height: 16px;
      top: calc(var(--split-ratio, 0.5) * 100dvh); transform: translateY(-50%);
      cursor: row-resize;
    }
    /* Visible grip line + dot, drawn centered in the (wider, easier-to-grab)
       hit area. */
    #cam-splitter::before {
      content: ''; position: absolute;
      background: var(--border); box-shadow: 0 0 0 1px rgba(0,0,0,0.4);
    }
    body.split-v #cam-splitter::before { left: 50%; top: 0; width: 2px; height: 100%; transform: translateX(-50%); }
    body.split-h #cam-splitter::before { top: 50%; left: 0; height: 2px; width: 100%; transform: translateY(-50%); }
    #cam-splitter:hover::before, body.split-dragging #cam-splitter::before { background: var(--accent); }
  </style>
  <!-- `is:global` is required because most of qualia's UI (sequencer pads,
       cells, prop inputs, pattern-row chrome, etc.) is built at runtime via
       document.createElement in src/lib/qualia/sequencer.js and friends.
       Astro's default scoped <style> hashes selectors with
       `[data-astro-cid-…]`, which is only attached to elements present in
       this .astro file at build time — so dynamically-created nodes match
       NONE of those rules and inherit raw UA defaults (which on Android
       Chrome means seq cells render as tiny default-button white pills).
       qualia.astro is a standalone page (no shared layout), so going
       global has no cross-page bleed risk. -->
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --accent:    #8b5cf6;
      --cyan:      #22d3ee;
      --pink:      #f472b6;
      --green:     #4ade80;
      --amber:     #fbbf24;
      --void:      #05050d;
      --surface:   rgba(10,10,26,0.82);
      --surface-2: rgba(15,15,36,0.65);
      --border:    rgba(45,45,80,0.7);
      --text:      #dde1f0;
      --muted:     #7878a8;
      --font-mono: 'JetBrains Mono', ui-monospace, monospace;
    }
    html, body { width: 100%; height: 100%; overflow: hidden; background: var(--void); }
    #test-canvas {
      position: fixed; inset: 0; width: 100%; height: 100%; display: block;
      z-index: 5; pointer-events: none; background: transparent;
    }

    #video {
      position: fixed; bottom: 1.25rem; right: 1.25rem;
      width: 200px; height: auto; display: none;
      border-radius: 8px; border: 1px solid var(--border);
      /* z-index 17 keeps the live preview above #panel-tabs (16) and
         #panel-stack (15) — without this the preview renders behind the
         mobile tab bar and the user sees a "camera not working" black
         strip in the bottom-right. Preview modes (small/large) are
         fully opaque; only size-full fades down (it's a backdrop). */
      opacity: 1; z-index: 17;
      transform: scaleX(-1);
      transition: opacity 0.2s, width 0.3s;
      /* Touch handlers (tap / double-tap / long-press / drag) live in
         page-init.js. Disabling default browser touch actions on the
         element lets the JS handler see horizontal/vertical movement
         without the browser hijacking it for native scroll/zoom. */
      touch-action: none;
      user-select: none;
      -webkit-user-select: none;
      -webkit-touch-callout: none;
    }
    /* When the user drags the preview around, we suspend the size CSS
       transition — without this the smooth size transition fights with
       the per-frame top/left updates and the element lags behind the
       finger. */
    #video.dragging { transition: opacity 0.2s; cursor: grabbing; }
    #video.visible { display: block; }
    #video.visible.hidden     { opacity: 0; pointer-events: none; }
    #video.visible.size-large { width: 420px; }
    #video.visible.size-full {
      top: 0; left: 0; right: 0; bottom: 0;
      width: 100vw; height: 100dvh;
      opacity: 0.22; border-radius: 0; border: none;
      object-fit: contain; background: black;
    }
    /* Split-screen camera panel — fills the half opposite the fx stage.
       Higher specificity (body class + #video + .visible) than the size-*
       rules above, so it wins without needing to strip those classes; the
       JS just clears the inline bottom/right offsets when entering split. */
    body.split-v #video.visible, body.split-h #video.visible {
      opacity: 1; border: none; border-radius: 0;
      right: auto; bottom: auto; object-fit: cover; background: var(--void);
    }
    body.split-v #video.visible {
      left: calc(var(--split-ratio, 0.5) * 100vw); top: 0;
      width: calc((1 - var(--split-ratio, 0.5)) * 100vw); height: 100dvh;
    }
    body.split-h #video.visible {
      left: 0; top: calc(var(--split-ratio, 0.5) * 100dvh);
      width: 100vw; height: calc((1 - var(--split-ratio, 0.5)) * 100dvh);
    }

    /* Topbar always uses the column layout — title row on top, control
       buttons below — across every viewport. Keeps the upper-right corner
       (strudel + zen) and the title row free of any wrapping-button
       contention regardless of window width. */
    #topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 20;
      display: flex; flex-direction: column; align-items: stretch; gap: 0.4rem;
      padding: 0.5rem 0.9rem;
      background: var(--surface); backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      font-family: var(--font-mono); font-size: 0.75rem;
      transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), opacity 0.35s ease;
    }
    #topbar.zen { transform: translateY(-110%); opacity: 0; pointer-events: none; }
    /* Title row: experiment label on the left, strudel + zen on the right.
       Shared horizontal flex row (siblings, not absolute overlay) so the
       boxes can't overlap — each takes its natural space. */
    #topbar-titlerow {
      display: flex; align-items: center; gap: 1rem;
      justify-content: space-between;
    }
    #topbar-left  {
      display: flex; align-items: center; gap: 0.7rem;
      min-width: 0;       /* allow flex-shrink so long titles ellipsis */
      white-space: nowrap; overflow: hidden;
      flex: 1 1 auto;
    }
    /* Controls row — wrapping flex of all the toggle buttons. Sits on its
       own row below the title; never collides with the corner. */
    #topbar-right { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }

    /* Strudel + zen pinned to the right end of the title row. Same vertical
       slot as #zen-handle (which fades in at top-right when zen mode hides
       the toolbar) so the tap zone is muscle-memory stable across modes. */
    #topbar-corner {
      display: flex; align-items: center; gap: 0.5rem;
      flex: 0 0 auto;     /* don't shrink — keep both buttons readable */
    }

    .back-link { color: var(--muted); text-decoration: none; display: flex; align-items: center; gap: 0.35rem; }
    .back-link:hover { color: var(--accent); }
    .experiment-title { color: var(--text); font-weight: 500; }
    .experiment-tag   { color: var(--accent); overflow: hidden; text-overflow: ellipsis; min-width: 0; }
    #fps     { color: var(--muted); min-width: 5ch; }
    #fxname  { color: var(--cyan);  min-width: 8ch; }
    #lvl     { color: var(--muted); min-width: 11ch; font-size: 0.72rem; }

    .ctrl-btn {
      background: none; border: 1px solid var(--border); border-radius: 5px;
      color: var(--muted); font-family: var(--font-mono); font-size: 0.75rem;
      padding: 0.25rem 0.6rem; cursor: pointer;
      transition: all 0.15s; white-space: nowrap;
      text-decoration: none; display: inline-block;
    }
    .ctrl-btn:hover  { border-color: var(--accent); color: var(--accent); }
    .ctrl-btn:disabled { opacity: 0.3; cursor: default; pointer-events: none; }
    .ctrl-btn.active { border-color: var(--cyan);   color: var(--cyan);   }
    .ctrl-btn.active-audio { border-color: var(--pink); color: var(--pink); }
    select.ctrl-btn {
      max-width: 200px; appearance: none;
      padding-right: 1.2rem;
      background-image: linear-gradient(45deg, transparent 50%, var(--muted) 50%),
                        linear-gradient(135deg, var(--muted) 50%, transparent 50%);
      background-position: calc(100% - 10px) 50%, calc(100% - 5px) 50%;
      background-size: 5px 5px; background-repeat: no-repeat;
    }
    select.ctrl-btn option { background: var(--surface); color: var(--text); }

    /* Dynamic-text buttons: lock min-width to the longest possible label so
       the topbar/popover layout doesn't reflow (and re-wrap) every time the
       auto-cycle/phase timer ticks down a digit or a label flips. Sized in
       `ch` (mono font) against the widest reachable string for each id. */
    #btn-cycle, #btn-phase    { min-width: 13ch; } /* "cycle 45s (♪)" */
    #btn-cycle-beat,
    #btn-phase-beat           { min-width: 11ch; } /* "♪ cycle off" */
    #btn-audio                { min-width: 13ch; } /* "audio strudel" */
    #btn-camera               { min-width: 9ch;  } /* "cam large" */
    #btn-cam-rotate           { min-width: 8ch;  } /* "rot 270°" */
    #btn-cam-split            { min-width: 8ch;  } /* "split horiz" */
    #btn-cursor               { min-width: 15ch; } /* "cursor combined" */
    #btn-pause                { min-width: 6ch;  } /* "paused" */
    #btn-ascii                { min-width: 10ch; } /* "ascii blip" */
    #btn-mosh, #btn-edge      { min-width: 9ch;  } /* "mosh blip" */
    #btn-record-mode          { min-width: 8ch;  } /* "viewport" */

    /* Topbar group popovers — each `.qg-group` owns a trigger button + a
       hidden popover containing the original buttons unchanged. Click the
       trigger to open; click outside to close; click another trigger to
       swap. The trigger gets a dot on its caret when any descendant
       button is active so users can scan group state at a glance. */
    .qg-group { position: relative; display: inline-flex; }
    .qg-trigger { display: inline-flex; align-items: center; gap: 0.25rem; }
    .qg-trigger .qg-caret {
      font-size: 0.7rem; opacity: 0.65; line-height: 1;
      transition: transform 0.15s ease;
    }
    .qg-trigger[aria-expanded="true"] {
      border-color: var(--accent); color: var(--accent);
    }
    .qg-trigger[aria-expanded="true"] .qg-caret { transform: rotate(180deg); }
    /* Active dot — a tiny pink pip on the trigger when any child button
       has .active or .active-audio. Same width on/off so toggles inside
       the popover don't reflow the topbar. */
    .qg-trigger.qg-has-active::before {
      content: ""; width: 6px; height: 6px; border-radius: 50%;
      background: var(--pink); margin-right: 0.35rem;
      box-shadow: 0 0 6px var(--pink);
    }
    .qg-popover {
      position: absolute; top: calc(100% + 0.35rem); left: 0;
      z-index: 30;
      display: none; flex-direction: row; flex-wrap: wrap;
      gap: 0.4rem;
      padding: 0.5rem;
      background: var(--surface); backdrop-filter: blur(10px);
      border: 1px solid var(--border); border-radius: 8px;
      box-shadow: 0 12px 28px rgba(0,0,0,0.45);
      min-width: max-content;
      max-width: min(92vw, 520px);
      max-height: calc(100dvh - var(--topbar-h, 4.5rem) - 1rem);
      overflow: auto;
    }
    .qg-group.open > .qg-popover { display: flex; }
    /* On narrow viewports the popover may overflow the right edge of the
       screen. page-init.js flips this class to pin it to the trigger's
       right edge instead of its left edge. */
    .qg-popover.right-aligned { left: auto; right: 0; }
    /* On mobile, drop the trigger-anchored positioning entirely and turn
       the popover into a full-width drawer below the topbar. The
       previous trigger-relative layout pushed wider popovers off-screen
       (left edge clipped) when the right-aligned flip kicked in on a
       trigger sitting near the left half of the toolbar. */
    @media (max-width: 768px), (pointer: coarse) {
      .qg-popover,
      .qg-popover.right-aligned {
        position: fixed;
        top:    calc(var(--topbar-h, 4.5rem) + 0.35rem);
        left:   max(0.5rem, env(safe-area-inset-left));
        right:  max(0.5rem, env(safe-area-inset-right));
        bottom: auto;
        min-width: 0;
        max-width: none;
        max-height: calc(100dvh - var(--topbar-h, 4.5rem) - var(--tabs-h, 2.4rem) - 1.5rem);
      }
    }

    #zen-handle {
      position: fixed; top: 0; right: 1rem; z-index: 25;
      width: 44px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; opacity: 0; pointer-events: none;
      transition: opacity 0.5s ease;
    }
    #zen-handle.visible { opacity: 1; pointer-events: auto; }
    .zen-icon {
      font-size: 1.4rem; color: var(--accent); opacity: 0.8;
      animation: zen-spin 14s linear infinite;
      filter: drop-shadow(0 0 8px var(--accent)) drop-shadow(0 0 16px var(--accent));
      user-select: none; line-height: 1;
    }
    @keyframes zen-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

    #status-overlay {
      position: fixed; inset: 0; z-index: 30;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 1.25rem;
      background: rgba(5,5,13,0.93); font-family: var(--font-mono);
      transition: opacity 0.5s;
    }
    #status-overlay.hidden { opacity: 0; pointer-events: none; }
    .status-title { font-size: 1.1rem; color: var(--text); letter-spacing: 0.08em; }
    .status-msg   { font-size: 0.8rem; color: var(--muted); letter-spacing: 0.05em; }
    .status-sub   { font-size: 0.72rem; color: var(--muted); opacity: 0.7; max-width: 32rem; text-align: center; line-height: 1.6; }
    .status-dot   {
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--accent); box-shadow: 0 0 12px var(--accent);
      animation: pulse 1.4s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100% { opacity:0.4; transform:scale(0.9); } 50% { opacity:1; transform:scale(1.2); } }
    .start-btn {
      margin-top: 0.5rem; padding: 0.65rem 1.5rem;
      background: var(--accent); border: none; border-radius: 6px;
      color: white; font-family: var(--font-mono); font-size: 0.875rem;
      cursor: pointer; transition: all 0.2s;
    }
    .start-btn:hover { background: #7c3aed; box-shadow: 0 0 20px rgba(139,92,246,0.5); }
    .start-btn.alt {
      background: transparent; border: 1px solid var(--border);
      color: var(--muted); margin-top: 0;
    }
    .start-btn.alt:hover { border-color: var(--cyan); color: var(--cyan); box-shadow: none; }

    /* Param panel — bottom-left HUD that builds itself from the active fx's
       schema. Audio panel is a sibling row above it. The stack is height-
       capped to (viewport − topbar − margin) and scrolls internally so that
       expanding several cards never lets them slide under the fixed topbar.
       --topbar-h is exposed by page-init.js so this stays in sync with
       however tall the dynamic column-flex topbar happens to be. */
    #panel-stack {
      position: fixed;
      bottom: max(1.25rem, env(safe-area-inset-bottom));
      left:   max(1.25rem, env(safe-area-inset-left));
      z-index: 15;
      display: flex; flex-direction: column-reverse; gap: 0.5rem;
      max-width: min(94vw, 340px);
      max-height: calc(100dvh - var(--topbar-h, 4.5rem) - 1.5rem);
      overflow-y: auto; overflow-x: hidden;
      scrollbar-width: thin;
      /* Touch scrolling inside the stack should not bubble up and trigger
         our canvas swipe-to-cycle gesture. */
      overscroll-behavior: contain;
    }
    #panel-stack::-webkit-scrollbar { width: 6px; }
    #panel-stack::-webkit-scrollbar-thumb {
      background: var(--border); border-radius: 3px;
    }
    .qp-card {
      background: var(--surface); backdrop-filter: blur(12px);
      border: 1px solid var(--border); border-radius: 10px;
      padding: 0.65rem 0.8rem; font-family: var(--font-mono);
      font-size: 0.72rem; color: var(--text);
      display: flex; flex-direction: column; gap: 0.45rem;
    }

    /* Tab bar for the bottom-left card stack. Hidden on desktop — the
       free-stack with collapsible cards is fine when there's vertical
       space. On mobile / coarse pointer the bar shows pinned to the
       bottom of the viewport (NOT inside #panel-stack), so the cards
       above it scroll independently while the tabs stay reachable. The
       row is horizontally scrollable with snap so a phone screen can
       fit ~5 tabs visible at once with the rest reachable by scroll. */
    .qp-tabs {
      display: none;
      position: fixed;
      left:   max(0.5rem, env(safe-area-inset-left));
      right:  max(0.5rem, env(safe-area-inset-right));
      bottom: max(0.5rem, env(safe-area-inset-bottom));
      z-index: 16;
      flex-direction: row; gap: 0.3rem;
      padding: 0.3rem 0.4rem;
      background: var(--surface); backdrop-filter: blur(12px);
      border: 1px solid var(--border); border-radius: 8px;
      overflow-x: auto;
      scrollbar-width: thin;
      scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch;
      flex-shrink: 0;
      transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), opacity 0.35s ease;
    }
    .qp-tab {
      background: none; border: 1px solid var(--border); border-radius: 4px;
      color: var(--muted); font-family: var(--font-mono); font-size: 0.7rem;
      padding: 0.28rem 0.6rem; cursor: pointer; transition: all 0.15s;
      white-space: nowrap; flex: 0 0 auto;
      scroll-snap-align: start;
    }
    .qp-tab:hover  { color: var(--accent); border-color: var(--accent); }
    .qp-tab.active { color: var(--cyan);   border-color: var(--cyan); background: rgba(34,211,238,0.06); }
    /* Zen mode hides the bottom-left card stack AND the mobile tab bar so
       the viewport is just the active fx. setZen() in page-init also drops
       --tabs-h to 0 so any anchored elements (#video preview) reclaim the
       freed bottom margin. */
    #panel-tabs.zen { transform: translateY(150%); opacity: 0; pointer-events: none; }
    @media (max-width: 768px), (pointer: coarse) {
      .qp-tabs { display: flex; }

      /* On mobile the tab bar is the discovery + navigation surface, so
         the per-card collapsed headers ("audio ▾", "params ▾", …) are
         redundant. Hide collapsed cards entirely; for the active card,
         strip the title + caret from its header and leave only any
         action buttons (e.g. fx-card's `reset`). */
      #panel-stack > .qp-card.collapsed { display: none !important; }
      #panel-stack > .qp-card > .qp-head > .qp-title,
      #panel-stack > .qp-card > .qp-head > .qp-spacer,
      #panel-stack > .qp-card > .qp-head > span:last-child { display: none; }
      /* Compact the header: no padding, sized only to whatever buttons
         remain. Right-align the action buttons with margin-left:auto on
         the first remaining item. */
      #panel-stack > .qp-card > .qp-head {
        padding: 0; min-height: 0; gap: 0.3rem; justify-content: flex-end;
      }
      /* Headers with no remaining visible children (most cards) collapse
         to zero. :has is supported on Chrome / Safari / Firefox 121+
         which covers the user's primary platforms; older browsers just
         see a slightly taller card. */
      #panel-stack > .qp-card > .qp-head:not(:has(button, input, select, a)) {
        display: none;
      }
    }
    .qp-card.collapsed > .qp-body { display: none; }
    .qp-head {
      display: flex; align-items: center; gap: 0.5rem;
      color: var(--muted); cursor: pointer; user-select: none;
    }
    .qp-head .qp-title { color: var(--cyan); }
    .qp-head .qp-spacer { flex: 1; }
    .qp-body { display: flex; flex-direction: column; gap: 0.4rem; }

    .qp-presets {
      display: flex; align-items: center; gap: 0.35rem; flex-wrap: wrap;
    }
    .qp-preset-label { color: var(--muted); margin-right: 0.2rem; }
    .qp-preset {
      background: none; border: 1px solid var(--border);
      border-radius: 4px; color: var(--muted);
      font-family: var(--font-mono); font-size: 0.68rem;
      padding: 0.15rem 0.5rem; cursor: pointer; transition: all 0.15s;
    }
    .qp-preset:hover  { border-color: var(--accent); color: var(--accent); }
    .qp-preset.active { border-color: var(--pink);   color: var(--pink); }

    .qp-row {
      display: grid; grid-template-columns: 1fr auto;
      align-items: center; gap: 0.5rem;
    }
    .qp-row label {
      display: flex; align-items: center; gap: 0.35rem;
      color: var(--text); white-space: nowrap;
    }
    /* The "reactive" indicator dot is rendered inline in ui.js (see
       buildParamPanel) — Astro's per-component CSS scoping doesn't reach
       JS-created elements without the `data-astro-cid-…` attribute. */
    .qp-val { color: var(--cyan); min-width: 5ch; text-align: right; }
    .qp-row input[type=range] {
      width: 130px; accent-color: var(--accent); cursor: pointer;
      /* Bigger hit target for touch — the native track stays slim but the
         slider responds to taps anywhere in the row gutter. Coarse pointers
         (touch-only devices) get an even taller transparent area. */
      height: 22px;
      touch-action: none;
    }
    @media (pointer: coarse) {
      .qp-row input[type=range] { height: 28px; width: 160px; }
    }
    .qp-toggle {
      background: none; border: 1px solid var(--border); border-radius: 4px;
      color: var(--muted); font-family: var(--font-mono); font-size: 0.68rem;
      padding: 0.1rem 0.55rem; cursor: pointer; transition: all 0.15s;
    }
    .qp-toggle.active { border-color: var(--pink); color: var(--pink); }
    .qp-select {
      background: var(--surface-2); border: 1px solid var(--border);
      border-radius: 4px; color: var(--text);
      font-family: var(--font-mono); font-size: 0.7rem;
      padding: 0.1rem 0.4rem;
    }
    .qp-section-tag {
      color: var(--muted); font-size: 0.65rem; letter-spacing: 0.06em;
      border-top: 1px dashed var(--border);
      padding-top: 0.4rem; margin-top: 0.1rem;
    }

    /* Modulation pill — small 2-row block, one per modulator.
       Row 1: [name][activity meter]   Row 2: [── weight slider ──]
       Two rows avoids a width fight between name, meter, and the
       native range input on narrow panels. */
    .qp-mods {
      grid-column: 1 / -1;
      display: flex; flex-direction: column; gap: 0.2rem;
      margin: 0.05rem 0 0.1rem 0.5rem;
    }
    .qp-mod-pill {
      display: flex; flex-direction: column; gap: 0.18rem;
      border: 1px solid var(--border); border-radius: 4px;
      padding: 0.18rem 0.45rem 0.22rem;
      line-height: 1.2;
      font-size: 0.62rem; color: var(--muted);
      background: var(--surface-2);
    }
    .qp-mod-pill.audio { border-color: rgba(34,211,238,0.30); color: rgba(34,211,238,0.85); }
    .qp-mod-pill.pose  { border-color: rgba(236,72,153,0.30); color: rgba(236,72,153,0.85); }
    .qp-mod-head {
      display: flex; align-items: center; gap: 0.4rem;
    }
    .qp-mod-name {
      flex: 0 0 auto;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }
    .qp-mod-meter {
      flex: 1; min-width: 24px; height: 3px;
      background: rgba(255,255,255,0.08); border-radius: 2px;
      overflow: hidden; position: relative;
    }
    .qp-mod-meter > span {
      display: block; height: 100%; width: 0%;
      transition: width 70ms linear;
    }
    .qp-mod-pill.audio .qp-mod-meter > span { background: var(--cyan); }
    .qp-mod-pill.pose  .qp-mod-meter > span { background: var(--pink); }
    /* Slider on its own row — full pill width, no width fight. */
    .qp-mods input.qp-mod-weight {
      width: 100%; height: 11px;
      accent-color: var(--accent);
      cursor: pointer; margin: 0; padding: 0;
      display: block;
    }
    .qp-mod-pill.audio input.qp-mod-weight { accent-color: var(--cyan); }
    .qp-mod-pill.pose  input.qp-mod-weight { accent-color: var(--pink); }
    .diag-row { gap: 0.6rem; }
    .diag-row .diag-label { color: var(--text); }
    .diag-row .qp-val     { font-variant-numeric: tabular-nums; }
    /* Build-stamp header at the top of the diag body. Selectable so the
       user can copy the sha into a bug report. Tooltip carries the full
       commit ISO + build ISO for cache-debugging. */
    .diag-build {
      font-family: var(--font-mono); font-size: 0.62rem;
      color: var(--muted); letter-spacing: 0.03em;
      text-align: center;
      padding: 0.1rem 0 0.45rem;
      border-bottom: 1px dashed var(--border);
      margin-bottom: 0.15rem;
      user-select: text; -webkit-user-select: text; cursor: text;
    }
    .diag-build:hover { color: var(--text); }

    #hints {
      position: fixed; bottom: 1.25rem; right: 1.25rem; z-index: 10;
      font-family: var(--font-mono); font-size: 0.68rem; color: var(--muted);
      display: flex; flex-direction: column; gap: 0.25rem; opacity: 0.5;
    }
    kbd {
      display: inline-block; background: rgba(45,45,80,0.8);
      border-radius: 3px; padding: 0 4px; color: var(--text);
    }

    /* Cycle pool manager — modal listing every registered quale with a
       checkbox, deciding whether each one participates in the auto-cycle.
       Rendered dynamically by page-init.js into #cycle-mgr-list. */
    #cycle-mgr-backdrop {
      position: fixed; inset: 0; z-index: 30;
      display: none;
      background: rgba(5, 5, 13, 0.55);
      backdrop-filter: blur(2px);
    }
    #cycle-mgr-backdrop.visible { display: block; }
    #cycle-mgr {
      position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
      z-index: 31;
      display: none;
      flex-direction: column; gap: 0.55rem;
      width: min(92vw, 360px);
      max-height: min(80dvh, 540px);
      padding: 0.75rem 0.85rem 0.85rem;
      background: var(--surface); backdrop-filter: blur(12px);
      border: 1px solid var(--border); border-radius: 10px;
      box-shadow: 0 12px 36px rgba(0,0,0,0.45);
      font-family: var(--font-mono); font-size: 0.74rem; color: var(--text);
    }
    #cycle-mgr.visible { display: flex; }
    #cycle-mgr-head {
      display: flex; align-items: center; gap: 0.6rem;
      color: var(--muted);
    }
    #cycle-mgr-head .cycle-mgr-title { color: var(--cyan); }
    #cycle-mgr-head .cycle-mgr-spacer { flex: 1; }
    #cycle-mgr-bulk {
      display: flex; gap: 0.35rem; flex-wrap: wrap;
    }
    #cycle-mgr-list {
      display: flex; flex-direction: column; gap: 0.2rem;
      overflow-y: auto;
      max-height: calc(80dvh - 7rem);
      padding: 0.1rem 0.1rem 0.1rem 0;
    }
    .cycle-mgr-row {
      display: flex; align-items: center; gap: 0.5rem;
      padding: 0.32rem 0.45rem;
      border: 1px solid var(--border); border-radius: 5px;
      background: var(--surface-2);
      cursor: pointer; user-select: none;
    }
    .cycle-mgr-row:hover { border-color: var(--accent); }
    .cycle-mgr-row input[type=checkbox] {
      accent-color: var(--cyan);
      cursor: pointer;
      width: 14px; height: 14px;
    }
    .cycle-mgr-row .cycle-mgr-name { color: var(--text); }
    .cycle-mgr-row.active .cycle-mgr-name { color: var(--cyan); font-weight: 500; }

    /* Strudel panel — same layout as cymatics so the embed feels familiar. */
    #strudel-panel {
      position: fixed; left: 50%; top: 4.5rem;
      transform: translateX(-50%);
      z-index: 18;
      width: min(96vw, 920px);
      height: 480px;
      min-width: 360px;  min-height: 220px;
      max-width: 100vw;  max-height: calc(100dvh - 6rem);
      background: transparent;
      border: 1px solid var(--border); border-radius: 10px;
      font-family: var(--font-mono); color: var(--text);
      display: flex; flex-direction: column; overflow: hidden;
      box-shadow: 0 12px 36px rgba(0,0,0,0.45);
      resize: both;
    }
    #strudel-header {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.45rem 0.75rem;
      background: var(--surface); backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
      font-size: 0.75rem;
      cursor: grab; user-select: none;
      /* Without this Android (and iOS Safari) hijack the touch for native
         scroll/zoom and our pointer-drag handler only sees a few pixels of
         movement before the browser cancels the pointer. */
      touch-action: none;
    }
    #strudel-header.dragging { cursor: grabbing; }
    #strudel-header .ctrl-btn { cursor: pointer; }
    .sp-title { color: var(--text); }
    .sp-tag   { color: var(--accent); margin-left: 0.25rem; }
    .sp-status { color: var(--muted); margin-left: auto; font-size: 0.7rem; }
    .sp-status.live { color: var(--pink); }
    /* Eval error indicator — shows the last Strudel syntax/runtime error right
       after the panel title. Hidden until set; clears on the next clean eval.
       flex-shrinks with an ellipsis (full text in the title tooltip) so a long
       message never crowds the header controls, including on mobile. */
    .sp-err {
      margin-left: 0.5rem; min-width: 0; flex: 0 1 auto; max-width: 20rem;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      font-size: 0.7rem; color: #ff6b6b; cursor: help;
    }
    #btn-strudel-play, #btn-strudel-stop { padding: 0.1rem 0.55rem; font-size: 0.85rem; line-height: 1; }
    #btn-strudel-play.playing { color: var(--pink); border-color: var(--pink); }
    #btn-strudel-close { padding: 0.1rem 0.55rem; font-size: 0.95rem; line-height: 1; }
    #strudel-tabs {
      display: flex; gap: 0.25rem;
      padding: 0.3rem 0.6rem;
      border-bottom: 1px solid var(--border);
      background: rgba(0,0,0,0.25);
    }
    .sp-tab {
      background: none; border: 1px solid transparent;
      border-radius: 4px; color: var(--muted);
      font-family: var(--font-mono); font-size: 0.72rem;
      padding: 0.18rem 0.6rem; cursor: pointer; transition: all 0.15s;
    }
    .sp-tab:hover  { color: var(--accent); }
    .sp-tab.active { color: var(--cyan); border-color: var(--border); background: rgba(34,211,238,0.06); }
    /* Editor view-option toggle (line numbers). Right-aligned in the tab bar;
       styled like a tab but not one — the tab handler only binds .sp-tab. */
    .sp-opt {
      margin-left: auto;
      background: none; border: 1px solid transparent; border-radius: 4px;
      color: var(--muted); font-family: var(--font-mono); font-size: 0.72rem;
      padding: 0.18rem 0.5rem; cursor: pointer; transition: all 0.15s;
    }
    .sp-opt:hover  { color: var(--accent); }
    .sp-opt.active { color: var(--cyan); border-color: var(--border); background: rgba(34,211,238,0.06); }

    #strudel-patterns {
      flex: 1; min-height: 0; overflow: auto;
      padding: 0.6rem; display: flex; flex-direction: column; gap: 0.5rem;
      color: var(--text); font-family: var(--font-mono); font-size: 0.74rem;
    }
    .sp-pat-toolbar { display: flex; gap: 0.4rem; flex-wrap: wrap; }
    .sp-pat-list   { display: flex; flex-direction: column; gap: 0.3rem; }
    .sp-pat-row {
      display: flex; flex-wrap: wrap;
      align-items: center; gap: 0.4rem;
      padding: 0.4rem 0.5rem;
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--border); border-radius: 6px;
    }
    .sp-pat-meta {
      display: flex; flex-direction: column; gap: 0.15rem;
      min-width: 0; flex: 1 1 9rem;
    }
    .sp-pat-name {
      background: transparent; border: none; outline: none;
      color: var(--cyan); font-family: var(--font-mono); font-size: 0.78rem;
      padding: 0; width: 100%; min-width: 0;
    }
    .sp-pat-name:focus { color: var(--accent); }
    .sp-pat-by { color: var(--muted); font-size: 0.66rem; }
    .sp-pat-actions {
      display: flex; gap: 0.25rem; flex-wrap: wrap;
      flex-shrink: 0; margin-left: auto;
    }
    .sp-pat-actions .ctrl-btn { padding: 0.15rem 0.45rem; font-size: 0.68rem; }
    .sp-pat-empty { color: var(--muted); padding: 0.6rem; text-align: center; }

    /* Qualem panel reuses .sp-pat-* row styling. The body just needs flex
       column + small gap so the toolbar sits cleanly above the list.
       Cap the body height + scroll the list internally — with #panel-stack
       on flex-direction: column-reverse, an uncapped qualem-body pushes
       the qualem-card head upward as the list grows. On Safari/Mac the
       column-reverse scrollbar inside #panel-stack doesn't reliably reach
       that head once it's pushed offscreen, leaving the user unable to
       click "▾" to minimize. Internal scrolling keeps the head pinned.

       NOTE: do NOT set `display` here. The base `.qp-body` rule already
       gives us `display: flex; flex-direction: column;`, and the collapse
       rule `.qp-card.collapsed > .qp-body { display: none }` relies on
       class specificity. An ID selector with `display: flex` would beat
       the collapse rule (1,0,0 > 0,3,0) and the panel would refuse to
       collapse on header click. */
    #qualem-body {
      gap: 0.5rem;
      font-family: var(--font-mono); font-size: 0.74rem;
      max-height: 55vh;
    }
    #qualem-list {
      overflow-y: auto;
      overscroll-behavior: contain;
      scrollbar-width: thin;
      min-height: 0;
    }

    /* Share popover — modal-ish dialog floating over everything else. The
       backdrop swallows outside clicks so the popover behaves like the
       cycle-pool manager (already in use in this page). */
    #qualem-share-backdrop {
      position: fixed; inset: 0; z-index: 99;
      background: rgba(0,0,0,0.5); backdrop-filter: blur(2px);
    }
    #qualem-share {
      position: fixed; z-index: 100;
      left: 50%; top: 50%;
      transform: translate(-50%, -50%);
      width: min(92vw, 520px);
      background: rgba(10,10,26,0.95);
      border: 1px solid var(--border); border-radius: 8px;
      color: var(--text); font-family: var(--font-mono);
      box-shadow: 0 12px 40px rgba(0,0,0,0.6);
      display: flex; flex-direction: column;
    }
    #qualem-share-head {
      display: flex; align-items: center; gap: 0.4rem;
      padding: 0.5rem 0.7rem;
      border-bottom: 1px solid var(--border);
    }
    .qualem-share-title { color: var(--cyan); font-size: 0.78rem; }
    .qualem-share-spacer { flex: 1; }
    #qualem-share-body {
      padding: 0.7rem; display: flex; flex-direction: column; gap: 0.5rem;
    }
    #qualem-share-url {
      width: 100%; min-height: 5rem; resize: vertical;
      background: rgba(0,0,0,0.4); color: var(--cyan);
      border: 1px solid var(--border); border-radius: 4px;
      padding: 0.4rem 0.5rem;
      font-family: var(--font-mono); font-size: 0.7rem;
      word-break: break-all;
    }
    #qualem-share-actions {
      display: flex; align-items: center; gap: 0.4rem;
    }
    .qualem-share-status {
      color: var(--accent); font-size: 0.68rem;
    }
    .qualem-share-hint {
      color: var(--muted); font-size: 0.65rem; line-height: 1.3;
    }

    /* Recording status pill. Two roles depending on which class is set:
       - .rec-active: visible during recording, but COMPACT and pinned
         bottom-center with pointer-events:none so it never obstructs
         topbar menus. The rec button itself shows the timer + color
         change as the primary indicator; this pill is a backup for
         zen / fullscreen mode where the topbar is hidden.
       - .rec-ready (post-stop): bottom-center, larger, interactive,
         with save / dismiss buttons. This one has to capture taps so
         the user gesture cascades into the download. */
    #rec-toast {
      position: fixed;
      left: 50%; transform: translateX(-50%);
      z-index: 50;
      display: flex; align-items: center; gap: 0.5rem;
      background: rgba(10,10,26,0.85);
      border: 1px solid var(--border); border-radius: 999px;
      color: var(--text); font-family: var(--font-mono);
      box-shadow: 0 4px 16px rgba(0,0,0,0.5);
      backdrop-filter: blur(8px);
      max-width: 92vw;
    }
    /* Active recording: compact pill, bottom-center, click-through. */
    #rec-toast.rec-active {
      bottom: calc(env(safe-area-inset-bottom, 0px) + var(--tabs-h, 0px) + 0.6rem);
      padding: 0.2rem 0.6rem;
      font-size: 0.68rem;
      pointer-events: none;     /* taps pass through to whatever's below */
      opacity: 0.85;
    }
    /* Post-stop: bigger, interactive, same bottom anchor. */
    #rec-toast.rec-ready {
      bottom: calc(env(safe-area-inset-bottom, 0px) + var(--tabs-h, 0px) + 0.6rem);
      padding: 0.45rem 0.7rem;
      font-size: 0.74rem;
      border-color: var(--accent);
      color: var(--accent);
    }
    #rec-toast-body { display: flex; align-items: center; gap: 0.35rem; }
    #rec-toast-dot { color: #ff4d4d; }
    #rec-toast.rec-active #rec-toast-dot { animation: rec-pulse 1.4s ease-in-out infinite; }
    #rec-toast.rec-ready #rec-toast-dot { color: var(--accent); animation: none; }
    #rec-toast-actions { display: flex; gap: 0.3rem; }
    #rec-toast-actions .ctrl-btn { padding: 0.15rem 0.55rem; font-size: 0.7rem; }
    @keyframes rec-pulse {
      0%, 100% { opacity: 1; }
      50%      { opacity: 0.25; }
    }

    #strudel-mount {
      flex: 1; min-height: 0; overflow: auto;
      background: transparent;
    }
    #strudel-mount strudel-editor {
      display: block; width: 100%; background: transparent !important;
      --background:        transparent !important;
      --bg:                transparent !important;
      --editor-background: transparent !important;
      --background-color:  transparent !important;
    }
    #strudel-mount strudel-editor,
    #strudel-mount strudel-editor * {
      background:       transparent !important;
      background-color: transparent !important;
      background-image: none        !important;
    }
    #strudel-mount :is(.cm-content, .cm-line) {
      text-shadow: 0 0 4px rgba(0,0,0,0.85), 0 0 2px rgba(0,0,0,0.85);
    }
    #strudel-mount strudel-editor .cm-content .cm-line > *,
    #strudel-mount strudel-editor .cm-line > * {
      background: rgba(0,0,0,0.35) !important;
    }

    /* Mobile-only tweaks — the topbar layout itself is column-flex at every
       width (defined above) so we just dial in tighter spacing and hide
       non-essential pieces here. */
    @media (max-width: 768px) {
      #topbar       { padding: 0.4rem 0.6rem; gap: 0.3rem; font-size: 0.72rem; }
      #topbar-titlerow { gap: 0.6rem; }
      #topbar-left  { gap: 0.6rem; }
      #topbar-right { gap: 0.35rem; }
      #topbar-corner { gap: 0.35rem; }
      #lvl, #fxname { display: none; }
      .ctrl-btn     { padding: 0.32rem 0.6rem; font-size: 0.7rem; }
      #panel-stack  {
        left: max(0.5rem, env(safe-area-inset-left));
        right: max(0.5rem, env(safe-area-inset-right));
        /* Lift above the fixed tab bar (~2.4rem tall incl. padding +
           border) plus the inset/gap. --tabs-h is set live by page-init
           via ResizeObserver so a wrapped tab row doesn't underlap. */
        bottom: calc(max(0.5rem, env(safe-area-inset-bottom)) + var(--tabs-h, 2.4rem) + 0.4rem);
        max-width: none;
        /* Tighter cap on mobile — at most 50% of viewport so the active fx
           stays clearly visible behind the panel. The min() ensures we
           don't overlap the topbar even with a 4-row wrap on a narrow
           screen. */
        max-height: min(50dvh, calc(100dvh - var(--topbar-h, 4.5rem) - var(--tabs-h, 2.4rem) - 1.5rem));
      }
      /* Phone screens are short — the params card eats a lot of canvas.
         Lower the card alpha so the viz remains readable underneath; the
         backdrop-filter blur keeps the text legible. Tabs and topbar
         keep their original alpha — they're thin chrome, not big slabs. */
      .qp-card { background: rgba(10,10,26,0.40); }
      #hints        { display: none; }
      /* Mobile preview: anchor ABOVE the fixed tab bar so it doesn't
         disappear behind it. --tabs-h is published live from page-init.
         applyVideoOffset (drag) reads the same var. */
      #video.visible {
        width: 120px;
        bottom: calc(max(0.5rem, env(safe-area-inset-bottom)) + var(--tabs-h, 2.4rem) + 0.4rem);
        right: max(0.5rem, env(safe-area-inset-right));
      }
      #strudel-panel { top: calc(var(--topbar-h, 5.5rem) + 0.5rem); width: 96vw; height: 60dvh; }
      #sequencer-panel { top: calc(var(--topbar-h, 5.5rem) + 0.5rem); width: 96vw; height: 60dvh; }
      .sp-tag, .sp-status { display: none; }
    }

    /* Sequencer panel — same draggable-window shape as #strudel-panel so
       both panels feel like one family. The grid below ships its own
       layout because RR-style cells × pads have no parallel in Strudel. */
    #sequencer-panel {
      position: fixed; left: 50%; top: 4.5rem;
      transform: translateX(-50%);
      z-index: 18;
      width: min(96vw, 920px);
      height: 480px;
      min-width: 360px;  min-height: 220px;
      max-width: 100vw;  max-height: calc(100dvh - 6rem);
      background: rgba(10,10,26,0.55);
      border: 1px solid var(--border); border-radius: 10px;
      font-family: var(--font-mono); color: var(--text);
      display: flex; flex-direction: column; overflow: hidden;
      box-shadow: 0 12px 36px rgba(0,0,0,0.45);
      backdrop-filter: blur(8px);
      resize: both;
    }
    #sequencer-header {
      display: flex; align-items: center; gap: 0.6rem;
      padding: 0.45rem 0.75rem;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      font-size: 0.75rem;
      cursor: grab; user-select: none;
      touch-action: none;
    }
    #sequencer-header.dragging { cursor: grabbing; }
    #sequencer-header .ctrl-btn { cursor: pointer; }
    .seq-name-input {
      background: transparent; border: 1px solid var(--border);
      border-radius: 4px;
      color: var(--cyan); font-family: var(--font-mono); font-size: 0.75rem;
      padding: 0.15rem 0.45rem; min-width: 8ch; max-width: 18ch;
      outline: none;
    }
    .seq-name-input:focus { border-color: var(--accent); color: var(--accent); }
    #btn-sequencer-play, #btn-sequencer-stop { padding: 0.1rem 0.55rem; font-size: 0.85rem; line-height: 1; }
    #btn-sequencer-play.playing { color: var(--pink); border-color: var(--pink); }
    #btn-sequencer-close { padding: 0.1rem 0.55rem; font-size: 0.95rem; line-height: 1; }
    /* Live/mute toggle — reads as a state badge ("live") in green when
       audio is flowing and switches to a muted-red label when silenced.
       Sized smaller than play/stop so it doesn't compete for the
       primary-action slot. */
    .panel-mute-btn {
      padding: 0.1rem 0.5rem; font-size: 0.7rem; line-height: 1;
      color: var(--cyan); border-color: var(--cyan);
      min-width: 3.5ch; text-align: center;
    }
    .panel-mute-btn.muted {
      color: var(--pink); border-color: var(--pink);
      background: rgba(244, 114, 182, 0.10);
    }
    /* Compact gain slider in the panel header — sits next to the mute/live
       button so the source-level controls cluster together. Narrow enough
       not to crowd the play/stop/close run on phone-width viewports. */
    .panel-gain-slider {
      width: 70px; min-width: 60px;
      accent-color: var(--cyan);
      vertical-align: middle; cursor: pointer;
      margin: 0 0.1rem;
    }
    #sequencer-tabs {
      display: flex; gap: 0.25rem;
      padding: 0.3rem 0.6rem;
      border-bottom: 1px solid var(--border);
      background: rgba(0,0,0,0.25);
    }
    /* Grid pane — properties row above the pad-by-step matrix. Matrix
       scrolls independently so the props row stays pinned. */
    #sequencer-grid { flex: 1; min-height: 0; display: flex; flex-direction: column; }
    #seq-props {
      display: flex; flex-wrap: wrap; gap: 0.4rem 0.7rem;
      padding: 0.35rem 0.7rem;
      background: rgba(0,0,0,0.2);
      border-bottom: 1px solid var(--border);
      font-size: 0.72rem;
    }
    .seq-prop { display: inline-flex; align-items: center; gap: 0.35rem; }
    .seq-prop-check { gap: 0.4rem; }
    .seq-prop-label { color: var(--muted); }
    .seq-num {
      background: rgba(0,0,0,0.3); color: var(--cyan);
      border: 1px solid var(--border); border-radius: 4px;
      font-family: var(--font-mono); font-size: 0.74rem;
      padding: 0.12rem 0.35rem; width: 4.5ch;
      outline: none; text-align: right;
      /* The native UA spinner arrows are too small for touch; we render
         our own [−] / [+] buttons via .seq-num-step instead. Hide the
         defaults so the bare field reads cleanly between them. */
      -moz-appearance: textfield;
    }
    .seq-num::-webkit-inner-spin-button,
    .seq-num::-webkit-outer-spin-button {
      -webkit-appearance: none; margin: 0;
    }
    .seq-num-wide { width: 6ch; }
    .seq-num:focus { border-color: var(--accent); color: var(--accent); }
    /* [−] [input] [+] cluster — the buttons are oversized vs. the native
       UA arrows so a finger can hit them without summoning the OS
       keyboard. Uses inline-flex so the wrapper participates in the
       enclosing flex/wrap layout the same way the bare input did. */
    .seq-num-wrap {
      display: inline-flex; align-items: stretch;
      border-radius: 4px; overflow: hidden;
    }
    .seq-num-wrap .seq-num {
      border-radius: 0; border-left: none; border-right: none;
    }
    .seq-num-step {
      padding: 0.05rem 0.45rem; font-size: 0.85rem; line-height: 1;
      min-width: 1.6rem; text-align: center;
    }
    .seq-num-wrap .seq-num-step:first-child  { border-radius: 4px 0 0 4px; }
    .seq-num-wrap .seq-num-step:last-child   { border-radius: 0 4px 4px 0; }
    .seq-prop-check input[type=checkbox] {
      accent-color: var(--cyan); cursor: pointer;
      width: 14px; height: 14px;
    }
    .seq-sync-status {
      font-size: 0.66rem; color: var(--muted);
      margin-left: 0.15rem;
    }
    .seq-sync-status[data-state="connected"] { color: var(--cyan); }
    .seq-sync-status[data-state="waiting"]   { color: var(--accent); }
    #seq-matrix-wrap {
      flex: 1; min-height: 0; overflow: auto;
      padding: 0.25rem 0.35rem;
    }
    #seq-matrix {
      display: flex; flex-direction: column; gap: 1px;
      min-width: 100%;
    }
    .seq-pad-row {
      display: grid;
      grid-template-columns: 92px minmax(0, 1fr);
      gap: 0.3rem;
      align-items: center;
      margin-bottom: 1px;
    }
    /* Three-column grid (audition / name / mute) keeps the controls tight
       on either edge while the name flexes to fill. Replaces the old
       2-button flex row that doubled the name as a mute toggle. */
    .seq-pad-ctrl {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 0.15rem;
      align-items: center;
    }
    .seq-pad-name {
      min-width: 0;
      padding: 0.05rem 0.25rem;
      font-size: 0.66rem;
      color: var(--text); font-family: var(--font-mono);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .seq-pad-mute {
      padding: 0.05rem 0.3rem; font-size: 0.66rem;
      min-width: 1.4rem; text-align: center;
    }
    .seq-pad-mute.muted {
      color: var(--pink); border-color: var(--pink);
      background: rgba(244, 114, 182, 0.10);
    }
    .seq-pad-audition { padding: 0.05rem 0.35rem; font-size: 0.66rem; }
    .seq-cells {
      display: grid;
      gap: 1px;
      /* `grid-auto-rows` pins the implicit row track to a fixed pixel
         height. `min-height` and per-cell `height` both turned out
         insufficient on Android Chrome — the engine sized the row to the
         button's intrinsic min-content (effectively 0 for an empty
         <button>) and the buttons collapsed to thin pill-dashes. With an
         explicit auto-row, the track is the floor regardless of how the
         child content reports its size. */
      grid-auto-rows: 22px;
      min-height: 22px;
      align-self: stretch;
    }
    .seq-cell {
      /* `appearance: none` strips the user-agent button styling that
         makes Android Chrome ignore explicit `height`/`min-height` on
         empty <button>s in grid layout — that was the actual culprit
         behind the white-dash collapse. With UA styling out of the way
         the height props finally take, but we keep `grid-auto-rows`
         above as a belt-and-braces backstop. */
      appearance: none; -webkit-appearance: none;
      width: 100%; height: 100%; min-width: 0;
      /* OFF-state contrast: solid translucent fill + 1px border on the
         frosted panel backdrop. The cyan ON state fills the whole cell
         so on/off is unmistakable at a glance. */
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.32);
      border-radius: 4px;
      cursor: pointer; padding: 0;
      transition: background-color 0.08s ease, border-color 0.08s ease;
      /* Improves perceived hit area on touch — the visual cell can stay
         compact while the touch slop extends a couple of px in each
         direction. Without this, dense 16-cell rows on a 360-CSS-px
         viewport leave finger-sized gaps you can't actually hit. */
      touch-action: manipulation;
    }
    .seq-cell:hover  { background: rgba(34,211,238,0.18); }
    .seq-cell.on     { background: var(--cyan); border-color: var(--cyan); }
    .seq-cell.on:hover { background: var(--accent); border-color: var(--accent); }
    /* Beat-start gets a brighter left edge so the underlying meter is
       readable at a glance — same visual cue as RR's bold beat divider. */
    .seq-cell.beat-start { border-left: 2px solid var(--accent); }
    /* Current step indicator while playing — outline rather than fill so
       the on/off state stays visible underneath. */
    .seq-cell.cur { outline: 2px solid var(--pink); outline-offset: -1px; }
    #sequencer-patterns {
      flex: 1; min-height: 0; overflow: auto;
      padding: 0.6rem; display: flex; flex-direction: column; gap: 0.5rem;
      color: var(--text); font-family: var(--font-mono); font-size: 0.74rem;
    }
    /* Phone screens: stack the control row ABOVE the cells so the cell
       strip gets the full panel width. Compact tuning — control row sits
       just above the LEDs at minimal padding, cells run 26px tall (still
       finger-tappable in the RR/MPC 24-32px band). Long patterns
       (8 beats × 4 steps) overflow horizontally rather than collapsing. */
    @media (max-width: 700px) {
      #seq-matrix-wrap { padding: 0.2rem 0.25rem; }
      #seq-matrix { gap: 1px; }
      .seq-pad-row {
        grid-template-columns: 1fr;
        gap: 0.1rem;
        margin-bottom: 2px;
        /* Desktop sets `align-items: center` so the label column reads
           centred against the LED strip. Once the rows stack on mobile,
           that alignment lets Android Chrome size the implicit cells
           track to whatever the cell buttons report as their min-content
           height — which collapsed to a few px. Stretch gives the row
           its full intrinsic height back. */
        align-items: stretch;
      }
      .seq-pad-ctrl { width: 100%; gap: 0.15rem; }
      .seq-pad-name { font-size: 0.7rem; padding: 0.08rem 0.3rem; }
      .seq-pad-mute { font-size: 0.7rem; padding: 0.08rem 0.35rem; min-width: 1.5rem; }
      .seq-pad-audition { padding: 0.08rem 0.4rem; font-size: 0.7rem; }
      .seq-cell {
        border-radius: 4px;
        /* Lift OFF contrast another notch on phone displays — outdoor
           glare and lower native gamut still leave 12%/32% white reading
           too softly to scan a 16-cell row at a glance. */
        background: rgba(255,255,255,0.16);
        border-color: rgba(255,255,255,0.42);
      }
      /* 26px keeps the LEDs finger-tappable while letting twice as many
         rows fit on a phone viewport. RR/MPC-class rhythm UIs run 24-36px;
         26 sits at the compact end of that band — paired with the new
         10-voice kit (kick…rim) it keeps the whole strip on-screen on
         a typical 6"-class phone. */
      .seq-cells { gap: 2px; grid-auto-rows: 26px; min-height: 26px; }
      /* Tighten the pinned props row so the matrix gets more vertical
         space — with 10 voices vs. the previous 9 every row of header
         chrome is real estate stolen from the grid. */
      #seq-props {
        padding: 0.2rem 0.4rem;
        gap: 0.25rem 0.45rem;
        font-size: 0.68rem;
      }
      #sequencer-tabs { padding: 0.2rem 0.45rem; }
      .seq-num-step { padding: 0.02rem 0.35rem; min-width: 1.4rem; }
    }

    /* Vocoder panel — same draggable-window shape as #strudel-panel /
       #sequencer-panel. Smaller default footprint than the sequencer because
       the body is just a column of property rows, no grid matrix. */
    #vocoder-panel {
      position: fixed; left: 50%; top: 4.5rem;
      transform: translateX(-50%);
      z-index: 18;
      width: min(96vw, 560px);
      height: auto;
      min-width: 320px;
      max-width: 100vw;  max-height: calc(100dvh - 6rem);
      background: rgba(10,10,26,0.55);
      border: 1px solid var(--border); border-radius: 10px;
      font-family: var(--font-mono); color: var(--text);
      display: flex; flex-direction: column; overflow: hidden;
      box-shadow: 0 12px 36px rgba(0,0,0,0.45);
      backdrop-filter: blur(8px);
      resize: both;
    }
    #vocoder-header {
      display: flex; align-items: center; gap: 0.6rem;
      padding: 0.45rem 0.75rem;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      font-size: 0.75rem;
      cursor: grab; user-select: none;
      touch-action: none;
    }
    #vocoder-header.dragging { cursor: grabbing; }
    #vocoder-header .ctrl-btn { cursor: pointer; }
    #btn-vocoder-play, #btn-vocoder-stop { padding: 0.1rem 0.55rem; font-size: 0.85rem; line-height: 1; }
    #btn-vocoder-play.playing { color: var(--pink); border-color: var(--pink); }
    #btn-vocoder-close { padding: 0.1rem 0.55rem; font-size: 0.95rem; line-height: 1; }
    #vocoder-body {
      flex: 1; min-height: 0; overflow: auto;
      padding: 0.6rem 0.7rem;
      display: flex; flex-direction: column; gap: 0.5rem;
    }
    #vox-shared {
      display: flex; flex-wrap: wrap; gap: 0.5rem 0.9rem;
      font-size: 0.74rem;
    }
    /* Vocoder / master / harmonizer each read as a delineated, collapsible
       container with a click-to-collapse head. */
    .vox-section {
      display: flex; flex-direction: column; gap: 0.4rem;
      padding-top: 0.5rem; border-top: 1px solid var(--border);
      font-size: 0.74rem;
    }
    .vox-sec-head {
      display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
      cursor: pointer; user-select: none;
    }
    .vox-caret {
      padding: 0 0.25rem; font-size: 0.7rem; line-height: 1.3;
      background: none; border: none; color: var(--muted); cursor: pointer;
    }
    .vox-sec-body { display: flex; flex-direction: column; gap: 0.4rem; }
    .vox-section.vox-collapsed .vox-sec-body { display: none; }
    #voc-section.voc-disabled #voc-props { opacity: 0.4; pointer-events: none; }
    .voc-props {
      display: flex; flex-wrap: wrap; gap: 0.5rem 0.9rem;
      font-size: 0.74rem;
    }
    /* Range rows widen the slider so a finger-drag actually has somewhere to
       go on a phone — without flex-grow the slider collapses to its
       intrinsic size and ends up the same width as the label. */
    .voc-range { flex: 1 1 220px; min-width: 200px; }
    .voc-range input[type=range] {
      flex: 1; min-width: 0;
      accent-color: var(--cyan);
    }
    /* Cap the mic <select> so a long device label can't stretch the panel. */
    #voc-mic { max-width: 13rem; }
    #harm-chord {
      margin-left: auto; color: var(--cyan);
      font-variant-numeric: tabular-nums; letter-spacing: 0.02em;
    }
    #harm-section.harm-disabled #harm-picker,
    #harm-section.harm-disabled #harm-keys-row,
    #harm-section.harm-disabled #harm-track,
    #harm-section.harm-disabled #harm-formant-row { opacity: 0.4; pointer-events: none; }
    .harm-row { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    #harm-keys { display: flex; gap: 2px; flex: 1; min-width: 0; }
    .harm-key {
      flex: 1; min-width: 0; padding: 0.35rem 0.1rem;
      font-size: 0.6rem; line-height: 1;
      background: var(--surface); color: var(--text);
      border: 1px solid var(--border); border-radius: 3px;
      cursor: pointer;
    }
    .harm-key.blk { background: var(--void); color: var(--muted); }
    .harm-key.on  { background: var(--cyan); color: var(--void); border-color: var(--cyan); }
    .harm-key:active { transform: translateY(1px); }
    #voc-help {
      color: var(--muted); font-size: 0.66rem; line-height: 1.4;
      padding: 0.3rem 0.1rem 0;
      border-top: 1px solid var(--border);
    }
    @media (max-width: 768px) {
      #vocoder-panel { top: calc(var(--topbar-h, 5.5rem) + 0.5rem); width: 96vw; }
    }
  </style>
</head>
<body>

<!-- QualiaCore creates a <canvas> inside #qualia-host on each fx switch
     (a single canvas can only bind one context type). The host carries the
     CSS slot so the inner canvas inherits position/blend/z-index. -->
<div id="qualia-host"></div>
<canvas id="test-canvas"></canvas>
<video id="video" autoplay playsinline muted></video>
<!-- Split-screen splitter handle. Hidden until a split mode is active
     (body.split-v / body.split-h); drag logic + snap-assist in page-init.js. -->
<div id="cam-splitter" role="separator" aria-label="Resize split"></div>

<div id="topbar">
  <!-- Title row: experiment label + the pinned strudel/zen corner. Sharing
       a flex row instead of stacking with absolute positioning means the
       boxes can't overlap — they each take their natural space. -->
  <div id="topbar-titlerow">
    <div id="topbar-left">
      <a href="/lab" class="back-link">← lab</a>
      <span class="experiment-title">qualia</span>
      <span class="experiment-tag">// what it's like</span>
    </div>
    <div id="topbar-corner">
      <button class="ctrl-btn" id="btn-strudel" title="Strudel REPL (S)">strudel</button>
      <button class="ctrl-btn" id="btn-sequencer" title="Pattern sequencer (Q)">seq</button>
      <button class="ctrl-btn" id="btn-vocoder" title="Vox — vocal fx (W)">vox</button>
      <button class="ctrl-btn" id="btn-record" title="Record (Shift+R)">rec</button>
      <button class="ctrl-btn" id="btn-record-mode" title="Capture mode — viewport (fx + overlay only) or tab (everything visible, including strudel / sequencer / panels via the browser share picker)">viewport</button>
      <button class="ctrl-btn" id="btn-zen" title="Zen mode (Z)">zen</button>
      <button class="ctrl-btn" id="btn-fullscreen" title="Fullscreen (X)">full</button>
    </div>
  </div>
  <!-- Controls row: status indicators + the primary fx picker + audio +
       pause kept inline (highest-frequency actions); everything else
       grouped into category popovers (`camera`, `pose`, `layers`, `post`,
       `auto`) so a phone screen sees ~8 chips instead of ~22. Original
       button IDs are preserved verbatim so every keyboard shortcut and
       page-init.js handler keeps working without changes. -->
  <div id="topbar-right">
    <span id="fps">-- fps</span>
    <span id="fxname">—</span>
    <span id="lvl">b-- m-- h--</span>
    <select id="fx-select" class="ctrl-btn" title="Active fx (V)"></select>
    <select id="mic-select" class="ctrl-btn" title="Choose microphone" style="display:none;"></select>
    <button class="ctrl-btn" id="btn-audio" title="Mic audio (A)">audio</button>

    <div class="qg-group" data-group="camera">
      <button type="button" class="ctrl-btn qg-trigger" data-group-trigger="camera"
              title="Camera controls (C/R/M)" aria-haspopup="true" aria-expanded="false">camera<span class="qg-caret">▾</span></button>
      <div class="qg-popover" role="menu">
        <!-- The camera on/off toggle lives here (rather than in the pose
             popover) because users intuitively look for "start camera"
             under "camera". The select drives the same poseSelect element
             the rest of the code targets — only the visible labels and
             group placement changed. Keyboard shortcut P still cycles. -->
        <select id="pose-source" class="ctrl-btn" title="Camera on/off (P)">
          <option value="off">camera off</option>
          <option value="camera">camera on</option>
        </select>
        <!-- cam-select is the only control still gated by the dynamic
             "are there ≥2 cameras" check (handled by wirePicker). The
             others (size / rotate / mirror) are always visible — they're
             pure toggles that persist either way and surface cleanly when
             the camera comes on. Previously they were inline-hidden until
             pose-source flipped to 'camera', which left the popover
             looking empty when camera startup hiccupped on mobile. -->
        <select id="cam-select" class="ctrl-btn" title="Choose camera" style="display:none;"></select>
        <button class="ctrl-btn active" id="btn-camera"     title="Camera size (C)">camera</button>
        <button class="ctrl-btn"        id="btn-cam-rotate" title="Rotate camera (R)">rot 0°</button>
        <button class="ctrl-btn active" id="btn-cam-mirror" title="Mirror camera (M)">mirror</button>
        <!-- Split-screen: off → vertical (side by side) → horizontal (stacked).
             Both panels are included in viewport screen recordings. -->
        <button class="ctrl-btn"        id="btn-cam-split"  title="Split screen — camera ⟂ visualizer, draggable divider">split</button>
      </div>
    </div>

    <div class="qg-group" data-group="pose">
      <button type="button" class="ctrl-btn qg-trigger" data-group-trigger="pose"
              title="Pose detection (P/J/F/G)" aria-haspopup="true" aria-expanded="false">pose<span class="qg-caret">▾</span></button>
      <div class="qg-popover" role="menu">
        <select id="pose-max" class="ctrl-btn" title="Max poses (1-6)" style="display:none;">
          <option value="1">1 pose</option>
          <option value="2">2 poses</option>
          <option value="3" selected>3 poses</option>
          <option value="4">4 poses</option>
          <option value="5">5 poses</option>
          <option value="6">6 poses</option>
        </select>
        <button class="ctrl-btn active" id="btn-skeleton" title="Skeleton overlay (J)">skeleton</button>
        <button class="ctrl-btn active" id="btn-sparks"   title="Beat sparks (F)">sparks</button>
        <button class="ctrl-btn active" id="btn-aura"     title="Resonance aura (G)">aura</button>
      </div>
    </div>

    <div class="qg-group" data-group="layers">
      <button type="button" class="ctrl-btn qg-trigger" data-group-trigger="layers"
              title="Reactive overlays (B)" aria-haspopup="true" aria-expanded="false">layers<span class="qg-caret">▾</span></button>
      <div class="qg-popover" role="menu">
        <button class="ctrl-btn active" id="btn-ripples" title="Beat ripples (B)">ripples</button>
        <button class="ctrl-btn"        id="btn-cursor"  title="Cursor trail (cycle modes)">cursor off</button>
      </div>
    </div>

    <div class="qg-group" data-group="post">
      <button type="button" class="ctrl-btn qg-trigger" data-group-trigger="post"
              title="Post-process glitches (T/K/E)" aria-haspopup="true" aria-expanded="false">post<span class="qg-caret">▾</span></button>
      <div class="qg-popover" role="menu">
        <button class="ctrl-btn" id="btn-ascii" title="ASCII post (T) — off / on / blip / flip">ascii</button>
        <button class="ctrl-btn" id="btn-mosh"  title="Data-mosh post (K) — off / on / blip / flip">mosh</button>
        <button class="ctrl-btn" id="btn-edge"  title="Edge-detect post (E) — off / on / blip / flip">edge</button>
      </div>
    </div>

    <div class="qg-group" data-group="auto">
      <button type="button" class="ctrl-btn qg-trigger" data-group-trigger="auto"
              title="Auto-cycle + auto-phase (N/L)" aria-haspopup="true" aria-expanded="false">auto<span class="qg-caret">▾</span></button>
      <div class="qg-popover" role="menu">
        <button class="ctrl-btn" id="btn-cycle" title="Auto-cycle between qualia (N)">cycle</button>
        <select id="cycle-style" class="ctrl-btn" title="Auto-cycle style">
          <option value="sequential">sequential</option>
          <option value="random">random</option>
        </select>
        <button class="ctrl-btn" id="btn-cycle-beat" title="Beat-sync cycle: dwell time becomes a minimum, then the next hard kick triggers the switch (silence fallback at 2× dwell). Falls through to time-based when audio is off.">♪ cycle off</button>
        <button class="ctrl-btn" id="btn-phase" title="Auto-phase modes within active quale (L)">phase</button>
        <select id="phase-style" class="ctrl-btn" title="Auto-phase style">
          <option value="chapters">chapters</option>
          <option value="alternate">alternate</option>
          <option value="random">random</option>
          <option value="hold">hold glitch</option>
        </select>
        <button class="ctrl-btn" id="btn-phase-beat" title="Beat-sync phase: dwell time becomes a minimum, then the next beat triggers the next phase step (silence fallback at 2× dwell). Falls through to time-based when audio is off.">♪ phase off</button>
        <button class="ctrl-btn" id="btn-cycle-manage" title="Pick which quales the auto-cycle rotates through">manage</button>
      </div>
    </div>

    <button class="ctrl-btn" id="btn-pause" title="Pause (Space)">pause</button>
    <a href="https://github.com/randbrown" target="_blank" rel="noopener" class="ctrl-btn">source ↗</a>
  </div>
</div>

<div id="zen-handle" title="Exit zen mode (Z)">
  <span class="zen-icon">✦</span>
</div>

<div id="status-overlay">
  <div class="status-dot"></div>
  <div class="status-title">qualia</div>
  <div class="status-msg" id="status-msg">click start to enable microphone</div>
  <div class="status-sub">pluggable visualizer harness — chladni · singularity lens · neural field. audio + pose drive a shared QualiaField; new fx are one file.</div>
  <button class="start-btn" id="start-btn">enable mic →</button>
  <button class="start-btn alt" id="start-silent-btn">start without mic</button>
</div>

<div id="hints">
  <span><kbd>V</kbd> next fx</span>
  <span><kbd>L</kbd> phase</span>
  <span><kbd>N</kbd> cycle</span>
  <span><kbd>T</kbd> ascii</span>
  <span><kbd>K</kbd> mosh</span>
  <span><kbd>E</kbd> edge</span>
  <span><kbd>B</kbd> ripples</span>
  <span><kbd>J</kbd> skeleton</span>
  <span><kbd>F</kbd> sparks</span>
  <span><kbd>G</kbd> aura</span>
  <span><kbd>P</kbd> pose src</span>
  <span><kbd>C</kbd> cam size</span>
  <span><kbd>R</kbd> rotate</span>
  <span><kbd>M</kbd> mirror</span>
  <span><kbd>A</kbd> audio</span>
  <span><kbd>S</kbd> strudel</span>
