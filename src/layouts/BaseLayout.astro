---
import { execSync } from 'node:child_process';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeBoot from '../components/ThemeBoot.astro';
import StyleGuard from '../components/StyleGuard.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

// Build stamp — short commit + commit timestamp + build timestamp.
// Computed in the layout frontmatter so it's available to both the
// in-page <meta> tag (visible via "view source") and the inline debug
// script (where we can't import from JS modules). Git calls fall back
// to '?' so a non-git build env still works.
function readBuildStamp() {
  let commit = '?', commitISO = '?';
  try { commit    = execSync('git rev-parse --short HEAD').toString().trim(); } catch {}
  try { commitISO = execSync('git log -1 --format=%cI').toString().trim();   } catch {}
  return { commit, commitISO, builtAt: new Date().toISOString() };
}
const buildStamp = readBuildStamp();

const {
  title,
  description = 'voidstar — art, code, and the space between.',
  ogImage,
  noIndex,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteTitle = title === 'voidstar' ? 'voidstar' : `${title} | voidstar`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <ThemeBoot />
  <meta name="voidstar-build" content={`${buildStamp.commit} · committed ${buildStamp.commitISO} · built ${buildStamp.builtAt}`} />
  <link rel="canonical" href={canonicalURL} />
  <title>{siteTitle}</title>
  <meta name="description" content={description} />
  {noIndex && <meta name="robots" content="noindex" />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={description} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Twitter/X Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={siteTitle} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/icon-192.png" />

  <!-- PWA: install-as-app on Android Chrome / iOS Safari -->
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#05050d" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="voidstar" />

  <!-- Preload fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;1,300&family=VT323&display=swap" />

  <!-- Register the PWA service worker (skipped on local dev hosts so
       Astro's HMR isn't fighting cached assets). -->
  <script is:inline>
    if ('serviceWorker' in navigator
        && !/^(localhost|127\.|0\.0\.0\.0|192\.168\.|10\.)/.test(location.hostname)) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      });
    }
  </script>
  <StyleGuard />

  <!-- Mobile diagnostics: ?debug=1 (or ?debug=eruda) injects the Eruda
       in-page DevTools overlay so phones can see console errors without
       a USB cable. Sticky via localStorage so PWA navigations keep it.
       Always renders a small "DBG" status badge in the corner so users
       can confirm the script ran even if eruda's CDN is blocked. Tap
       the badge to open eruda; long-press to disable. ?debug=0 also
       disables it. -->
  <script is:inline define:vars={{ build: buildStamp }}>
    // Build stamp is set on window unconditionally so every page can be
    // verified against the latest deploy (eg. `__VOIDSTAR_BUILD__` in the
    // console, or "view source" → look for the meta tag) — independent of
    // whether the debug overlay is enabled.
    window.__VOIDSTAR_BUILD__ = build;
    (function () {
      try {
        var qs = new URLSearchParams(location.search);
        var qDebug = qs.get('debug');
        var KEY = 'voidstar.debug.console';
        if (qDebug === '0' || qDebug === 'off') {
          localStorage.removeItem(KEY);
          console.log('[voidstar] debug console disabled');
          return;
        }
        if (qDebug === '1' || qDebug === 'eruda' || qDebug === 'on') {
          localStorage.setItem(KEY, 'eruda');
        }
        if (localStorage.getItem(KEY) !== 'eruda') return;
        console.log('[voidstar] build ' + build.commit
          + ' · committed ' + build.commitISO
          + ' · built ' + build.builtAt);
        console.log('[voidstar] debug=eruda — loading overlay…');

        // Status badge — appended to body once it exists. Color codes
        // its state so users get a yes/no signal even without a console:
        //   amber  "DBG…"  = script ran, eruda still loading
        //   green  "DBG"   = eruda initialized
        //   red    "DBG!"  = eruda CDN unreachable / init failed
        var badge = null;
        function ensureBadge() {
          if (badge || !document.body) return badge;
          badge = document.createElement('div');
          badge.id = 'voidstar-debug-badge';
          badge.textContent = 'DBG…';
          badge.title = 'voidstar build ' + build.commit
            + ' · committed ' + build.commitISO
            + ' · built ' + build.builtAt
            + ' — tap to open console; long-press to disable';
          var s = badge.style;
          s.position = 'fixed';
          s.top = 'calc(env(safe-area-inset-top, 0px) + 6px)';
          s.right = '6px';
          s.zIndex = '2147483647';
          s.padding = '2px 6px';
          s.borderRadius = '4px';
          s.font = '11px ui-monospace, Menlo, Consolas, monospace';
          s.background = 'rgba(0,0,0,0.72)';
          s.color = '#ffc857';
          s.border = '1px solid #ffc857';
          s.pointerEvents = 'auto';
          s.cursor = 'pointer';
          var pressTimer = null;
          badge.addEventListener('click', function () {
            try { window.eruda && window.eruda.show(); } catch (_) {}
          });
          badge.addEventListener('touchstart', function () {
            pressTimer = setTimeout(function () {
              localStorage.removeItem(KEY);
              location.reload();
            }, 1200);
          });
          badge.addEventListener('touchend', function () { clearTimeout(pressTimer); });
          document.body.appendChild(badge);
          return badge;
        }
        function setBadge(text, color) {
          var b = ensureBadge();
          if (!b) return;
          b.textContent = text;
          b.style.color = color;
          b.style.borderColor = color;
        }

        function bootEruda() {
          if (!window.eruda) {
            console.error('[voidstar] eruda failed to load (CDN blocked?). '
              + 'Try chrome://inspect remote debugging instead.');
            setBadge('DBG!', '#ff5e7e');
            return;
          }
          try {
            window.eruda.init();
            console.log('[voidstar] eruda initialized — tap the gear (or the badge).');
            setBadge('DBG', '#7cf2a5');
          } catch (e) {
            console.error('[voidstar] eruda.init() threw', e);
            setBadge('DBG!', '#ff5e7e');
          }
        }
        function loadFrom(src, next) {
          var s = document.createElement('script');
          s.src = src;
          s.crossOrigin = 'anonymous';
          s.onload  = bootEruda;
          s.onerror = next || function () {
            console.error('[voidstar] eruda CDN unreachable:', src);
            setBadge('DBG!', '#ff5e7e');
          };
          document.head.appendChild(s);
        }
        function start() {
          ensureBadge();
          // jsdelivr first, fall back to unpkg if it 404s or is blocked.
          loadFrom('https://cdn.jsdelivr.net/npm/eruda', function () {
            loadFrom('https://unpkg.com/eruda', null);
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', start);
        } else {
          start();
        }
      } catch (e) {
        try { console.error('[voidstar] debug-script error', e); } catch (_) {}
      }
    })();
  </script>
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
