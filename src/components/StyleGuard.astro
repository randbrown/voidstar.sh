---
// Style guard — self-heal for the "HTML loaded but hashed assets didn't"
// failure mode: a flaky connection mid-load, a poisoned service-worker
// cache, or a deploy-edge skew can leave the page as bare unstyled HTML
// (native buttons, serif text, every popover expanded). Astro hashes
// /_astro/* filenames, so a broken load never fixes itself without a
// reload — bad news mid-performance.
//
// After load, if any stylesheet <link> finished without a usable sheet,
// clear the service-worker registrations + caches and reload ONCE
// (sessionStorage-guarded so a genuinely broken deploy doesn't loop, and
// skipped entirely while offline so the offline fallback cache survives).
---
<script is:inline>
  (function () {
    function styleBroken() {
      var links = document.querySelectorAll('link[rel="stylesheet"]');
      for (var i = 0; i < links.length; i++) {
        try {
          // Same-origin sheets only — a third-party CSS outage (fonts CDN)
          // shouldn't cost us the offline cache.
          if (new URL(links[i].href, location.href).origin !== location.origin) continue;
          // Chromium attaches an EMPTY sheet object to a failed <link>, so
          // "no sheet" alone is not a reliable failure signal — a loaded
          // stylesheet must actually contain rules.
          var sheet = links[i].sheet;
          if (!sheet || sheet.cssRules.length === 0) return true;
        } catch (e) { return true; }
      }
      return false;
    }
    function recover() {
      if (navigator.onLine === false) return;   // offline: cached shell is all we have
      if (!styleBroken()) return;
      var KEY = 'voidstar.styleguard.reloaded';
      try {
        if (sessionStorage.getItem(KEY)) return;
        sessionStorage.setItem(KEY, '1');
      } catch (e) { return; }
      var work = [];
      try {
        if (navigator.serviceWorker && navigator.serviceWorker.getRegistrations) {
          work.push(navigator.serviceWorker.getRegistrations().then(function (rs) {
            return Promise.all(rs.map(function (r) { return r.unregister(); }));
          }));
        }
        if (window.caches && caches.keys) {
          work.push(caches.keys().then(function (ks) {
            return Promise.all(ks.map(function (k) { return caches.delete(k); }));
          }));
        }
      } catch (e) { /* still reload below */ }
      Promise.all(work).catch(function () {}).then(function () { location.reload(); });
    }
    if (document.readyState === 'complete') setTimeout(recover, 400);
    else window.addEventListener('load', function () { setTimeout(recover, 400); });
  })();
</script>
