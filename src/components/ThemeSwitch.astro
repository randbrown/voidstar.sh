---
// Theme switcher control. Renders a compact <select> styled in the mono UI
// language; options + wiring come from src/lib/qualia/theme.js at runtime.
interface Props { class?: string; }
const { class: className = '' } = Astro.props;
---
<label class:list={['theme-switch', className]} title="Switch theme">
  <span class="theme-switch-icon" aria-hidden="true">◑</span>
  <select aria-label="Theme" data-theme-select></select>
</label>

<script>
  import { initThemeControl } from '../lib/qualia/theme.js';
  document.querySelectorAll('select[data-theme-select]').forEach((el) =>
    initThemeControl(el as HTMLSelectElement)
  );
</script>

<style>
  .theme-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
  }
  .theme-switch-icon {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1;
  }
  .theme-switch select {
    appearance: none;
    -webkit-appearance: none;
    background: var(--surface);
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.3rem 1.4rem 0.3rem 0.55rem;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    background-image:
      linear-gradient(45deg, transparent 50%, var(--text-muted) 50%),
      linear-gradient(135deg, var(--text-muted) 50%, transparent 50%);
    background-position: calc(100% - 11px) 50%, calc(100% - 6px) 50%;
    background-size: 5px 5px;
    background-repeat: no-repeat;
  }
  .theme-switch select:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>
