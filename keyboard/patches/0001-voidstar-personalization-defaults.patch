From 23b8c34366fcab5409302ca5167b5f3aff76f096 Mon Sep 17 00:00:00 2001
From: Rand Brown <brown.randy@gmail.com>
Date: Thu, 4 Jun 2026 00:41:39 +0000
Subject: [PATCH] voidstar personalization: arrow row + personal-LM finetuning
 on by default, less aggressive autocorrect, lean on transformer

- PREF_ENABLE_ARROW_ROW default true  (arrow keys, the Samsung gap)
- USE_TRANSFORMER_FINETUNING default true  (on-device personal LM learns your phrases)
- lm_autocorrect_threshold 4.0 -> 8.0  (stop fighting your typed words)
- binary_dict_result_weight 3.4 -> 4.5 (lean on transformer morphology: plural/POS)
---
 java/src/org/futo/inputmethod/latin/uix/Settings.kt       | 3 ++-
 .../futo/inputmethod/latin/uix/settings/pages/Typing.kt   | 3 ++-
 .../inputmethod/latin/xlm/LanguageModelFacilitator.kt     | 8 ++++++--
 3 files changed, 10 insertions(+), 4 deletions(-)

diff --git a/java/src/org/futo/inputmethod/latin/uix/Settings.kt b/java/src/org/futo/inputmethod/latin/uix/Settings.kt
index a775644..3f3c03f 100644
--- a/java/src/org/futo/inputmethod/latin/uix/Settings.kt
+++ b/java/src/org/futo/inputmethod/latin/uix/Settings.kt
@@ -376,7 +376,8 @@ val USE_SYSTEM_VOICE_INPUT = SettingsKey(
 
 val USE_TRANSFORMER_FINETUNING = SettingsKey(
     key = booleanPreferencesKey("useTransformerFinetuning2"),
-    default = false
+    // voidstar: on by default so the on-device personal LM learns your phrases.
+    default = true
 )
 
 val SUGGESTION_BLACKLIST = SettingsKey(
diff --git a/java/src/org/futo/inputmethod/latin/uix/settings/pages/Typing.kt b/java/src/org/futo/inputmethod/latin/uix/settings/pages/Typing.kt
index 0218653..cbdc2cc 100644
--- a/java/src/org/futo/inputmethod/latin/uix/settings/pages/Typing.kt
+++ b/java/src/org/futo/inputmethod/latin/uix/settings/pages/Typing.kt
@@ -814,7 +814,8 @@ val KeyboardSettingsMenu = UserSettingsMenu(
             title = R.string.keyboard_settings_show_arrow_row,
             subtitle = R.string.keyboard_settings_show_arrow_row_subtitle,
             key = Settings.PREF_ENABLE_ARROW_ROW,
-            default = {false},
+            // voidstar: arrow row on by default (the thing Samsung's keyboard lacks).
+            default = {true},
             icon = {
                 Icon(painterResource(id = R.drawable.direction_arrows), contentDescription = null)
             }
diff --git a/java/src/org/futo/inputmethod/latin/xlm/LanguageModelFacilitator.kt b/java/src/org/futo/inputmethod/latin/xlm/LanguageModelFacilitator.kt
index 5c0e099..43f53dc 100644
--- a/java/src/org/futo/inputmethod/latin/xlm/LanguageModelFacilitator.kt
+++ b/java/src/org/futo/inputmethod/latin/xlm/LanguageModelFacilitator.kt
@@ -36,12 +36,16 @@ import kotlin.math.ceil
 
 val AutocorrectThresholdSetting = SettingsKey(
     floatPreferencesKey("lm_autocorrect_threshold"),
-    4.0f
+    // voidstar: raised from 4.0 so the keyboard must be much more confident
+    // before it auto-replaces what you typed -- i.e. it stops fighting you.
+    8.0f
 )
 
 val BinaryDictTransformerWeightSetting = SettingsKey(
     floatPreferencesKey("binary_dict_result_weight"),
-    3.4f
+    // voidstar: raised from 3.4 to lean harder on the transformer LM, which has
+    // real morphological sense (singular/plural, part-of-speech) vs the n-gram dict.
+    4.5f
 )
 
 val AllowTransformerOnNonQWERTYLayouts = SettingsKey(
-- 
2.43.0

